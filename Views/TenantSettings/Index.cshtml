@model ClothInventoryApp.Dto.TenantSettings.TenantSettingsEditDto
@{
    ViewData["Title"] = Localizer["Workspace Settings"];
    var hasEcommerceFeature = ViewBag.HasEcommerceFeature is bool hasFeature && hasFeature;
}

<div class="create-product-shell">
    <div class="create-product-hero">
        <div class="create-product-hero-content">
            <div class="hero-kicker">
                <i class="bi bi-gear-fill"></i>
                <span>@Localizer["Workspace"]</span>
            </div>
            <h1>@Localizer["Workspace Settings"]</h1>
            <p>@Localizer["Control staff access and low-stock alerts for your workspace."]</p>
            <div class="hero-actions">
                <a asp-controller="Home" asp-action="Index" class="btn-soft-light">
                    <i class="bi bi-arrow-left"></i> @Localizer["Back to Overview"]
                </a>
            </div>
        </div>
        <div class="create-product-hero-side">
            <div class="hero-stat-card">
                <div class="hero-stat-icon">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>
                <div class="hero-stat-title">@Localizer["Admin Only"]</div>
                <div class="hero-stat-text">
                    @Localizer["These settings affect staff accounts only. Admins always keep full access."]
                </div>
            </div>
        </div>
    </div>

    <form asp-action="Update" method="post">
        @Html.AntiForgeryToken()

        <div class="create-product-grid">
            <div class="create-main-card">
                <div class="section-header">
                    <div>
                        <h3>@Localizer["Staff Access Control"]</h3>
                        <p>@Localizer["Choose which sections staff can open. Hidden sections are removed completely from staff navigation."]</p>
                    </div>
                </div>

                <div class="staff-toggles-list">
                    <label class="status-toggle-card" for="StaffCanSeeDashboard">
                        <div class="status-toggle-copy">
                            <div class="status-toggle-title">
                                <i class="bi bi-bar-chart-line-fill me-2 settings-icon settings-icon-dashboard"></i>@Localizer["Dashboard"]
                            </div>
                            <div class="status-toggle-text">@Localizer["View overview metrics, sales trends, and business highlights."]</div>
                        </div>
                        <div class="status-toggle-switch">
                            <input asp-for="StaffCanSeeDashboard" class="form-check-input modern-switch" id="StaffCanSeeDashboard" type="checkbox" />
                        </div>
                    </label>

                    <label class="status-toggle-card" for="StaffCanSeeFinance">
                        <div class="status-toggle-copy">
                            <div class="status-toggle-title">
                                <i class="bi bi-cash-coin me-2 settings-icon settings-icon-finance"></i>@Localizer["Finance Dashboard"]
                            </div>
                            <div class="status-toggle-text">@Localizer["View income, expenses, profit, and cashflow pages."]</div>
                        </div>
                        <div class="status-toggle-switch">
                            <input asp-for="StaffCanSeeFinance" class="form-check-input modern-switch" id="StaffCanSeeFinance" type="checkbox" />
                        </div>
                    </label>

                    <label class="status-toggle-card" for="StaffCanSeeProducts">
                        <div class="status-toggle-copy">
                            <div class="status-toggle-title">
                                <i class="bi bi-box-seam-fill me-2 settings-icon settings-icon-products"></i>@Localizer["Products"]
                            </div>
                            <div class="status-toggle-text">@Localizer["View product list and product details."]</div>
                        </div>
                        <div class="status-toggle-switch">
                            <input asp-for="StaffCanSeeProducts" class="form-check-input modern-switch" id="StaffCanSeeProducts" type="checkbox" />
                        </div>
                    </label>

                    <label class="status-toggle-card" for="StaffCanSeeVariants">
                        <div class="status-toggle-copy">
                            <div class="status-toggle-title">
                                <i class="bi bi-palette-fill me-2 settings-icon settings-icon-variants"></i>@Localizer["Variants"]
                            </div>
                            <div class="status-toggle-text">@Localizer["View product variants such as SKU, size, and color."]</div>
                        </div>
                        <div class="status-toggle-switch">
                            <input asp-for="StaffCanSeeVariants" class="form-check-input modern-switch" id="StaffCanSeeVariants" type="checkbox" />
                        </div>
                    </label>

                    <label class="status-toggle-card" for="StaffCanSeeTextiles">
                        <div class="status-toggle-copy">
                            <div class="status-toggle-title">
                                <i class="bi bi-tags-fill me-2 settings-icon settings-icon-purchases"></i>@Localizer["Purchases"]
                            </div>
                            <div class="status-toggle-text">@Localizer["View purchase records for textiles and materials."]</div>
                        </div>
                        <div class="status-toggle-switch">
                            <input asp-for="StaffCanSeeTextiles" class="form-check-input modern-switch" id="StaffCanSeeTextiles" type="checkbox" />
                        </div>
                    </label>

                    <label class="status-toggle-card" for="StaffCanSeeStockMovement">
                        <div class="status-toggle-copy">
                            <div class="status-toggle-title">
                                <i class="bi bi-plus-circle-fill me-2 settings-icon settings-icon-stock"></i>@Localizer["Stock Movement"]
                            </div>
                            <div class="status-toggle-text">@Localizer["View stock in, stock out, and movement history."]</div>
                        </div>
                        <div class="status-toggle-switch">
                            <input asp-for="StaffCanSeeStockMovement" class="form-check-input modern-switch" id="StaffCanSeeStockMovement" type="checkbox" />
                        </div>
                    </label>

                    <label class="status-toggle-card" for="StaffCanSeeInventory">
                        <div class="status-toggle-copy">
                            <div class="status-toggle-title">
                                <i class="bi bi-clock-history me-2 settings-icon settings-icon-inventory"></i>@Localizer["Inventory Log"]
                            </div>
                            <div class="status-toggle-text">@Localizer["View current stock balance for each variant."]</div>
                        </div>
                        <div class="status-toggle-switch">
                            <input asp-for="StaffCanSeeInventory" class="form-check-input modern-switch" id="StaffCanSeeInventory" type="checkbox" />
                        </div>
                    </label>

                    <label class="status-toggle-card" for="StaffCanSeeSales">
                        <div class="status-toggle-copy">
                            <div class="status-toggle-title">
                                <i class="bi bi-bag-check-fill me-2 settings-icon settings-icon-sales"></i>@Localizer["Sales"]
                            </div>
                            <div class="status-toggle-text">@Localizer["View sales history, invoices, and sale records."]</div>
                        </div>
                        <div class="status-toggle-switch">
                            <input asp-for="StaffCanSeeSales" class="form-check-input modern-switch" id="StaffCanSeeSales" type="checkbox" />
                        </div>
                    </label>

                    <label class="status-toggle-card" for="StaffCanSeeCustomers">
                        <div class="status-toggle-copy">
                            <div class="status-toggle-title">
                                <i class="bi bi-people-fill me-2 settings-icon settings-icon-customers"></i>@Localizer["Customers"]
                            </div>
                            <div class="status-toggle-text">@Localizer["View customer profiles, contacts, and purchase history."]</div>
                        </div>
                        <div class="status-toggle-switch">
                            <input asp-for="StaffCanSeeCustomers" class="form-check-input modern-switch" id="StaffCanSeeCustomers" type="checkbox" />
                        </div>
                    </label>
                </div>

                <div class="form-footer-modern">
                    <button type="submit" class="btn-modern-primary">
                        <i class="bi bi-floppy-fill"></i> @Localizer["Save Settings"]
                    </button>
                </div>
            </div>

            <div class="create-side-column">
                <div class="side-info-card">
                    <div class="side-info-header">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <h4>@Localizer["Low Stock Alert"]</h4>
                    </div>

                    <p class="side-info-text">
                        @Localizer["Variants at or below this threshold are marked as low stock across the app and in Telegram alerts."]
                    </p>

                    <div class="info-list-modern mb-3">
                        <div class="info-row-modern">
                            <span class="info-label">@Localizer["Threshold"]</span>
                            <div class="input-icon-wrap settings-threshold-wrap">
                                <i class="bi bi-sliders"></i>
                                <input asp-for="LowStockThreshold"
                                       type="number"
                                       class="input-modern settings-threshold-input"
                                       min="1" max="10000"
                                       placeholder="10" />
                            </div>
                        </div>
                        <span asp-validation-for="LowStockThreshold" class="field-validation-modern"></span>
                    </div>

                    <label class="status-toggle-card settings-staff-toggle" for="LowStockAlertEnabled">
                        <div class="status-toggle-copy">
                            <div class="status-toggle-title">
                                <i class="bi bi-bell-fill me-2 settings-icon settings-icon-alert"></i>@Localizer["Enable for Staff"]
                            </div>
                            <div class="status-toggle-text">@Localizer["Show low-stock warning badges to staff users."]</div>
                        </div>
                        <div class="status-toggle-switch">
                            <input asp-for="LowStockAlertEnabled" class="form-check-input modern-switch" id="LowStockAlertEnabled" type="checkbox" />
                        </div>
                    </label>
                </div>

                <div class="side-info-card">
                    <div class="side-info-header">
                        <i class="bi bi-info-circle-fill"></i>
                        <h4>@Localizer["How It Works"]</h4>
                    </div>
                    <p class="side-info-text settings-help-text">
                        @Localizer["Hidden sections disappear from staff navigation and staff cannot open them directly. Admins always keep full access."]
                    </p>
                </div>
            </div>
        </div>

        <div class="settings-ecommerce-card">
            <div class="section-header">
                <div>
                    <h3><i class="bi bi-shop me-2"></i>@Localizer["E-commerce"]</h3>
                    <p>@Localizer["Enable your public shop and control the text shown to customers."]</p>
                </div>
            </div>

            @if (!hasEcommerceFeature)
            {
                <div class="validation-summary-modern">
                    @Localizer["E-commerce is not included in your active plan. Upgrade or ask SuperAdmin to enable this feature before using the public shop link."]
                </div>
            }

            <div class="settings-ecommerce-grid">
                <div class="settings-ecommerce-main">
                    <label class="status-toggle-card settings-ecommerce-toggle" for="StorefrontEnabled">
                        <div class="status-toggle-copy">
                            <div class="status-toggle-title">
                                <i class="bi bi-bag-check-fill me-2 settings-icon settings-icon-sales"></i>@Localizer["Public shop enabled"]
                            </div>
                            <div class="status-toggle-text">@Localizer["Customers can browse products, add to cart, and place orders online."]</div>
                        </div>
                        <div class="status-toggle-switch">
                            <input asp-for="StorefrontEnabled" class="form-check-input modern-switch" id="StorefrontEnabled" type="checkbox" disabled="@(!hasEcommerceFeature)" />
                        </div>
                    </label>
                    @if (!hasEcommerceFeature)
                    {
                        <input type="hidden" asp-for="StorefrontEnabled" value="false" />
                    }

                    @if (ViewBag.ShopUrl is string shopUrl && !string.IsNullOrWhiteSpace(shopUrl))
                    {
                        <div class="settings-shop-link-card">
                            <span class="info-label">@Localizer["Shop Link"]</span>
                            <a href="@shopUrl" target="_blank" rel="noopener" class="settings-shop-link">@shopUrl</a>
                        </div>
                    }
                    else if (hasEcommerceFeature)
                    {
                        <div class="settings-shop-link-card settings-shop-link-card-muted">
                            @Localizer["Enable the public shop and save settings to generate the shop link."]
                        </div>
                    }
                </div>

                <div class="settings-ecommerce-fields">
                    <div class="form-group-modern">
                        <label asp-for="StorefrontTagline" class="form-label-modern"></label>
                        <input asp-for="StorefrontTagline" class="input-modern" placeholder="@Localizer["e.g. Everyday wear, delivered fast"]" />
                        <span asp-validation-for="StorefrontTagline" class="field-validation-modern"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="StorefrontShippingFee" class="form-label-modern"></label>
                        <input asp-for="StorefrontShippingFee" class="input-modern" type="number" min="0" step="1" placeholder="0" />
                        <span asp-validation-for="StorefrontShippingFee" class="field-validation-modern"></span>
                    </div>

                    <div class="form-group-modern form-group-full">
                        <label asp-for="StorefrontDescription" class="form-label-modern"></label>
                        <textarea asp-for="StorefrontDescription" class="input-modern settings-ecommerce-description" rows="4" placeholder="@Localizer["Short introduction for your online shop"]"></textarea>
                        <span asp-validation-for="StorefrontDescription" class="field-validation-modern"></span>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/create-product.css" asp-append-version="true" />
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
