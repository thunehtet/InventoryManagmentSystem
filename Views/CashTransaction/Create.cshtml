@using ClothInventoryApp.Dto.CashTransaction
@model CreateCashTransactionDto

@{
    ViewData["Title"] = "Create Cash Transaction";
}

<div class="create-product-shell">
    <div class="create-main-card">
        <div class="section-header">
            <div>
                <h3>Add Cash Transaction</h3>
                <p>Record money in or money out.</p>
            </div>
        </div>

        <form asp-action="Create" method="post" class="modern-product-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary-modern"></div>

            <div class="form-grid-modern">
                <div class="form-group-modern">
                    <label asp-for="TransactionDate" class="form-label-modern"></label>
                    <input asp-for="TransactionDate" class="input-modern" type="date" />
                </div>

                <div class="form-group-modern">
                    <label asp-for="Type" class="form-label-modern"></label>
                    <select asp-for="Type" asp-items="ViewBag.Types" class="input-modern">
                        <option value="">-- Select Type --</option>
                    </select>
                </div>

                <div class="form-group-modern form-group-full">
                    <label asp-for="Category" class="form-label-modern"></label>
                    <select asp-for="Category" asp-items="ViewBag.Categories" class="input-modern">
                        <option value="">-- Select Category --</option>
                    </select>
                </div>

                <div class="form-group-modern">
                    <label asp-for="Amount" class="form-label-modern"></label>
                    <input asp-for="Amount" class="input-modern" type="number" />
                </div>

                <div class="form-group-modern">
                    <label asp-for="ReferenceNo" class="form-label-modern"></label>
                    <input asp-for="ReferenceNo" class="input-modern" />
                </div>

                <div class="form-group-modern form-group-full">
                    <label asp-for="Remarks" class="form-label-modern"></label>
                    <textarea asp-for="Remarks" class="input-modern" rows="4"></textarea>
                </div>
            </div>

            <div class="form-footer-modern">
                <button type="submit" class="btn-modern-primary btn-modern-lg">Save Transaction</button>
                <a asp-action="Index" class="btn-modern-outline btn-modern-lg">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/create-product.css" />
}