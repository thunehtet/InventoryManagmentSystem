@using ClothInventoryApp.Dto.CashTransaction
@model ViewCashTransactionDto

@{
    ViewData["Title"] = Localizer["Transaction Details"];
    var currency = ViewData["Currency"] as string ?? "";
}

<div class="create-product-shell">
    <div class="create-main-card">
        <div class="section-header">
            <div>
                <h3>@Localizer["Transaction Details"]</h3>
            </div>
        </div>

        <div class="form-grid-modern">
            <div class="form-group-modern"><label class="form-label-modern">@Localizer["Date"]</label><input value="@Model.TransactionDate.ToString("yyyy-MM-dd")" class="input-modern" readonly /></div>
            <div class="form-group-modern"><label class="form-label-modern">@Localizer["Type"]</label><input value="@Model.Type" class="input-modern" readonly /></div>
            <div class="form-group-modern form-group-full"><label class="form-label-modern">@Localizer["Category"]</label><input value="@Model.Category" class="input-modern" readonly /></div>
            <div class="form-group-modern"><label class="form-label-modern">@Localizer["Amount"]</label><input value="@(Model.Amount.ToString("N0") + " " + currency)" class="input-modern" readonly /></div>
            <div class="form-group-modern"><label class="form-label-modern">@Localizer["Reference No"]</label><input value="@Model.ReferenceNo" class="input-modern" readonly /></div>
            <div class="form-group-modern form-group-full"><label class="form-label-modern">@Localizer["Remarks"]</label><textarea class="input-modern" rows="4" readonly>@Model.Remarks</textarea></div>
        </div>

        <div class="form-footer-modern">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-modern-primary btn-modern-lg">@Localizer["Edit"]</a>
            <a asp-action="Index" class="btn-modern-outline btn-modern-lg">@Localizer["Back"]</a>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/create-product.css" />
}
