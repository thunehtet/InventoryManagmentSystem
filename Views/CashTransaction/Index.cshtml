@using ClothInventoryApp.Dto.CashTransaction
@model IEnumerable<ViewCashTransactionDto>
@{
    ViewData["Title"] = Localizer["Cash Transactions"];
    var currency = ViewData["Currency"] as string ?? "";
    var pg = ViewBag.Pagination as ClothInventoryApp.Models.PaginationViewModel;
}

<div class="product-index-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <div class="hero-kicker">
                <i class="bi bi-cash-stack"></i>
                <span>@Localizer["Cashflow"]</span>
            </div>
            <h1>@Localizer["Cash Transactions"]</h1>
            <p>@Localizer["Track all cash moving in and out of your business."]</p>
            <div class="hero-actions">
                <a asp-action="Create" class="btn-modern-primary">
                    <i class="bi bi-plus-circle"></i> @Localizer["Add Transaction"]
                </a>
            </div>
        </div>
        <div class="product-hero-side">
            <div class="hero-stat-card">
                <div class="hero-stat-icon"><i class="bi bi-wallet2"></i></div>
                <div class="hero-stat-title">@Localizer["Total Records"]</div>
                <div class="hero-stat-text">@string.Format(Localizer["{0} transactions"].Value, pg?.TotalCount ?? 0)</div>
            </div>
        </div>
    </div>

    <div class="list-filter-bar">
        <form method="get" asp-action="Index" class="filter-form">
            @if (pg != null) { <input type="hidden" name="size" value="@pg.PageSize" /> }
            <div class="filter-search-wrap">
                <i class="bi bi-search filter-search-icon"></i>
                <input type="text" name="search" value="@ViewBag.Search"
                       class="filter-search-input" placeholder="@Localizer["Search category, type, reference..."]" autocomplete="off" />
                @if (!string.IsNullOrWhiteSpace(ViewBag.Search as string))
                {
                    <a href="@Url.Action("Index", new { size = pg?.PageSize ?? 10 })" class="filter-clear-btn" title="@Localizer["Clear"]">
                        <i class="bi bi-x-circle-fill"></i>
                    </a>
                }
            </div>
            <button type="submit" class="filter-search-btn">
                <i class="bi bi-search"></i> @Localizer["Search"]
            </button>
        </form>
    </div>

    <div class="product-table-card">
        <div class="table-responsive-modern">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>@Localizer["Date"]</th>
                        <th>@Localizer["Type"]</th>
                        <th>@Localizer["Category"]</th>
                        <th>@Localizer["Amount"]</th>
                        <th>@Localizer["Reference"]</th>
                        <th>@Localizer["Remarks"]</th>
                        <th>@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <div>@(string.IsNullOrWhiteSpace(ViewBag.Search as string) ? Localizer["No transactions yet"].Value : Localizer["No transactions match your search"].Value)</div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            var isProtected = item.Category == "Sale Income"
                                || item.Category == "Sales"
                                || item.Category == "Inventory Purchase"
                                || item.Category == "Textile Purchase";
                            <tr>
                                <td class="text-muted table-cell-sm">@item.TransactionDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (item.Type == "IN")
                                    {
                                        <span class="badge-modern badge-success">IN</span>
                                    }
                                    else
                                    {
                                        <span class="badge-modern badge-muted">OUT</span>
                                    }
                                </td>
                                <td>@item.Category</td>
                                <td class="fw-semibold">@item.Amount.ToString("N0") @currency</td>
                                <td class="text-muted table-cell-sm">@(item.ReferenceNo ?? "-")</td>
                                <td class="text-muted table-cell-sm">@(item.Remarks ?? "-")</td>
                                <td>
                                    <div class="table-actions">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="action-btn action-btn-view" title="@Localizer["Details"]"><i class="bi bi-eye-fill"></i></a>
                                        @if (!isProtected)
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn action-btn-edit" title="@Localizer["Edit"]"><i class="bi bi-pencil-fill"></i></a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn action-btn-delete" title="@Localizer["Delete"]"><i class="bi bi-trash-fill"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (pg != null) { @await Html.PartialAsync("_Pagination", pg) }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" />
}
