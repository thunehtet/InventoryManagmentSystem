@using ClothInventoryApp.Dto.CashTransaction
@model IEnumerable<ViewCashTransactionDto>

@{
    ViewData["Title"] = "Cash Flow";
}

<div class="product-index-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <div class="hero-kicker">
                <i class="bi bi-cash-stack"></i>
                <span>Money Flow</span>
            </div>

            <h1>Cash Transactions</h1>
            <p>Track all money in and money out for your business.</p>

            <div class="hero-actions">
                <a asp-action="Create" class="btn-modern-primary">
                    <i class="bi bi-plus-circle"></i>
                    Add Transaction
                </a>
            </div>
        </div>
    </div>

    <div class="product-table-card">
        <div class="table-responsive-modern">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Category</th>
                        <th>Amount</th>
                        <th>Reference</th>
                        <th>Remarks</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="empty-state">No cash transaction found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.TransactionDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    @if (item.Type == "IN")
                                    {
                                        <span class="badge-modern badge-success">IN</span>
                                    }
                                    else
                                    {
                                        <span class="badge-modern badge-muted">OUT</span>
                                    }
                                </td>
                                <td>@item.Category</td>
                                <td>@item.Amount</td>
                                <td>@item.ReferenceNo</td>
                                <td>@item.Remarks</td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-icon"><i class="bi bi-pencil"></i></a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-icon"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-icon text-danger"><i class="bi bi-trash"></i></a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" />
}