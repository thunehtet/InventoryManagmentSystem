@{
    Layout = null;
    var tenantName = ViewBag.TenantName as string ?? "Shop";
    var tenantCode = ViewBag.TenantCode as string ?? "";
    var tenantLogoUrl = ViewBag.TenantLogoUrl as string;
    var tagline = ViewBag.Tagline as string;
    var currency = ViewBag.Currency as string ?? "";
    int cartQty = ViewBag.CartQuantity is int q ? q : 0;
    var title = ViewBag.Title as string ?? tenantName;
}
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - @tenantName</title>
    <link rel="icon" type="image/png" href="~/images/websitelogo.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/pages/storefront.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="shop-page">
    <header class="shop-topbar">
        <div class="shop-container shop-topbar-inner">
            <a class="shop-brand" href="/shop/@tenantCode">
                <div class="shop-brand-logo">
                    @if (!string.IsNullOrWhiteSpace(tenantLogoUrl))
                    {
                        <img src="@tenantLogoUrl" alt="@tenantName" />
                    }
                    else
                    {
                        <span>@tenantName.Substring(0, 1).ToUpperInvariant()</span>
                    }
                </div>
                <div>
                    <div class="shop-brand-name">@tenantName</div>
                    @if (!string.IsNullOrWhiteSpace(tagline))
                    {
                        <div class="shop-brand-tag">@tagline</div>
                    }
                </div>
            </a>
            <nav class="shop-nav">
                <a href="/shop/@tenantCode">@Localizer["Home"]</a>
                <a href="/shop/@tenantCode/products">@Localizer["Shop"]</a>
                <a class="shop-cart-link" href="/shop/@tenantCode/cart">
                    <i class="bi bi-bag"></i>
                    <span>@Localizer["Cart"]</span>
                    @if (cartQty > 0)
                    {
                        <span class="shop-cart-count">@cartQty</span>
                    }
                </a>
            </nav>
        </div>
    </header>

    @if (TempData["Success"] is string successMsg)
    {
        <div class="shop-toast shop-toast--success shop-container">
            <i class="bi bi-check-circle"></i> @successMsg
        </div>
    }
    @if (TempData["Error"] is string errorMsg)
    {
        <div class="shop-toast shop-toast--error shop-container">
            <i class="bi bi-exclamation-triangle"></i> @errorMsg
        </div>
    }

    <main class="shop-main">
        @RenderBody()
    </main>

    <footer class="shop-footer">
        <div class="shop-container">
            <div class="shop-footer-main">
                <div>
                    <div class="shop-footer-brand">@tenantName</div>
                    @if (!string.IsNullOrWhiteSpace(ViewBag.TenantPhone as string))
                    {
                        <div class="shop-footer-line"><i class="bi bi-telephone"></i> @ViewBag.TenantPhone</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(ViewBag.TenantEmail as string))
                    {
                        <div class="shop-footer-line"><i class="bi bi-envelope"></i> @ViewBag.TenantEmail</div>
                    }
                </div>
                <div class="shop-footer-powered">
                    <span>@Localizer["Powered by"]</span>
                    <img src="~/images/websitelogo.png" alt="StockEasy" />
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
