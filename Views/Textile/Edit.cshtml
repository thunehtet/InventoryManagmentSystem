@using ClothInventoryApp.Dto.Textile
@model ViewTextileDto

@{
    ViewData["Title"] = "Edit Textile";
}

<div class="create-product-shell">
    <div class="create-main-card">
        <div class="section-header">
            <div>
                <h3>Edit Textile</h3>
            </div>
        </div>

        <form asp-action="Edit" method="post" class="modern-product-form">
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="validation-summary-modern"></div>

            <div class="form-grid-modern">
                <div class="form-group-modern form-group-full">
                    <label asp-for="Name" class="form-label-modern"></label>
                    <input asp-for="Name" class="input-modern input-modern-lg" />
                </div>

                <div class="form-group-modern">
                    <label asp-for="PurchaseFrom" class="form-label-modern"></label>
                    <input asp-for="PurchaseFrom" class="input-modern" />
                </div>

                <div class="form-group-modern">
                    <label asp-for="Quantity" class="form-label-modern"></label>
                    <input asp-for="Quantity" class="input-modern" type="number" />
                </div>

                <div class="form-group-modern">
                    <label asp-for="PurchaseDate" class="form-label-modern"></label>
                    <input asp-for="PurchaseDate" class="input-modern" type="date" />
                </div>

                <div class="form-group-modern">
                    <label asp-for="UnitPrice" class="form-label-modern"></label>
                    <input asp-for="UnitPrice" class="input-modern" type="number" />
                </div>
            </div>

            <div class="form-footer-modern">
                <button type="submit" class="btn-modern-primary btn-modern-lg">Update Textile</button>
                <a asp-action="Index" class="btn-modern-outline btn-modern-lg">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/create-product.css" />
}