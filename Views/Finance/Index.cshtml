@model ClothInventoryApp.Dto.Finance.FinanceDashboardViewModel

@{
    ViewData["Title"] = "Finance Overview";
}

<div class="dashboard-shell">
    <section class="dashboard-hero">
        <div class="dashboard-hero-content">
            <div class="hero-badge-modern">
                <i class="bi bi-cash-coin"></i>
                <span>Business finance overview</span>
            </div>

            <h1 class="dashboard-title">Track money in, money out, and business cash position.</h1>

            <p class="dashboard-subtitle">
                Monitor sales income, textile purchases, tailor fees, personal withdrawals, and overall cash balance.
            </p>

            <div class="dashboard-hero-actions">
                <a asp-controller="CashTransaction" asp-action="Create" class="btn-dashboard-primary">
                    <i class="bi bi-plus-circle"></i>
                    Add Transaction
                </a>

                <a asp-controller="CashTransaction" asp-action="Index" class="btn-dashboard-secondary">
                    <i class="bi bi-list-ul"></i>
                    View All Transactions
                </a>
            </div>
        </div>
    </section>

    <section class="dashboard-stats-grid">
        <div class="dashboard-stat-card">
            <div class="stat-card-icon bg-blue-soft"><i class="bi bi-arrow-down-circle-fill"></i></div>
            <div class="stat-card-content">
                <div class="stat-card-label">Total Cash In</div>
                <div class="stat-card-value">@Model.TotalCashIn</div>
            </div>
        </div>

        <div class="dashboard-stat-card">
            <div class="stat-card-icon bg-orange-soft"><i class="bi bi-arrow-up-circle-fill"></i></div>
            <div class="stat-card-content">
                <div class="stat-card-label">Total Cash Out</div>
                <div class="stat-card-value">@Model.TotalCashOut</div>
            </div>
        </div>

        <div class="dashboard-stat-card">
            <div class="stat-card-icon bg-purple-soft"><i class="bi bi-wallet2"></i></div>
            <div class="stat-card-content">
                <div class="stat-card-label">Cash Balance</div>
                <div class="stat-card-value">@Model.CashBalance</div>
            </div>
        </div>
    </section>

    <section class="dashboard-main-grid">
        <div class="dashboard-panel dashboard-panel-large">
            <div class="panel-header">
                <div>
                    <h3>Expense Breakdown</h3>
                    <p>Where your business money is going.</p>
                </div>
            </div>

            <div class="quick-action-grid">
                <div class="quick-action-card">
                    <div class="quick-action-body">
                        <h4>Sales Income</h4>
                        <p>@Model.TotalSalesIncome</p>
                    </div>
                </div>

                <div class="quick-action-card">
                    <div class="quick-action-body">
                        <h4>Textile Purchase</h4>
                        <p>@Model.TotalTextileExpense</p>
                    </div>
                </div>

                <div class="quick-action-card">
                    <div class="quick-action-body">
                        <h4>Tailor Fee</h4>
                        <p>@Model.TotalTailorFee</p>
                    </div>
                </div>

                <div class="quick-action-card">
                    <div class="quick-action-body">
                        <h4>Living Expense</h4>
                        <p>@Model.TotalLivingExpense</p>
                    </div>
                </div>

                <div class="quick-action-card">
                    <div class="quick-action-body">
                        <h4>Other Expense</h4>
                        <p>@Model.TotalOtherExpense</p>
                    </div>
                </div>

                <div class="quick-action-card">
                    <div class="quick-action-body">
                        <h4>Estimated Profit</h4>
                        <p>@Model.GrossProfitEstimate</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="dashboard-panel recent-activity-panel">
        <div class="panel-header">
            <div>
                <h3>Recent Cash Transactions</h3>
                <p>Latest money movement records.</p>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table-modern dashboard-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Category</th>
                        <th>Amount</th>
                        <th>Reference</th>
                        <th>Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RecentTransactions.Any())
                    {
                        <tr>
                            <td colspan="6" class="empty-state-cell">No transaction found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.RecentTransactions)
                        {
                            <tr>
                                <td>@item.TransactionDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    @if (item.Type == "IN")
                                    {
                                        <span class="badge-soft success">IN</span>
                                    }
                                    else
                                    {
                                        <span class="badge-soft warning">OUT</span>
                                    }
                                </td>
                                <td>@item.Category</td>
                                <td>@item.Amount</td>
                                <td>@item.ReferenceNo</td>
                                <td>@item.Remarks</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/dashboard.css" />
}