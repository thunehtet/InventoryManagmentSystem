@model ClothInventoryApp.Dto.Finance.FinanceDashboardViewModel

@{
    ViewData["Title"] = Localizer["Finance Overview"];
    var currency = ViewData["Currency"] as string ?? "";
    var selectedMonthName = new DateTime(Model.SelectedYear, Model.SelectedMonth, 1).ToString("MMMM");
}

<div class="dashboard-shell">
    <section class="dashboard-hero finance-hero">
        <div class="dashboard-hero-content">
            <div class="hero-badge-modern">
                <i class="bi bi-cash-coin"></i>
                <span>@Localizer["Financial performance dashboard"]</span>
            </div>

            <h1 class="dashboard-title">@Localizer["Track period cashflow, spending, and business profit clearly."]</h1>

            <p class="dashboard-subtitle">
                @Localizer["Use this dashboard to review money movement and performance. Operations stay on the main dashboard."]
            </p>

            <div class="dashboard-hero-actions">
                <a asp-controller="CashTransaction" asp-action="Create" class="btn-dashboard-primary">
                    <i class="bi bi-plus-circle"></i>
                    @Localizer["Add Transaction"]
                </a>

                <a asp-controller="CashTransaction" asp-action="Index" class="btn-dashboard-secondary">
                    <i class="bi bi-list-ul"></i>
                    @Localizer["View All Transactions"]
                </a>
            </div>
        </div>
    </section>

    <section class="dashboard-panel mb-4">
        <div class="panel-header panel-header-with-action">
            <div>
                <h3>@Localizer["Reporting Period"]</h3>
                <p>@Localizer["Showing finance metrics for {0} {1}.", selectedMonthName, Model.SelectedYear]</p>
            </div>
            <form method="get" asp-action="Index" class="trend-period-form">
                <label class="visually-hidden" for="financeMonth">@Localizer["Month"]</label>
                <select id="financeMonth" name="month" class="form-select form-select-sm trend-period-select">
                    @for (var month = 1; month <= 12; month++)
                    {
                        var monthName = new DateTime(Model.SelectedYear, month, 1).ToString("MMMM");
                        if (month == Model.SelectedMonth)
                        {
                            <option value="@month" selected>@monthName</option>
                        }
                        else
                        {
                            <option value="@month">@monthName</option>
                        }
                    }
                </select>
                <label class="visually-hidden" for="financeYear">@Localizer["Year"]</label>
                <select id="financeYear" name="year" class="form-select form-select-sm trend-period-select">
                    @foreach (var year in Model.AvailableYears)
                    {
                        if (year == Model.SelectedYear)
                        {
                            <option value="@year" selected>@year</option>
                        }
                        else
                        {
                            <option value="@year">@year</option>
                        }
                    }
                </select>
            </form>
        </div>
    </section>

    <section class="dashboard-stats-grid dashboard-stats-grid-4">
        <div class="dashboard-stat-card">
            <div class="stat-card-icon bg-blue-soft"><i class="bi bi-arrow-down-circle-fill"></i></div>
            <div class="stat-card-content">
                <div class="stat-card-label">@Localizer["Cash In"]</div>
                <div class="stat-card-value">@Model.PeriodCashIn.ToString("N0") @currency</div>
                <div class="stat-card-note">@Localizer["Money received in this period"]</div>
            </div>
        </div>

        <div class="dashboard-stat-card">
            <div class="stat-card-icon bg-orange-soft"><i class="bi bi-arrow-up-circle-fill"></i></div>
            <div class="stat-card-content">
                <div class="stat-card-label">@Localizer["Cash Out"]</div>
                <div class="stat-card-value">@Model.PeriodCashOut.ToString("N0") @currency</div>
                <div class="stat-card-note">@Localizer["All expenses and withdrawals"]</div>
            </div>
        </div>

        <div class="dashboard-stat-card">
            <div class="stat-card-icon @(Model.PeriodNetCashFlow >= 0 ? "bg-green-soft" : "bg-red-soft")"><i class="bi bi-activity"></i></div>
            <div class="stat-card-content">
                <div class="stat-card-label">@Localizer["Net Cashflow"]</div>
                <div class="stat-card-value">@Model.PeriodNetCashFlow.ToString("N0") @currency</div>
                <div class="stat-card-note">@Localizer["Previous month: {0} {1}", Model.PreviousMonthNetCashFlow.ToString("N0"), currency]</div>
            </div>
        </div>

        <div class="dashboard-stat-card">
            <div class="stat-card-icon bg-purple-soft"><i class="bi bi-wallet2"></i></div>
            <div class="stat-card-content">
                <div class="stat-card-label">@Localizer["Gross Profit Est."]</div>
                <div class="stat-card-value">@Model.GrossProfitEstimate.ToString("N0") @currency</div>
                <div class="stat-card-note">@Localizer["Sales income minus operating expense"]</div>
            </div>
        </div>
    </section>

    <section class="dashboard-main-grid finance-main-grid">
        <div class="dashboard-panel dashboard-panel-large">
            <div id="financeTrendData"
                 data-labels='@System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(x => x.Label))'
                 data-cash-in='@System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(x => x.CashIn))'
                 data-cash-out='@System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(x => x.CashOut))'
                 data-currency='@currency'
                 data-cash-in-label='@Localizer["Cash In"].Value'
                 data-cash-out-label='@Localizer["Cash Out"].Value'
                 hidden></div>
            <div class="panel-header">
                <div>
                    <h3>@Localizer["Cashflow Trend"]</h3>
                    <p>@Localizer["Monthly cash in and cash out for {0}.", Model.SelectedYear]</p>
                </div>
            </div>
            <div class="chart-wrap finance-chart-wrap">
                <canvas id="financeTrendChart"></canvas>
            </div>
        </div>

        <div class="dashboard-panel dashboard-panel-side">
            <div class="panel-header">
                <div>
                    <h3>@Localizer["Period Summary"]</h3>
                    <p>@Localizer["Key finance readings for this period."]</p>
                </div>
            </div>

            <div class="attention-list">
                <div class="attention-card tone-blue">
                    <div class="attention-top">
                        <span class="attention-title">@Localizer["Sales Income"]</span>
                        <span class="attention-value">@Model.PeriodSalesIncome.ToString("N0")</span>
                    </div>
                    <p>@Localizer["Cash received from sale income transactions."]</p>
                </div>

                <div class="attention-card tone-orange">
                    <div class="attention-top">
                        <span class="attention-title">@Localizer["Operating Expense"]</span>
                        <span class="attention-value">@Model.OperatingExpense.ToString("N0")</span>
                    </div>
                    <p>@Localizer["Inventory purchase, packaging fee, transportation, and other operating expense."]</p>
                </div>

                <div class="attention-card tone-red">
                    <div class="attention-top">
                        <span class="attention-title">@Localizer["Owner Drawings"]</span>
                        <span class="attention-value">@Model.OwnerDrawings.ToString("N0")</span>
                    </div>
                    <p>@Localizer["Living expense is shown separately so profit stays clearer."]</p>
                </div>
            </div>
        </div>
    </section>

    <section class="dashboard-main-grid finance-main-grid">
        <div class="dashboard-panel dashboard-panel-large">
            <div class="panel-header panel-header-with-action">
                <div>
                    <h3>@Localizer["Expense Breakdown"]</h3>
                    <p>@Localizer["Where the money went during {0} {1}.", selectedMonthName, Model.SelectedYear]</p>
                </div>
            </div>

            @if (!Model.ExpenseBreakdown.Any())
            {
                <div class="empty-state-wrap py-4">
                    <i class="bi bi-pie-chart"></i>
                    <p>@Localizer["No expenses recorded for this period."]</p>
                </div>
            }
            else
            {
                <div class="expense-breakdown-list">
                    @foreach (var item in Model.ExpenseBreakdown)
                    {
                        <div class="expense-breakdown-row">
                            <div class="expense-breakdown-head">
                                <span class="expense-name">@Localizer[item.Category]</span>
                                <span class="expense-amount">@item.Amount.ToString("N0") @currency</span>
                            </div>
                            <div class="expense-bar-wrap">
                                <progress class="expense-bar" max="100" value="@item.Percentage">@item.Percentage%</progress>
                            </div>
                            <div class="expense-foot">@item.Percentage%</div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="dashboard-panel dashboard-panel-side">
            <div class="panel-header">
                <div>
                    <h3>@Localizer["Finance Health"]</h3>
                    <p>@Localizer["Current risk indicators for this period."]</p>
                </div>
            </div>

            @if (Model.PeriodNetCashFlow < 0)
            {
                <div class="alert-soft warning mb-3">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <span>@Localizer["Cash out is higher than cash in for this period."]</span>
                </div>
            }
            else
            {
                <div class="alert-soft success mb-3">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>@Localizer["Cashflow is positive for this period."]</span>
                </div>
            }

            <div class="health-list">
                <div class="health-row">
                    <div class="health-label-wrap">
                        <span class="health-dot blue"></span>
                        <span class="health-label">@Localizer["Inventory Purchase"]</span>
                    </div>
                    <span class="health-value">@Model.PeriodTextileExpense.ToString("N0")</span>
                </div>
                <div class="health-row">
                    <div class="health-label-wrap">
                        <span class="health-dot purple"></span>
                        <span class="health-label">@Localizer["Packaging Fee"]</span>
                    </div>
                    <span class="health-value">@Model.PeriodPackagingFee.ToString("N0")</span>
                </div>
                <div class="health-row">
                    <div class="health-label-wrap">
                        <span class="health-dot purple"></span>
                        <span class="health-label">@Localizer["Transportation"]</span>
                    </div>
                    <span class="health-value">@Model.PeriodTransportationExpense.ToString("N0")</span>
                </div>
                <div class="health-row">
                    <div class="health-label-wrap">
                        <span class="health-dot orange"></span>
                        <span class="health-label">@Localizer["Other Expense"]</span>
                    </div>
                    <span class="health-value">@Model.PeriodOtherExpense.ToString("N0")</span>
                </div>
            </div>
        </div>
    </section>

    <section class="dashboard-panel recent-activity-panel">
        <div class="panel-header panel-header-with-action">
            <div>
                <h3>@Localizer["Recent Cash Transactions"]</h3>
                <p>@Localizer["Latest money movement records."]</p>
            </div>
            <a asp-controller="CashTransaction" asp-action="Index" class="panel-link-action">
                @Localizer["View all"]
                <i class="bi bi-arrow-right"></i>
            </a>
        </div>

        <div class="table-responsive">
            <table class="table-modern dashboard-table">
                <thead>
                    <tr>
                        <th>@Localizer["Date"]</th>
                        <th>@Localizer["Type"]</th>
                        <th>@Localizer["Category"]</th>
                        <th>@Localizer["Amount"]</th>
                        <th>@Localizer["Reference"]</th>
                        <th>@Localizer["Remarks"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RecentTransactions.Any())
                    {
                        <tr>
                            <td colspan="6" class="empty-state-cell">@Localizer["No transaction found."]</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.RecentTransactions)
                        {
                            var isIn = item.Type == "IN";
                            <tr>
                                <td>@Html.TenantDate(item.TransactionDate, "yyyy-MM-dd HH:mm")</td>
                                <td>
                                    <span class="badge-soft @(isIn ? "success" : "warning")">@(isIn ? "IN" : "OUT")</span>
                                </td>
                                <td>@item.Category</td>
                                <td class="@(isIn ? "qty-positive" : "qty-negative")">
                                    @(isIn ? "+" : "-")@item.Amount.ToString("N0") @currency
                                </td>
                                <td>@item.ReferenceNo</td>
                                <td>@item.Remarks</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/dashboard.css" asp-append-version="true" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script src="~/js/finance-index.js" asp-append-version="true"></script>
}
