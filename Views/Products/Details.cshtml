@model ClothInventoryApp.Dto.Product.ViewProductDto
@{
    ViewData["Title"] = "Product Details";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" asp-append-version="true" />
}

<div class="product-index-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <h1 class="product-hero-title">
                <i class="bi bi-box-seam-fill"></i> Product Details
            </h1>
            <p class="product-hero-sub">View product information</p>
        </div>
        <a asp-action="Index" class="btn-modern-secondary">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>

    <div class="product-table-card product-form-card">
        <div class="product-detail-card">
            <div class="product-detail-row">
                <span class="product-detail-label">Name</span>
                <span class="product-detail-value">@Model.Name</span>
            </div>
            <div class="product-detail-row">
                <span class="product-detail-label">Category</span>
                <span class="product-detail-value">@Model.Category</span>
            </div>
            <div class="product-detail-row">
                <span class="product-detail-label">Brand</span>
                <span class="product-detail-value">@Model.Brand</span>
            </div>
            <div class="product-detail-row">
                <span class="product-detail-label">Status</span>
                <span class="product-detail-value">
                    @if (Model.IsActive)
                    {
                        <span class="badge-modern badge-success">@Localizer["Active"]</span>
                    }
                    else
                    {
                        <span class="badge-modern badge-muted">@Localizer["Inactive"]</span>
                    }
                </span>
            </div>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-modern-primary">
                <i class="bi bi-pencil-fill"></i> Edit
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-modern-danger">
                <i class="bi bi-trash-fill"></i> Delete
            </a>
            <a asp-action="Index" class="btn-modern-secondary">@Localizer["Cancel"]</a>
        </div>
    </div>
</div>
