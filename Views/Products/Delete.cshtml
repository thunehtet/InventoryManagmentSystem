@model ClothInventoryApp.Dto.Product.ViewProductDto
@{
    ViewData["Title"] = Localizer["Delete Product"];
    var canDelete = !(ViewBag.CanDelete is bool deleteAllowed) || deleteAllowed;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" asp-append-version="true" />
}

<div class="product-index-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <h1 class="product-hero-title">
                <i class="bi bi-trash-fill"></i> @Localizer["Delete Product"]
            </h1>
            <p class="product-hero-sub">@Localizer["This action cannot be undone"]</p>
        </div>
        <a asp-action="Index" class="btn-modern-secondary">
            <i class="bi bi-arrow-left"></i> @Localizer["Back"]
        </a>
    </div>

    <div class="product-table-card product-form-card">
        @if (TempData["Error"] is string errorMessage)
        {
            <div class="alert alert-danger mb-3">@errorMessage</div>
        }

        @if (ViewBag.DeleteMessage is string deleteMessage)
        {
            <div class="alert alert-warning mb-3">@deleteMessage</div>
        }

        <p class="mb-3 text-muted">@Localizer["Are you sure you want to delete this product?"]</p>

        <div class="product-detail-card">
            <div class="product-detail-row">
                <span class="product-detail-label">@Localizer["Name"]</span>
                <span class="product-detail-value">@Model.Name</span>
            </div>
            <div class="product-detail-row">
                <span class="product-detail-label">@Localizer["Category"]</span>
                <span class="product-detail-value">@Model.Category</span>
            </div>
            <div class="product-detail-row">
                <span class="product-detail-label">@Localizer["Brand"]</span>
                <span class="product-detail-value">@Model.Brand</span>
            </div>
            <div class="product-detail-row">
                <span class="product-detail-label">@Localizer["Status"]</span>
                <span class="product-detail-value">
                    @if (Model.IsActive)
                    {
                        <span class="badge-modern badge-success">Active</span>
                    }
                    else
                    {
                        <span class="badge-modern badge-muted">Inactive</span>
                    }
                </span>
            </div>
        </div>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-flex gap-2">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-modern-danger" disabled="@(!canDelete ? "disabled" : null)">
                <i class="bi bi-trash-fill"></i> @Localizer["Yes, Delete"]
            </button>
            <a asp-action="Index" class="btn-modern-secondary">Cancel</a>
        </form>
    </div>
</div>
