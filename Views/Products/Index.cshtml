@using ClothInventoryApp.Dto.Product
@model IEnumerable<ViewProductDto>

@{
    ViewData["Title"] = "Products";
}

<div class="product-index-shell">

    <!-- HERO -->
    <div class="product-hero">
        <div class="product-hero-content">
            <div class="hero-kicker">
                <i class="bi bi-box-seam-fill"></i>
                <span>Inventory</span>
            </div>

            <h1>Product Catalog</h1>
            <p>
                Manage your clothing products. Create, organize, and maintain your inventory in one place.
            </p>

            <div class="hero-actions">
                <a asp-controller="Products" asp-action="Create" class="btn-modern-primary">
                    <i class="bi bi-plus-circle"></i>
                    Create Product
                </a>
            </div>
        </div>

        <div class="product-hero-side">
            <div class="hero-stat-card">
                <div class="hero-stat-icon">
                    <i class="bi bi-collection"></i>
                </div>
                <div class="hero-stat-title">Total Products</div>
                <div class="hero-stat-text">
                    @Model.Count() items in your catalog
                </div>
            </div>
        </div>
    </div>

    <!-- TABLE CARD -->
    <div class="product-table-card">
        <div class="section-header">
            <div>
                <h3>All Products</h3>
                <p>Overview of all items in your inventory.</p>
            </div>
        </div>

        <div class="table-responsive-modern">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Brand</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <div>No products found</div>
                                <a asp-action="Create" class="btn-modern-primary mt-2">
                                    Create your first product
                                </a>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Name</td>
                                <td>@item.Category</td>
                                <td>@item.Brand</td>

                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge-modern badge-success">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-modern badge-muted">
                                            Inactive
                                        </span>
                                    }
                                </td>

                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-icon">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-icon">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-icon text-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" />
}