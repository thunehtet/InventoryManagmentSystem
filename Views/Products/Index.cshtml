@using ClothInventoryApp.Dto.Product
@model IEnumerable<ViewProductDto>
@{
    ViewData["Title"] = Localizer["Products"];
    var pg = ViewBag.Pagination as ClothInventoryApp.Models.PaginationViewModel;
}

<div class="product-index-shell">
    @await Html.PartialAsync("_PlanLimitWarnings", ViewBag.PlanLimitWarnings as IEnumerable<ClothInventoryApp.Dto.Subscription.PlanLimitWarningDto>)

    @if (TempData["LimitError"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["LimitError"]
            <a asp-controller="Account" asp-action="FeatureRequired" asp-route-feature="products" class="alert-link ms-2">@Localizer["Upgrade Plan"]</a>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- HERO -->
    <div class="product-hero">
        <div class="product-hero-content">
            <div class="hero-kicker">
                <i class="bi bi-box-seam-fill"></i>
                <span>@Localizer["Inventory"]</span>
            </div>
            <h1>@Localizer["Product Catalog"]</h1>
            <div class="hero-actions">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Products" asp-action="QuickCreate" class="btn-modern-primary">
                        <i class="bi bi-lightning-charge-fill"></i> @Localizer["Quick Create"]
                    </a>
                    <a asp-controller="Products" asp-action="Import" class="btn-modern-outline">
                        <i class="bi bi-file-earmark-spreadsheet"></i> @Localizer["Import Excel"]
                    </a>
                    <a asp-controller="Products" asp-action="Create" class="btn-modern-primary">
                        <i class="bi bi-plus-circle"></i> @Localizer["Create Product"]
                    </a>
                }
            </div>
        </div>
        <div class="product-hero-side">
            <div class="hero-stat-card">
                <div class="hero-stat-icon"><i class="bi bi-collection"></i></div>
                <div class="hero-stat-title">@Localizer["Total Products"]</div>
                <div class="hero-stat-text">@(pg?.TotalCount ?? 0) @Localizer["items in your catalog"]</div>
            </div>
        </div>
    </div>

    <!-- FILTER BAR -->
    <div class="list-filter-bar">
        <form method="get" asp-action="Index" class="filter-form">
            @if (pg != null) { <input type="hidden" name="size" value="@pg.PageSize" /> }
            <div class="filter-search-wrap">
                <i class="bi bi-search filter-search-icon"></i>
                <input type="text" name="search" value="@ViewBag.Search"
                       class="filter-search-input" placeholder="@Localizer["Search name, category, brand…"]" autocomplete="off" />
                @if (!string.IsNullOrWhiteSpace(ViewBag.Search as string))
                {
                    <a href="@Url.Action("Index", new { size = pg?.PageSize ?? 10 })" class="filter-clear-btn" title="Clear">
                        <i class="bi bi-x-circle-fill"></i>
                    </a>
                }
            </div>
            <button type="submit" class="filter-search-btn">
                <i class="bi bi-search"></i> @Localizer["Search"]
            </button>
        </form>
    </div>

    <!-- TABLE CARD -->
    <div class="product-table-card">
        <div class="table-responsive-modern">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>@Localizer["Name"]</th>
                        <th>@Localizer["Category"]</th>
                        <th>@Localizer["Brand"]</th>
                        <th>@Localizer["Status"]</th>
                        <th>@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <div>@(string.IsNullOrWhiteSpace(ViewBag.Search as string) ? Localizer["No products yet"].Value : Localizer["No products match your search"].Value)</div>
                                @if (User.IsInRole("Admin") && string.IsNullOrWhiteSpace(ViewBag.Search as string))
                                {
                                    <a asp-action="Create" class="btn-modern-primary mt-2">@Localizer["Create your first product"]</a>
                                }
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Name</td>
                                <td>@item.Category</td>
                                <td>@item.Brand</td>
                                <td>
                                    <span class="badge-modern @(item.IsActive ? "badge-success" : "badge-muted")">
                                        @(item.IsActive ? Localizer["Active"].Value : Localizer["Inactive"].Value)
                                    </span>
                                </td>
                                <td>
                                    <div class="table-actions">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="action-btn action-btn-view" title="Details">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn action-btn-edit" title="Edit">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn action-btn-delete" title="Delete">
                                                <i class="bi bi-trash-fill"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (pg != null) { @await Html.PartialAsync("_Pagination", pg) }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" />
}
