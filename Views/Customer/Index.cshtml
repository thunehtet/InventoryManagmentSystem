@using ClothInventoryApp.Dto.Customer
@model IEnumerable<ViewCustomerDto>
@{
    ViewData["Title"] = Localizer["Customers"];
    var currency = ViewData["Currency"] as string ?? "";
    var pg = ViewBag.Pagination as ClothInventoryApp.Models.PaginationViewModel;
    var inviteLinks = ViewBag.InviteLinks as List<CustomerInviteLinkDto> ?? new();
}

<div class="product-index-shell customer-page-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <div class="hero-kicker">
                <i class="bi bi-people-fill"></i>
                <span>@Localizer["Customers"]</span>
            </div>
            <h1>@Localizer["Customer List"]</h1>
            <p>@Localizer["Manage your customer records, purchase history, and one-time registration links."]</p>
            <div class="hero-actions">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn-modern-primary">
                        <i class="bi bi-person-plus-fill"></i> @Localizer["Add Customer"]
                    </a>
                    <form asp-action="CreateInviteLink" method="post" class="customer-inline-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-modern-outline">
                            <i class="bi bi-link-45deg"></i> @Localizer["Create Share Link"]
                        </button>
                    </form>
                }
            </div>
        </div>
        <div class="product-hero-side">
            <div class="hero-stat-card">
                <div class="hero-stat-icon"><i class="bi bi-people"></i></div>
                <div class="hero-stat-title">@Localizer["Total Customers"]</div>
                <div class="hero-stat-text">@(pg?.TotalCount ?? 0) @Localizer["customers total"]</div>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <section class="customer-share-card">
        <div class="customer-share-card__header">
            <div>
                <h2>@Localizer["Customer Share Links"]</h2>
                <p>@Localizer["Each link is tenant-isolated, expires after 7 days, and becomes invalid after one registration."]</p>
            </div>
        </div>

        @if (!inviteLinks.Any())
        {
            <div class="customer-share-empty">
                <i class="bi bi-link-45deg"></i>
                <div>@Localizer["No share links created yet."]</div>
            </div>
        }
        else
        {
            <div class="customer-share-list">
                @foreach (var link in inviteLinks)
                {
                    var statusClass = link.IsUsed ? "used" : link.IsExpired ? "expired" : link.IsActive ? "active" : "revoked";
                    var statusText = link.IsUsed ? string.Format(Localizer["Used by {0}"].Value, link.CustomerName ?? Localizer["customer"].Value) :
                        link.IsExpired ? Localizer["Expired"].Value :
                        link.IsActive ? Localizer["Active"].Value : Localizer["Revoked"].Value;

                    <article class="customer-share-item">
                        <div class="customer-share-item__main">
                            <div class="customer-share-item__meta">
                                <span class="customer-share-status customer-share-status--@statusClass">@statusText</span>
                                <span>@Localizer["Expires"] @link.ExpiresAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</span>
                            </div>
                            <div class="customer-share-item__url">@link.Url</div>
                        </div>
                        <div class="customer-share-item__actions">
                            <button type="button" class="action-btn action-btn-view" title="@Localizer["Copy link"]" data-copy-text="@link.Url">
                                <i class="bi bi-copy"></i>
                            </button>
                            @if (!link.IsUsed && !link.IsExpired && link.IsActive)
                            {
                                <form asp-action="RevokeInviteLink" method="post" class="customer-inline-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@link.Id" />
                                    <button type="submit" class="action-btn action-btn-delete" title="@Localizer["Revoke"]">
                                        <i class="bi bi-slash-circle"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <div class="list-filter-bar">
        <form method="get" asp-action="Index" class="filter-form">
            @if (pg != null) { <input type="hidden" name="size" value="@pg.PageSize" /> }
            <div class="filter-search-wrap">
                <i class="bi bi-search filter-search-icon"></i>
                <input type="text" name="search" value="@ViewBag.Search"
                       class="filter-search-input" placeholder="@Localizer["Search name, phone, Facebook, email..."]" autocomplete="off" />
                @if (!string.IsNullOrWhiteSpace(ViewBag.Search as string))
                {
                    <a href="@Url.Action("Index", new { size = pg?.PageSize ?? 10 })" class="filter-clear-btn" title="@Localizer["Clear"]">
                        <i class="bi bi-x-circle-fill"></i>
                    </a>
                }
            </div>
            <button type="submit" class="filter-search-btn">
                <i class="bi bi-search"></i> @Localizer["Search"]
            </button>
        </form>
    </div>

    <div class="product-table-card">
        <div class="table-responsive-modern">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>@Localizer["Name"]</th>
                        <th>@Localizer["Phone"]</th>
                        <th>Facebook</th>
                        <th>@Localizer["Sales"]</th>
                        <th>@Localizer["Revenue"]</th>
                        <th>@Localizer["Status"]</th>
                        <th>@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="empty-state">
                                <i class="bi bi-people"></i>
                                <div>@(string.IsNullOrWhiteSpace(ViewBag.Search as string) ? Localizer["No customers yet"].Value : Localizer["No customers match your search"].Value)</div>
                                @if (User.IsInRole("Admin") && string.IsNullOrWhiteSpace(ViewBag.Search as string))
                                {
                                    <a asp-action="Create" class="btn-modern-primary mt-2">@Localizer["Add first customer"]</a>
                                }
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var c in Model)
                        {
                            <tr>
                                <td>
                                    <div class="customer-name">@c.Name</div>
                                    @if (!string.IsNullOrEmpty(c.Email))
                                    {
                                        <div class="customer-email">@c.Email</div>
                                    }
                                </td>
                                <td class="text-muted">@(c.Phone ?? "-")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(c.FacebookAccount))
                                    {
                                        <span class="customer-social-tag">
                                            <i class="bi bi-facebook me-1"></i>@c.FacebookAccount
                                        </span>
                                    }
                                    else { <span class="text-muted">-</span> }
                                </td>
                                <td class="fw-semibold">@c.TotalSales</td>
                                <td class="fw-semibold">@c.TotalRevenue.ToString("N0") @currency</td>
                                <td>
                                    <span class="badge-modern @(c.IsActive ? "badge-success" : "badge-muted")">
                                        @(c.IsActive ? Localizer["Active"].Value : Localizer["Inactive"].Value)
                                    </span>
                                </td>
                                <td>
                                    <div class="table-actions">
                                        <a asp-action="Details" asp-route-id="@c.Id" class="action-btn action-btn-view" title="@Localizer["Details"]">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@c.Id" class="action-btn action-btn-edit" title="@Localizer["Edit"]">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@c.Id" class="action-btn action-btn-delete" title="@Localizer["Delete"]">
                                                <i class="bi bi-trash-fill"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (pg != null) { @await Html.PartialAsync("_Pagination", pg) }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" />
    <link rel="stylesheet" href="~/css/pages/customer-share.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/public-share.js" asp-append-version="true"></script>
}
