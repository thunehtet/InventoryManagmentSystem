@using ClothInventoryApp.Dto.Customer
@model ViewCustomerDto
@{
    ViewData["Title"] = $"{Localizer["Customer"]} - {Model.Name}";
    var currency = ViewData["Currency"] as string ?? "";
}

<div class="create-product-shell">
    <div class="create-main-card">
        <div class="section-header">
            <div>
                <h3><i class="bi bi-person-fill me-2 text-primary"></i>@Model.Name</h3>
                <p>Customer profile and purchase history</p>
            </div>
            <div class="d-flex gap-2">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-modern-primary btn-height-40">
                        <i class="bi bi-pencil-fill me-1"></i> Edit
                    </a>
                }
                <a asp-action="Index" class="btn-modern-outline btn-height-40">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </a>
            </div>
        </div>

        <!-- Stats row -->
        <div class="d-flex gap-3 mb-4">
            <div class="hero-stat-card hero-stat-card-fluid">
                <div class="hero-stat-icon"><i class="bi bi-bag-check-fill"></i></div>
                <div class="hero-stat-title">Total Sales</div>
                <div class="hero-stat-text">@Model.TotalSales sales</div>
            </div>
            <div class="hero-stat-card hero-stat-card-fluid">
                <div class="hero-stat-icon"><i class="bi bi-cash-coin"></i></div>
                <div class="hero-stat-title">Total Revenue</div>
                <div class="hero-stat-text">@Model.TotalRevenue.ToString("N0") @currency</div>
            </div>
            <div class="hero-stat-card hero-stat-card-fluid">
                <div class="hero-stat-icon"><i class="bi bi-calendar3"></i></div>
                <div class="hero-stat-title">Customer Since</div>
                <div class="hero-stat-text">@Model.CreatedAt.ToString("dd MMM yyyy")</div>
            </div>
        </div>

        <!-- Info grid -->
        <div class="form-grid-modern">
            <div class="form-group-modern">
                <label class="form-label-modern">Full Name</label>
                <div class="input-icon-wrap">
                    <i class="bi bi-person-fill"></i>
                    <input value="@Model.Name" class="input-modern" readonly />
                </div>
            </div>

            <div class="form-group-modern">
                <label class="form-label-modern">Status</label>
                <div class="input-modern d-flex align-items-center customer-status-readonly">
                    <span class="badge-modern @(Model.IsActive ? "badge-success" : "badge-muted")">
                        @(Model.IsActive ? "Active" : "Inactive")
                    </span>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Phone))
            {
                <div class="form-group-modern">
                    <label class="form-label-modern">Phone</label>
                    <div class="input-icon-wrap">
                        <i class="bi bi-telephone-fill"></i>
                        <input value="@Model.Phone" class="input-modern" readonly />
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.Email))
            {
                <div class="form-group-modern">
                    <label class="form-label-modern">Email</label>
                    <div class="input-icon-wrap">
                        <i class="bi bi-envelope-fill"></i>
                        <input value="@Model.Email" class="input-modern" readonly />
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.FacebookAccount))
            {
                <div class="form-group-modern form-group-full">
                    <label class="form-label-modern">Facebook</label>
                    <div class="input-icon-wrap">
                        <i class="bi bi-facebook"></i>
                        <input value="@Model.FacebookAccount" class="input-modern" readonly />
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.Address))
            {
                <div class="form-group-modern form-group-full">
                    <label class="form-label-modern">Address</label>
                    <div class="input-icon-wrap">
                        <i class="bi bi-geo-alt-fill"></i>
                        <input value="@Model.Address" class="input-modern" readonly />
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="form-group-modern form-group-full">
                    <label class="form-label-modern">Notes</label>
                    <textarea class="input-modern textarea-modern" rows="3" readonly
>@Model.Notes</textarea>
                </div>
            }
        </div>

        <!-- Recent sales -->
        @{
            var sales = ViewBag.Sales as IEnumerable<dynamic>;
        }
        @if (sales != null && sales.Any())
        {
            <hr class="my-4" />
            <h5 class="mb-3"><i class="bi bi-bag-check-fill me-2 text-primary"></i>Purchase History</h5>
            <div class="table-responsive-modern">
                <table class="table-modern">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Revenue</th>
                            <th>Discount</th>
                            <th>Profit</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in sales)
                        {
                            <tr>
                                <td>@((s.SaleDate as DateTime?)?.ToString("dd MMM yyyy"))</td>
                                <td class="fw-semibold">@(((int)s.TotalAmount).ToString("N0")) @currency</td>
                                <td class="@(s.Discount > 0 ? "text-danger fw-semibold" : "text-muted")">
                                    @(s.Discount > 0 ? "- " + ((int)s.Discount).ToString("N0") + " " + currency : "—")
                                </td>
                                <td class="@(s.TotalProfit >= 0 ? "qty-positive" : "qty-negative") fw-semibold">
                                    @(((int)s.TotalProfit).ToString("N0")) @currency
                                </td>
                                <td>
                                    <div class="table-actions">
                                        <a asp-controller="Sales" asp-action="Details" asp-route-id="@s.Id"
                                           class="action-btn action-btn-view" title="View sale">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        <a asp-controller="Sales" asp-action="InvoicePdf" asp-route-id="@s.Id"
                                           class="action-btn action-btn-pdf" title="Download Invoice PDF">
                                            <i class="bi bi-file-earmark-pdf-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/create-product.css" />
    <link rel="stylesheet" href="~/css/pages/product-index.css" />
}
