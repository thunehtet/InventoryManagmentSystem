@using ClothInventoryApp.Dto.Sale
@model IEnumerable<ViewSaleDto>
@{
    ViewData["Title"] = Localizer["Sales"];
    var currency       = ViewData["Currency"] as string ?? "";
    var pg             = ViewBag.Pagination as ClothInventoryApp.Models.PaginationViewModel;
    var hasSaleProfit  = (bool)(ViewBag.HasSaleProfit ?? false) && !User.IsInRole("Staff");
    var hasCustomers   = (bool)(ViewBag.HasCustomers  ?? false);
    var colSpan        = 3 + (hasCustomers ? 1 : 0) + (hasSaleProfit ? 2 : 0);
}

<div class="product-index-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <div class="hero-kicker">
                <i class="bi bi-receipt"></i>
                <span>@Localizer["Sales"]</span>
            </div>
            <h1>@Localizer["Sales List"]</h1>
            <p>@Localizer["Manage sales transactions and item details."]</p>
            <div class="hero-actions">
                <a asp-action="Create" class="btn-modern-primary">
                    <i class="bi bi-plus-circle"></i> @Localizer["Create Sale"]
                </a>
            </div>
        </div>
        <div class="product-hero-side">
            <div class="hero-stat-card">
                <div class="hero-stat-icon"><i class="bi bi-bag-check-fill"></i></div>
                <div class="hero-stat-title">@Localizer["Total Sales"]</div>
                <div class="hero-stat-text">@(pg?.TotalCount ?? 0) @Localizer["transactions"]</div>
            </div>
        </div>
    </div>

    <!-- FILTER BAR -->
    <div class="list-filter-bar">
        <form method="get" asp-action="Index" class="filter-form">
            @if (pg != null) { <input type="hidden" name="size" value="@pg.PageSize" /> }
            <div class="filter-search-wrap">
                <i class="bi bi-search filter-search-icon"></i>
                <input type="text" name="search" value="@ViewBag.Search"
                       class="filter-search-input" placeholder="@Localizer["Search by customer name..."]" autocomplete="off" />
                @if (!string.IsNullOrWhiteSpace(ViewBag.Search as string))
                {
                    <a href="@Url.Action("Index", new { size = pg?.PageSize ?? 10 })" class="filter-clear-btn" title="@Localizer["Clear"]">
                        <i class="bi bi-x-circle-fill"></i>
                    </a>
                }
            </div>
            <button type="submit" class="filter-search-btn">
                <i class="bi bi-search"></i> @Localizer["Search"]
            </button>
        </form>
    </div>

    <!-- TABLE CARD -->
    <div class="product-table-card">
        <div class="table-responsive-modern">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>@Localizer["Sale Date"]</th>
                        @if (hasCustomers) { <th>@Localizer["Customer"]</th> }
                        <th>@Localizer["Revenue"]</th>
                        @if (hasSaleProfit)
                        {
                            <th>@Localizer["Discount"]</th>
                            <th>
                                @Localizer["Profit"]
                                <button class="sensitive-toggle-btn" data-sensitive-btn="profit-list" title="Show">
                                    <i class="bi bi-eye-fill"></i>
                                </button>
                            </th>
                        }
                        <th>@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="@colSpan" class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <div>@(string.IsNullOrWhiteSpace(ViewBag.Search as string) ? Localizer["No sales yet"].Value : Localizer["No sales match your search"].Value)</div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-muted table-cell-sm">@item.SaleDate.ToString("dd MMM yyyy")</td>
                                @if (hasCustomers)
                                {
                                    <td>
                                        @if (item.CustomerId.HasValue)
                                        {
                                            <a asp-controller="Customer" asp-action="Details" asp-route-id="@item.CustomerId"
                                               class="link-inline-primary">
                                                <i class="bi bi-person-fill me-1"></i>@item.CustomerName
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">@Localizer["Walk-in"]</span>
                                        }
                                    </td>
                                }
                                <td class="fw-semibold">@item.TotalAmount.ToString("N0") @currency</td>
                                @if (hasSaleProfit)
                                {
                                    <td class="@(item.Discount > 0 ? "text-danger fw-semibold" : "text-muted")">
                                        @(item.Discount > 0 ? "- " + item.Discount.ToString("N0") + " " + currency : "—")
                                    </td>
                                    <td class="@(item.TotalProfit >= 0 ? "qty-positive" : "qty-negative") fw-semibold">
                                        <span data-sensitive-group="profit-list"
                                              data-real="@(item.TotalProfit.ToString("N0")) @currency">••••</span>
                                    </td>
                                }
                                <td>
                                    <div class="table-actions">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="action-btn action-btn-view" title="@Localizer["Details"]"><i class="bi bi-eye-fill"></i></a>
                                        <a asp-action="InvoicePdf" asp-route-id="@item.Id" class="action-btn action-btn-pdf" title="@Localizer["Download Invoice PDF"]"><i class="bi bi-file-earmark-pdf-fill"></i></a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn action-btn-delete" title="@Localizer["Delete"]"><i class="bi bi-trash-fill"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (pg != null) { @await Html.PartialAsync("_Pagination", pg) }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" />
}

@section Scripts {
    <script src="~/js/sensitive-toggle.js" asp-append-version="true"></script>
}
