@using ClothInventoryApp.Dto.Sale
@model ViewSaleDto

@{
    ViewData["Title"] = Localizer["Sale Details"];
    var currency = ViewData["Currency"] as string ?? "";

    int pdfUsed   = ViewBag.PdfUsed  is int pu ? pu : 0;
    int? pdfMax   = ViewBag.PdfMax   as int?;
    bool pdfLocked = pdfMax.HasValue && pdfUsed >= pdfMax.Value;

    int shareUsed    = ViewBag.ReceiptShareUsed is int su ? su : 0;
    int? shareMax    = ViewBag.ReceiptShareMax  as int?;
    bool hasExistingLink = Model.PublicReceiptUrl != null;
    bool canGenerate     = ViewBag.CanGenerateReceiptLink is bool cg ? cg : true;
    bool shareLocked     = !hasExistingLink && !canGenerate;

    string shareConfirmMsg = shareMax.HasValue
        ? string.Format(Localizer["You are on the Free plan. Receipt link sharing has a monthly limit of {0} uses ({1} used so far). Generating a link will count as 1 usage. Continue?"].Value, shareMax, shareUsed)
        : "";
    string shareLimitExhaustedMsg = shareMax.HasValue
        ? string.Format(Localizer["You have used all {0} free receipt shares this month."].Value, shareMax)
        : "";

    string? limitFeature = TempData["LimitFeature"] as string;
    int limitUsed = TempData["LimitUsed"] is int lu ? lu : 0;
    int? limitMax = TempData["LimitMax"] as int?;
}

<div class="create-product-shell sale-details-shell">
    <div class="create-main-card">
        <div class="section-header">
            <div>
                <h3>@Localizer["Sale Details"]</h3>
            </div>
            <div class="sale-details-actions">
                @if (pdfLocked)
                {
                    <span class="btn-modern-primary sale-details-btn sa-limit-btn" title="@string.Format(Localizer["You have used all {0} PDF downloads this month. Upgrade to unlock unlimited."].Value, pdfMax)">
                        <i class="bi bi-lock-fill me-1"></i> @Localizer["Download Invoice"]
                        <span class="sa-limit-badge">@pdfUsed / @pdfMax</span>
                    </span>
                }
                else
                {
                    <a asp-action="InvoicePdf" asp-route-id="@Model.Id" class="btn-modern-primary sale-details-btn">
                        <i class="bi bi-file-earmark-pdf-fill me-1"></i> @Localizer["Download Invoice"]
                        @if (pdfMax.HasValue)
                        {
                            <span class="sa-limit-badge sa-limit-badge--ok">@pdfUsed / @pdfMax</span>
                        }
                    </a>
                }
                <a asp-action="Index" class="btn-modern-outline sale-details-btn">
                    <i class="bi bi-arrow-left me-1"></i> @Localizer["Back"]
                </a>
            </div>
        </div>

        @if (limitFeature == "receipt_share")
        {
            <div class="sa-limit-banner">
                <i class="bi bi-exclamation-triangle-fill"></i>
                @string.Format(Localizer["You have used all {0} free receipt shares this month."].Value, limitMax)
                <a asp-controller="Subscription" asp-action="Index" class="sa-limit-upgrade-link">@Localizer["Upgrade to unlock unlimited"]</a>
            </div>
        }
        @if (limitFeature == "pdf_invoice")
        {
            <div class="sa-limit-banner">
                <i class="bi bi-exclamation-triangle-fill"></i>
                @string.Format(Localizer["You have used all {0} free PDF invoice downloads this month."].Value, limitMax)
                <a asp-controller="Subscription" asp-action="Index" class="sa-limit-upgrade-link">@Localizer["Upgrade to unlock unlimited"]</a>
            </div>
        }

        <section class="sale-share-panel">
            <div class="sale-share-panel__copy">
                <h4>@Localizer["Receipt Sharing"]</h4>
                <p>@Localizer["Share a permanent receipt link that is safe for customers and works well on mobile apps like Messenger and Viber."]</p>
                @if (shareMax.HasValue)
                {
                    <span class="sa-usage-pill @(shareLocked ? "sa-usage-pill--warn" : "")" id="shareUsagePill">
                        <i class="bi bi-share"></i> <span id="shareUsageText">@shareUsed / @shareMax</span> @Localizer["shares this month"]
                    </span>
                }
            </div>

            @* CSRF token for AJAX call *@
            @Html.AntiForgeryToken()

            @* State 1: Button — always shown first *@
            <div id="shareInitArea">
                <button type="button" id="btnGenerateReceiptLink" class="btn-modern-primary"
                        data-existing-url="@(Model.PublicReceiptUrl ?? "")"
                        data-has-limit="@(shareMax.HasValue ? "true" : "false")"
                        data-limit-reached="@(shareLocked ? "true" : "false")"
                        data-generate-url="@Url.Action("GenerateReceiptLink", "Sales", new { id = Model.Id })"
                        data-confirm-msg="@shareConfirmMsg"
                        data-limit-msg="@shareLimitExhaustedMsg">
                    <i class="bi bi-share-fill me-1"></i> @Localizer["Share Invoice with Link"]
                    @if (shareMax.HasValue)
                    {
                        <span class="sa-limit-badge @(shareLocked ? "" : "sa-limit-badge--ok")">@shareUsed / @shareMax</span>
                    }
                </button>
            </div>

            @* State 2: Free-plan confirmation notice *@
            <div id="shareConfirmArea" class="sa-confirm-notice d-none">
                <i class="bi bi-info-circle-fill"></i>
                <p id="shareConfirmMsg"></p>
                <div class="sa-confirm-actions">
                    <button type="button" id="btnConfirmYes" class="btn-modern-primary">
                        <i class="bi bi-check-lg me-1"></i> @Localizer["Yes, Generate Link"]
                    </button>
                    <button type="button" id="btnConfirmNo" class="btn-modern-outline">
                        @Localizer["Cancel"]
                    </button>
                </div>
            </div>

            @* State 3: Revealed link and share actions *@
            <div id="shareRevealArea" class="d-none">
                <div class="sale-share-panel__actions">
                    <button type="button" class="btn-modern-primary" id="btnShareReceipt" data-share-title="@Localizer["Receipt link"]">
                        <i class="bi bi-share-fill"></i> @Localizer["Share Receipt"]
                    </button>
                    <button type="button" class="btn-modern-outline" id="btnCopyLink">
                        <i class="bi bi-copy"></i> @Localizer["Copy Link"]
                    </button>
                    <form asp-action="RefreshReceiptLink" method="post" class="customer-inline-form">
                        <input type="hidden" name="__RequestVerificationToken" value="" id="refreshCsrf" />
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn-modern-outline">
                            <i class="bi bi-arrow-repeat"></i> @Localizer["Refresh Link"]
                        </button>
                    </form>
                    <a id="linkOpenReceipt" href="#" target="_blank" rel="noopener noreferrer" class="btn-modern-outline">
                        <i class="bi bi-box-arrow-up-right"></i> @Localizer["Open Receipt"]
                    </a>
                </div>
                <div class="sale-share-link" id="shareLinkDisplay"></div>
            </div>

            @* State 4: Limit locked *@
            <div id="shareLimitArea" class="sa-limit-locked d-none">
                <i class="bi bi-lock-fill"></i>
                <p id="shareLimitMsg"></p>
                <a asp-controller="Subscription" asp-action="Index" class="btn-modern-primary">
                    @Localizer["Upgrade for unlimited sharing"]
                </a>
            </div>
        </section>

        <div class="form-grid-modern">
            <div class="form-group-modern">
                <label class="form-label-modern">@Localizer["Sale Date"]</label>
                <input value="@Model.SaleDate.ToString("yyyy-MM-dd")" class="input-modern" readonly />
            </div>

            @if (Model.CustomerId.HasValue)
            {
                <div class="form-group-modern">
                    <label class="form-label-modern">@Localizer["Customer"]</label>
                    <div class="input-modern sale-customer-box">
                        <i class="bi bi-person-fill sale-customer-box__icon"></i>
                        <a asp-controller="Customer" asp-action="Details" asp-route-id="@Model.CustomerId" class="sale-customer-box__link">@Model.CustomerName</a>
                        @if (!string.IsNullOrEmpty(Model.CustomerPhone))
                        {
                            <span class="sale-customer-box__phone">· @Model.CustomerPhone</span>
                        }
                    </div>
                </div>
            }

            <div class="form-group-modern">
                <label class="form-label-modern">@Localizer["Total Revenue"]</label>
                <input value="@(Model.TotalAmount.ToString("N0") + " " + currency)" class="input-modern" readonly />
            </div>

            @if (Model.Discount > 0)
            {
                <div class="form-group-modern">
                    <label class="form-label-modern">@Localizer["Discount"]</label>
                    <input value="@(Model.Discount.ToString("N0") + " " + currency)" class="input-modern text-danger" readonly />
                </div>
            }

            <div class="form-group-modern">
                <label class="form-label-modern">@Localizer["Total Profit"]</label>
                <input value="@(Model.TotalProfit.ToString("N0") + " " + currency)"
                       class="input-modern @(Model.TotalProfit >= 0 ? "text-success" : "text-danger") fw-bold" readonly />
            </div>
        </div>

        <hr />
        <div class="table-responsive-modern">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>@Localizer["Variant"]</th>
                        <th>@Localizer["Qty"]</th>
                        <th>@Localizer["Unit Price"]</th>
                        <th>@Localizer["Cost Price"]</th>
                        <th>@Localizer["Revenue"]</th>
                        <th>@Localizer["Profit"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ProductVariantName</td>
                            <td>@item.Quantity</td>
                            <td>@item.UnitPrice.ToString("N0") @currency</td>
                            <td>@item.CostPrice.ToString("N0") @currency</td>
                            <td>@item.LineTotal.ToString("N0") @currency</td>
                            <td class="@(item.LineProfit >= 0 ? "text-success" : "text-danger") fw-semibold">
                                @item.LineProfit.ToString("N0") @currency
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/create-product.css" />
    <link rel="stylesheet" href="~/css/pages/public-share-panel.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/public-share.js" asp-append-version="true"></script>
    <script src="~/js/sale-details.js" asp-append-version="true"></script>
}
