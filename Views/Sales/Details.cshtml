@using ClothInventoryApp.Dto.Sale
@model ViewSaleDto

@{
    ViewData["Title"] = "Sale Details";
    var currency = ViewData["Currency"] as string ?? "";
}

<div class="create-product-shell">
    <div class="create-main-card">
        <div class="section-header">
            <div>
                <h3>Sale Details</h3>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="InvoicePdf" asp-route-id="@Model.Id"
                   class="btn-modern-primary" style="height:40px;padding:0 16px;font-size:.85rem">
                    <i class="bi bi-file-earmark-pdf-fill me-1"></i> Download Invoice
                </a>
                <a asp-action="Index" class="btn-modern-outline" style="height:40px;padding:0 16px;font-size:.85rem">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </a>
            </div>
        </div>

        <div class="form-grid-modern">
            <div class="form-group-modern">
                <label class="form-label-modern">Sale Date</label>
                <input value="@Model.SaleDate.ToString("yyyy-MM-dd")" class="input-modern" readonly />
            </div>

            @if (Model.CustomerId.HasValue)
            {
                <div class="form-group-modern">
                    <label class="form-label-modern">Customer</label>
                    <div class="input-modern d-flex align-items-center gap-2" style="background:#f8fafc;cursor:default">
                        <i class="bi bi-person-fill" style="color:#6366f1"></i>
                        <a asp-controller="Customer" asp-action="Details" asp-route-id="@Model.CustomerId"
                           style="color:#0f172a;text-decoration:none;font-weight:600">@Model.CustomerName</a>
                        @if (!string.IsNullOrEmpty(Model.CustomerPhone))
                        {
                            <span class="text-muted" style="font-size:13px">· @Model.CustomerPhone</span>
                        }
                    </div>
                </div>
            }

            <div class="form-group-modern">
                <label class="form-label-modern">Total Revenue</label>
                <input value="@(Model.TotalAmount.ToString("N0") + " " + currency)" class="input-modern" readonly />
            </div>

            @if (Model.Discount > 0)
            {
                <div class="form-group-modern">
                    <label class="form-label-modern">Discount</label>
                    <input value="@(Model.Discount.ToString("N0") + " " + currency)" class="input-modern text-danger" readonly />
                </div>
            }

            <div class="form-group-modern">
                <label class="form-label-modern">Total Profit</label>
                <input value="@(Model.TotalProfit.ToString("N0") + " " + currency)"
                       class="input-modern @(Model.TotalProfit >= 0 ? "text-success" : "text-danger") fw-bold" readonly />
            </div>
        </div>

        <hr />
        <div class="table-responsive-modern">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Variant</th>
                        <th>Qty</th>
                        <th>Unit Price</th>
                        <th>Cost Price</th>
                        <th>Revenue</th>
                        <th>Profit</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ProductVariantName</td>
                            <td>@item.Quantity</td>
                            <td>@item.UnitPrice.ToString("N0") @currency</td>
                            <td>@item.CostPrice.ToString("N0") @currency</td>
                            <td>@item.LineTotal.ToString("N0") @currency</td>
                            <td class="@(item.LineProfit >= 0 ? "text-success" : "text-danger") fw-semibold">
                                @item.LineProfit.ToString("N0") @currency
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="form-footer-modern">
            <a asp-action="InvoicePdf" asp-route-id="@Model.Id" class="btn-modern-primary btn-modern-lg">
                <i class="bi bi-file-earmark-pdf-fill"></i> Download Invoice PDF
            </a>
            <a asp-action="Index" class="btn-modern-outline btn-modern-lg">Back</a>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/create-product.css" />
}
