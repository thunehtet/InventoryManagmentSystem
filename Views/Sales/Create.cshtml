@using ClothInventoryApp.Dto.Sale
@model CreateSaleDto

@{
    ViewData["Title"] = Localizer["New Sale"];
    bool isStaff = User.IsInRole("Staff");
}

<div class="sc-shell">

    <!-- ══════════ LEFT: Product Picker ══════════ -->
    <div class="sc-picker">
        <div class="sc-picker-head">
            <div class="sc-picker-title">
                <i class="bi bi-grid-3x3-gap-fill"></i>
                <span>@Localizer["Products"]</span>
                <span class="sc-chip" id="variantCount">—</span>
            </div>
            <!-- Product filter tabs (populated by JS) -->
            <div class="sc-filter-tabs" id="filterTabs"></div>

            <div class="sc-search-wrap">
                <i class="bi bi-search sc-search-icon"></i>
                <input type="text" id="variantSearch"
                       placeholder="@Localizer["Search SKU, color, size…"]"
                       class="sc-search-input" autocomplete="off" />
            </div>
        </div>

        <div class="sc-grid" id="variantGrid">
            <div class="sc-loading">
                <div class="spinner-border spinner-border-sm" role="status"></div>
                <span>@Localizer["Loading products…"]</span>
            </div>
        </div>
    </div>

    <!-- ══════════ RIGHT: Order Panel ══════════ -->
    <div class="sc-order">

        <div class="sc-order-head">
            <i class="bi bi-receipt-cutoff"></i>
            <span>@Localizer["New Sale"]</span>
            @{
                int saleUsed = ViewBag.MonthlySaleUsed is int su ? su : 0;
                int? saleMax = ViewBag.MonthlySaleMax as int?;
            }
            @if (saleMax.HasValue)
            {
                <span class="sa-usage-pill @(saleUsed >= saleMax.Value ? "sa-usage-pill--warn" : "")">
                    @saleUsed / @saleMax @Localizer["Sales this month"]
                </span>
            }
        </div>

        <form asp-action="Create" method="post" id="saleForm" class="sc-form"
              data-is-staff="@(isStaff ? "true" : "false")"
              data-load-failed="@Localizer["Failed to load products. Please refresh."].Value"
              data-all="@Localizer["All"].Value"
              data-no-products="@Localizer["No products found"].Value"
              data-out-of-stock="@Localizer["Out of stock"].Value"
              data-left="@Localizer["left"].Value"
              data-price="@Localizer["Price"].Value"
              data-cart-required="@Localizer["Please add at least one product to the sale."].Value">

            <div id="clientError" class="sc-error sc-hidden"></div>
            <div asp-validation-summary="ModelOnly" class="sc-error"></div>

            <!-- Sale Date -->
            <div class="sc-field-group">
                <label class="sc-label">@Localizer["Sale Date"]</label>
                <input name="SaleDate" type="date" class="sc-input"
                       value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
            </div>

            <!-- Customer (Starter+ only) -->
            @if ((bool)(ViewBag.HasCustomers ?? false))
            {
            <div class="sc-field-group">
                <label class="sc-label">@Localizer["Customer"] <span class="text-muted small">(@Localizer["optional"])</span></label>
                <select name="CustomerId" class="sc-input">
                    <option value="">@Localizer["— Walk-in / No customer —"]</option>
                    @foreach (var c in (ViewBag.Customers as Microsoft.AspNetCore.Mvc.Rendering.SelectList ?? new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Enumerable.Empty<object>())))
                    {
                        <option value="@c.Value">@c.Text</option>
                    }
                </select>
                <div class="sc-field-note">
                    <a asp-controller="Customer" asp-action="Create" target="_blank"
                       class="sc-field-link">
                        <i class="bi bi-person-plus-fill"></i> @Localizer["Add new customer"]
                    </a>
                </div>
            </div>
            }

            <!-- Cart -->
            <div class="sc-cart-wrap">
                <div class="sc-cart-head">
                    <span class="sc-cart-title"><i class="bi bi-cart3"></i> @Localizer["Items"]</span>
                    <span class="sc-cart-badge" id="cartBadge">0</span>
                </div>

                <div id="emptyCart" class="sc-empty">
                    <i class="bi bi-cart-dash"></i>
                    <p>@Localizer["Click a product card to add items"]</p>
                </div>

                <div id="cartList" class="sc-cart-list"></div>
            </div>

            <!-- Hidden inputs populated by JS before submit -->
            <div id="hiddenInputs"></div>

            <!-- Discount (optional) -->
            <div class="sc-field-group sc-discount-group">
                <label class="sc-label">@Localizer["Discount"] <span class="text-muted small">(@Localizer["optional"])</span></label>
                <input name="Discount" id="discountInput" type="number" min="0" class="sc-input"
                       placeholder="@Localizer["Enter discount amount (0 = no discount)"]" value="0" />
            </div>

            <!-- Totals -->
            <div class="sc-totals">
                <div class="sc-total-row sc-hidden" id="discountRow">
                    <span class="sc-total-label">@Localizer["Discount"]</span>
                    <span class="sc-total-val sc-cost" id="sumDiscount">0</span>
                </div>
                <div class="sc-total-row sc-profit-row">
                    <span class="sc-total-label">@Localizer["Total"]</span>
                    <span class="sc-total-val" id="sumRevenue">0</span>
                </div>
            </div>

            <!-- Actions -->
            <div class="sc-form-footer">
                <button type="submit" class="btn-modern-primary btn-modern-lg sc-submit">
                    <i class="bi bi-check-circle-fill"></i> @Localizer["Save Sale"]
                </button>
                <a asp-action="Index" class="btn-modern-outline btn-modern-lg">@Localizer["Cancel"]</a>
            </div>

        </form>
    </div>

</div>

@section Scripts {
    <script src="~/js/sale-create.js" asp-append-version="true"></script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/create-product.css" />
    <link rel="stylesheet" href="~/css/pages/sale-create.css" />
}
