@using ClothInventoryApp.Dto.Stock
@model IEnumerable<ViewStockDto>

@{
    ViewData["Title"] = "Stock Movements";
}

<div class="product-index-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <div class="hero-kicker">
                <i class="bi bi-arrow-left-right"></i>
                <span>Stock</span>
            </div>

            <h1>Stock Movements</h1>
            <p>Manage stock in, stock out, and adjustment records for your product variants.</p>

            <div class="hero-actions">
                <a asp-action="Create" class="btn-modern-primary">
                    <i class="bi bi-plus-circle"></i>
                    Create Stock Movement
                </a>
            </div>
        </div>

        <div class="product-hero-side">
            <div class="hero-stat-card">
                <div class="hero-stat-icon">
                    <i class="bi bi-boxes"></i>
                </div>
                <div class="hero-stat-title">Total Records</div>
                <div class="hero-stat-text">
                    @Model.Count() stock movements
                </div>
            </div>
        </div>
    </div>

    <div class="product-table-card">
        <div class="section-header">
            <div>
                <h3>All Stock Movements</h3>
                <p>Overview of stock transactions for your inventory.</p>
            </div>
        </div>

        <div class="table-responsive-modern">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Variant</th>
                        <th>Movement Type</th>
                        <th>Quantity</th>
                        <th>Movement Date</th>
                        <th>Remarks</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <div>No stock movement found</div>
                                <a asp-action="Create" class="btn-modern-primary mt-2">
                                    Create your first stock movement
                                </a>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ProductVariantName</td>
                                <td>@item.MovementType</td>
                                <td>@item.Quantity</td>
                                <td>@item.MovementDate.ToString("yyyy-MM-dd")</td>
                                <td>@item.Remarks</td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-icon">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-icon">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-icon text-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" />
}