@using ClothInventoryApp.Dto.Stock
@model IEnumerable<ViewStockDto>
@{
    ViewData["Title"] = "Stock Movements";
    var pg = ViewBag.Pagination as ClothInventoryApp.Models.PaginationViewModel;
}

<div class="product-index-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <div class="hero-kicker">
                <i class="bi bi-arrow-left-right"></i>
                <span>@Localizer["Stock"]</span>
            </div>
            <h1>@Localizer["Stock Movements"]</h1>
            <div class="hero-actions">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn-modern-primary">
                        <i class="bi bi-plus-circle"></i> @Localizer["Create Stock Movement"]
                    </a>
                }
            </div>
        </div>
        <div class="product-hero-side">
            <div class="hero-stat-card">
                <div class="hero-stat-icon"><i class="bi bi-boxes"></i></div>
                <div class="hero-stat-title">@Localizer["Total Records"]</div>
                <div class="hero-stat-text">@(pg?.TotalCount ?? 0) @Localizer["Stock Movements"]</div>
            </div>
        </div>
    </div>

    <!-- FILTER BAR -->
    <div class="list-filter-bar">
        <form method="get" asp-action="Index" class="filter-form">
            @if (pg != null) { <input type="hidden" name="size" value="@pg.PageSize" /> }
            <div class="filter-search-wrap">
                <i class="bi bi-search filter-search-icon"></i>
                <input type="text" name="search" value="@ViewBag.Search"
                       class="filter-search-input" placeholder="@Localizer["Search variant, SKU, type, remarks…"]" autocomplete="off" />
                @if (!string.IsNullOrWhiteSpace(ViewBag.Search as string))
                {
                    <a href="@Url.Action("Index", new { size = pg?.PageSize ?? 10 })" class="filter-clear-btn" title="Clear">
                        <i class="bi bi-x-circle-fill"></i>
                    </a>
                }
            </div>
            <button type="submit" class="filter-search-btn">
                <i class="bi bi-search"></i> @Localizer["Search"]
            </button>
        </form>
    </div>

    <!-- TABLE CARD -->
    <div class="product-table-card">
        <div class="table-responsive-modern">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>@Localizer["Variant"]</th>
                        <th>@Localizer["Type"]</th>
                        <th>@Localizer["Quantity"]</th>
                        <th>@Localizer["Date"]</th>
                        <th>@Localizer["Remarks"]</th>
                        <th>@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <div>@(string.IsNullOrWhiteSpace(ViewBag.Search as string) ? Localizer["No stock movements yet"].Value : Localizer["No movements match your search"].Value)</div>
                                @if (User.IsInRole("Admin") && string.IsNullOrWhiteSpace(ViewBag.Search as string))
                                {
                                    <a asp-action="Create" class="btn-modern-primary mt-2">@Localizer["Create your first stock movement"]</a>
                                }
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold" style="font-size:0.875rem">@item.ProductVariantName</td>
                                <td>
                                    @if (item.MovementType == "IN")
                                    {
                                        <span class="badge-modern badge-success">IN</span>
                                    }
                                    else if (item.MovementType == "OUT")
                                    {
                                        <span class="badge-modern" style="background:#fee2e2;color:#dc2626;">OUT</span>
                                    }
                                    else
                                    {
                                        <span class="badge-modern badge-muted">@item.MovementType</span>
                                    }
                                </td>
                                <td class="fw-semibold">@item.Quantity</td>
                                <td class="text-muted" style="font-size:0.875rem">@item.MovementDate.ToString("dd MMM yyyy")</td>
                                <td class="text-muted" style="font-size:0.875rem">@(item.Remarks ?? "—")</td>
                                <td>
                                    <div class="table-actions">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="action-btn action-btn-view" title="Details"><i class="bi bi-eye-fill"></i></a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn action-btn-edit" title="Edit"><i class="bi bi-pencil-fill"></i></a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn action-btn-delete" title="Delete"><i class="bi bi-trash-fill"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (pg != null) { @await Html.PartialAsync("_Pagination", pg) }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" />
}
