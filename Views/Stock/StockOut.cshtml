@model ClothInventoryApp.Dto.StockInViewModel

@{
    ViewData["Title"] = Localizer["Stock Out"];
}

<div class="create-product-shell">
    <div class="create-product-hero">
        <div class="create-product-hero-content">
            <div class="hero-kicker">
                <i class="bi bi-box-arrow-up"></i>
                <span>@Localizer["Stock Out"]</span>
            </div>

            <h1>@Localizer["Remove stock"]</h1>
            <p>@Localizer["Record outgoing stock for a product variant."]</p>

            <div class="hero-actions">
                <a asp-action="Inventory" class="btn-soft-light">
                    <i class="bi bi-arrow-left"></i>
                    @Localizer["Back to Inventory"]
                </a>
            </div>
        </div>
    </div>

    <div class="create-product-grid">
        <div class="create-main-card">
            <div class="section-header">
                <div>
                    <h3>@Localizer["Stock out details"]</h3>
                    <p>@Localizer["Fill in the product variant and quantity issued."]</p>
                </div>
            </div>

            <form asp-action="StockOut" method="post" class="modern-product-form">
                <div asp-validation-summary="ModelOnly" class="validation-summary-modern"></div>

                <div class="form-grid-modern">
                    <div class="form-group-modern form-group-full">
                        <label asp-for="ProductVariantId" class="form-label-modern"></label>
                        <select asp-for="ProductVariantId" asp-items="ViewBag.ProductVariants" class="input-modern input-modern-lg" data-searchable-picker="true" data-placeholder="Select a variant" data-search-placeholder="Search variant by name, SKU, color, or size">
                            <option value="">@Localizer["-- Select Variant --"]</option>
                        </select>
                        <span asp-validation-for="ProductVariantId" class="field-validation-modern"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="Quantity" class="form-label-modern"></label>
                        <input asp-for="Quantity" class="input-modern" type="number" />
                        <span asp-validation-for="Quantity" class="field-validation-modern"></span>
                    </div>

                    <div class="form-group-modern form-group-full">
                        <label asp-for="Remarks" class="form-label-modern"></label>
                        <textarea asp-for="Remarks" class="input-modern" rows="4" placeholder="@Localizer["Optional remarks"]"></textarea>
                        <span asp-validation-for="Remarks" class="field-validation-modern"></span>
                    </div>
                </div>

                <div class="form-footer-modern">
                    <button type="submit" class="btn-modern-danger btn-modern-lg">
                        <i class="bi bi-check2-circle"></i>
                        @Localizer["Save Stock Out"]
                    </button>

                    <a asp-action="Inventory" class="btn-modern-outline btn-modern-lg">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/searchable-picker.js" asp-append-version="true"></script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/create-product.css" />
}
