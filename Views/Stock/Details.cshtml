@using ClothInventoryApp.Dto.Stock
@model ViewStockDto

@{
    ViewData["Title"] = Localizer["Stock Movement Details"];
}

<div class="create-product-shell">
    <div class="create-product-grid">
        <div class="create-main-card">
            <div class="section-header">
                <div>
                    <h3>@Localizer["Stock movement details"]</h3>
                    <p>@Localizer["Read-only view of this stock record."]</p>
                </div>
            </div>

            <div class="form-grid-modern">
                <div class="form-group-modern form-group-full">
                    <label class="form-label-modern">@Localizer["Product Variant"]</label>
                    <input value="@Model.ProductVariantName" class="input-modern input-modern-lg" readonly />
                </div>

                <div class="form-group-modern">
                    <label class="form-label-modern">@Localizer["Movement Type"]</label>
                    <input value="@Model.MovementType" class="input-modern" readonly />
                </div>

                <div class="form-group-modern">
                    <label class="form-label-modern">@Localizer["Quantity"]</label>
                    <input value="@Model.Quantity" class="input-modern" readonly />
                </div>

                <div class="form-group-modern">
                    <label class="form-label-modern">@Localizer["Movement Date"]</label>
                    <input value="@Model.MovementDate.ToString("yyyy-MM-dd")" class="input-modern" readonly />
                </div>

                <div class="form-group-modern form-group-full">
                    <label class="form-label-modern">@Localizer["Remarks"]</label>
                    <textarea class="input-modern" rows="4" readonly>@Model.Remarks</textarea>
                </div>
            </div>

            <div class="form-footer-modern">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-modern-primary btn-modern-lg">
                    <i class="bi bi-pencil"></i>
                    @Localizer["Edit"]
                </a>

                <a asp-action="Index" class="btn-modern-outline btn-modern-lg">
                    @Localizer["Back"]
                </a>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/create-product.css" />
}
