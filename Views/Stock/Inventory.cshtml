@model IEnumerable<ClothInventoryApp.Dto.InventoryViewModel>

@{
    ViewData["Title"] = Localizer["Inventory Log"];
    bool isLowStock = ViewBag.LowStock == true;
    int lowStockThreshold = ViewBag.LowStockThreshold ?? 10;
    bool lowStockAlertVisible = ViewBag.LowStockAlertVisible ?? true;
    var pg = ViewBag.Pagination as ClothInventoryApp.Models.PaginationViewModel;
}

<div class="product-index-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <h1 class="product-hero-title">
                <i class="bi bi-box-seam-fill"></i>
                @(isLowStock ? Localizer["Low Stock Items"].Value : Localizer["Inventory Log"].Value)
            </h1>
            <p class="product-hero-sub">
                @(isLowStock
                    ? string.Format(Localizer["Variants with stock below {0} units"].Value, lowStockThreshold)
                    : Localizer["Current stock balance for each product variant."].Value)
            </p>
        </div>
        <div class="d-flex gap-2 align-items-center">
            @if (isLowStock)
            {
                <a asp-action="Inventory" class="btn-modern-secondary">
                    <i class="bi bi-arrow-left"></i> @Localizer["All Stock"]
                </a>
            }
            else if (lowStockAlertVisible)
            {
                <a asp-action="Inventory" asp-route-lowstock="true" class="btn-modern-secondary">
                    <i class="bi bi-exclamation-triangle-fill"></i> @Localizer["Low Stock"]
                </a>
            }
            <a asp-action="StockIn" class="btn-modern-primary">
                <i class="bi bi-plus-circle-fill"></i> @Localizer["Stock In"]
            </a>
        </div>
    </div>

    <div class="list-filter-bar">
        <form method="get" asp-action="Inventory" class="filter-form">
            @if (pg != null)
            {
                <input type="hidden" name="size" value="@pg.PageSize" />
            }
            @if (isLowStock)
            {
                <input type="hidden" name="lowstock" value="true" />
            }
            <div class="filter-search-wrap">
                <i class="bi bi-search filter-search-icon"></i>
                <input type="text"
                       name="search"
                       value="@ViewBag.Search"
                       class="filter-search-input"
                       placeholder="@Localizer["Search product, SKU, color, size..."]"
                       autocomplete="off" />
                @if (!string.IsNullOrWhiteSpace(ViewBag.Search as string))
                {
                    <a href="@Url.Action("Inventory", new { lowstock = isLowStock ? "true" : null, size = pg?.PageSize ?? 10 })"
                       class="filter-clear-btn"
                       title="@Localizer["Clear"]">
                        <i class="bi bi-x-circle-fill"></i>
                    </a>
                }
            </div>
            <button type="submit" class="filter-search-btn">
                <i class="bi bi-search"></i> @Localizer["Search"]
            </button>
        </form>
    </div>

    <div class="product-table-card">
        <div class="table-responsive">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>@Localizer["Product"]</th>
                        <th>SKU</th>
                        <th>@Localizer["Color"]</th>
                        <th>@Localizer["Size"]</th>
                        <th>@Localizer["Current Stock"]</th>
                        <th>@Localizer["Status"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <div>@(isLowStock ? Localizer["No low stock items found."].Value : Localizer["No inventory records found."].Value)</div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            var stockClass = item.CurrentStock <= 0 ? "stock-empty" :
                                             item.CurrentStock < lowStockThreshold ? "stock-low" : "stock-ok";
                            <tr>
                                <td class="fw-semibold">@item.ProductName</td>
                                <td>@item.SKU</td>
                                <td>@item.Color</td>
                                <td>@item.Size</td>
                                <td class="fw-bold @stockClass">@item.CurrentStock</td>
                                <td>
                                    @if (item.CurrentStock <= 0)
                                    {
                                        <span class="badge-pill badge-out-of-stock">@Localizer["Out of Stock"]</span>
                                    }
                                    else if (item.CurrentStock < lowStockThreshold)
                                    {
                                        <span class="badge-pill badge-low-stock">@Localizer["Low Stock"]</span>
                                    }
                                    else
                                    {
                                        <span class="badge-pill badge-in-stock">@Localizer["In Stock"]</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (pg != null)
        {
            @await Html.PartialAsync("_Pagination", pg)
        }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" asp-append-version="true" />
}
