@model IEnumerable<ClothInventoryApp.Dto.InventoryViewModel>

@{
    ViewData["Title"] = "Inventory Log";
    bool isLowStock = ViewBag.LowStock == true;
}

<div class="product-index-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <h1 class="product-hero-title">
                <i class="bi bi-box-seam-fill"></i>
                @(isLowStock ? "Low Stock Items" : "Inventory Log")
            </h1>
            <p class="product-hero-sub">
                @(isLowStock ? "Variants with stock below 10 units" : "Current stock balance per product variant")
            </p>
        </div>
        <div class="d-flex gap-2 align-items-center">
            @if (isLowStock)
            {
                <a asp-action="Inventory" class="btn-modern-secondary">
                    <i class="bi bi-arrow-left"></i> All Stock
                </a>
            }
            else
            {
                <a asp-action="Inventory" asp-route-lowstock="true" class="btn-modern-secondary">
                    <i class="bi bi-exclamation-triangle-fill"></i> Low Stock
                </a>
            }
            <a asp-action="StockIn" class="btn-modern-primary">
                <i class="bi bi-plus-circle-fill"></i> Stock In
            </a>
        </div>
    </div>

    <div class="product-table-card">
        <div class="table-responsive">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>SKU</th>
                        <th>Color</th>
                        <th>Size</th>
                        <th>Current Stock</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <div>@(isLowStock ? "No low stock items found." : "No inventory records found.")</div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            var stockClass = item.CurrentStock <= 0 ? "stock-empty" :
                                             item.CurrentStock < 10  ? "stock-low"   : "stock-ok";
                            <tr>
                                <td class="fw-semibold">@item.ProductName</td>
                                <td>@item.SKU</td>
                                <td>@item.Color</td>
                                <td>@item.Size</td>
                                <td class="fw-bold @stockClass">@item.CurrentStock</td>
                                <td>
                                    @if (item.CurrentStock <= 0)
                                    {
                                        <span class="badge-pill badge-out-of-stock">Out of Stock</span>
                                    }
                                    else if (item.CurrentStock < 10)
                                    {
                                        <span class="badge-pill badge-low-stock">Low Stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge-pill badge-in-stock">In Stock</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" asp-append-version="true" />
}
