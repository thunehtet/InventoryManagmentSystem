@using ClothInventoryApp.Dto.ProductVariant
@model IEnumerable<ViewProductVariantDto>
@{
    ViewData["Title"] = "Product Variants";
    var currency = ViewData["Currency"] as string ?? "";
    var pg = ViewBag.Pagination as ClothInventoryApp.Models.PaginationViewModel;
}

<div class="product-index-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <div class="hero-kicker">
                <i class="bi bi-diagram-3-fill"></i>
                <span>@Localizer["Variants"]</span>
            </div>
            <h1>@Localizer["Product Variants"]</h1>
            <div class="hero-actions">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn-modern-primary">
                        <i class="bi bi-plus-circle"></i> @Localizer["Create Variant"]
                    </a>
                }
            </div>
        </div>
        <div class="product-hero-side">
            <div class="hero-stat-card">
                <div class="hero-stat-icon"><i class="bi bi-boxes"></i></div>
                <div class="hero-stat-title">@Localizer["Total Variants"]</div>
                <div class="hero-stat-text">@(pg?.TotalCount ?? 0) @Localizer["variants in your catalog"]</div>
            </div>
        </div>
    </div>

    <!-- FILTER BAR -->
    <div class="list-filter-bar">
        <form method="get" asp-action="Index" class="filter-form">
            @if (pg != null) { <input type="hidden" name="size" value="@pg.PageSize" /> }
            <div class="filter-search-wrap">
                <i class="bi bi-search filter-search-icon"></i>
                <input type="text" name="search" value="@ViewBag.Search"
                       class="filter-search-input" placeholder="@Localizer["Search product, SKU, color, size…"]" autocomplete="off" />
                @if (!string.IsNullOrWhiteSpace(ViewBag.Search as string))
                {
                    <a href="@Url.Action("Index", new { size = pg?.PageSize ?? 10 })" class="filter-clear-btn" title="Clear">
                        <i class="bi bi-x-circle-fill"></i>
                    </a>
                }
            </div>
            <button type="submit" class="filter-search-btn">
                <i class="bi bi-search"></i> @Localizer["Search"]
            </button>
        </form>
    </div>

    <!-- TABLE CARD -->
    <div class="product-table-card">
        <div class="table-responsive-modern">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>@Localizer["Product"]</th>
                        <th>SKU</th>
                        <th>@Localizer["Size"]</th>
                        <th>@Localizer["Color"]</th>
                        <th>
                            @Localizer["Cost Price"]
                            <button class="sensitive-toggle-btn" data-sensitive-btn="variant-cost" title="Show">
                                <i class="bi bi-eye-fill"></i>
                            </button>
                        </th>
                        <th>@Localizer["Selling Price"]</th>
                        <th>@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <div>@(string.IsNullOrWhiteSpace(ViewBag.Search as string) ? Localizer["No variants yet"].Value : Localizer["No variants match your search"].Value)</div>
                                @if (User.IsInRole("Admin") && string.IsNullOrWhiteSpace(ViewBag.Search as string))
                                {
                                    <a asp-action="Create" class="btn-modern-primary mt-2">@Localizer["Create your first variant"]</a>
                                }
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td class="fw-semibold">@item.SKU</td>
                                <td>@item.Size</td>
                                <td>@item.Color</td>
                                <td><span class="sensitive-val" data-sensitive-group="variant-cost" data-real="@(item.CostPrice.ToString("N0")) @currency">••••</span></td>
                                <td>@item.SellingPrice.ToString("N0") @currency</td>
                                <td>
                                    <div class="table-actions">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="action-btn action-btn-view" title="Details"><i class="bi bi-eye-fill"></i></a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn action-btn-edit" title="Edit"><i class="bi bi-pencil-fill"></i></a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn action-btn-delete" title="Delete"><i class="bi bi-trash-fill"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (pg != null) { @await Html.PartialAsync("_Pagination", pg) }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" />
}

@section Scripts {
    <script src="~/js/sensitive-toggle.js" asp-append-version="true"></script>
}
