@using ClothInventoryApp.Dto.ProductVariant
@model ViewProductVariantDto


@{
    ViewData["Title"] = Localizer["Edit Variant"];
}

<div class="create-product-shell">
    <div class="create-product-hero">
        <div class="create-product-hero-content">
            <div class="hero-kicker">
                <i class="bi bi-pencil-square"></i>
                <span>@Localizer["Variant Update"]</span>
            </div>

            <h1>@Localizer["Edit Variant"]</h1>
            <p>
                @Localizer["Update the product variant details and keep your inventory accurate."]
            </p>

            <div class="hero-actions">
                <a asp-action="Index" class="btn-soft-light">
                    <i class="bi bi-arrow-left"></i>
                    @Localizer["Back to Variants"]
                </a>
            </div>
        </div>
    </div>

    <div class="create-product-grid">
        <div class="create-main-card">
            <div class="section-header">
                <div>
                    <h3>@Localizer["Variant Details"]</h3>
                    <p>@Localizer["Update the selected product variant."]</p>
                </div>
            </div>

            <form asp-action="Edit" method="post" enctype="multipart/form-data" class="modern-product-form">
                <div asp-validation-summary="ModelOnly" class="validation-summary-modern"></div>

                <input asp-for="Id" type="hidden" />

                <div class="form-grid-modern">
                    <div class="form-group-modern form-group-full">
                        <label asp-for="ProductId" class="form-label-modern"></label>
                        <select asp-for="ProductId" asp-items="ViewBag.Products" class="input-modern input-modern-lg" data-searchable-picker="true" data-placeholder="Select a product" data-search-placeholder="Search product name">
                            <option value="">@Localizer["-- Select Product --"]</option>
                        </select>
                        <span asp-validation-for="ProductId" class="field-validation-modern"></span>
                    </div>

                    <div class="form-group-modern form-group-full">
                        <label asp-for="SKU" class="form-label-modern"></label>
                        <input asp-for="SKU" class="input-modern input-modern-lg" />
                        <span asp-validation-for="SKU" class="field-validation-modern"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="Size" class="form-label-modern"></label>
                        <input asp-for="Size" class="input-modern" />
                        <span asp-validation-for="Size" class="field-validation-modern"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="Color" class="form-label-modern"></label>
                        <input asp-for="Color" class="input-modern" />
                        <span asp-validation-for="Color" class="field-validation-modern"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="CostPrice" class="form-label-modern"></label>
                        <input asp-for="CostPrice" class="input-modern" type="number" step="1" />
                        <span asp-validation-for="CostPrice" class="field-validation-modern"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="SellingPrice" class="form-label-modern"></label>
                        <input asp-for="SellingPrice" class="input-modern" type="number" step="1" />
                        <span asp-validation-for="SellingPrice" class="field-validation-modern"></span>
                    </div>

                    <div class="form-group-modern form-group-full">
                        <label asp-for="NewImages" class="form-label-modern">@Localizer["Add more variant images"]</label>
                        <input asp-for="NewImages" class="input-modern" type="file" accept="image/png,image/jpeg" multiple />
                        <span class="text-muted small">@Localizer["Upload JPG/PNG images for this exact variant."]</span>
                    </div>
                </div>

                <div class="form-footer-modern">
                    <button type="submit" class="btn-modern-primary btn-modern-lg">
                        <i class="bi bi-check2-circle"></i>
                        @Localizer["Update Variant"]
                    </button>

                    <a asp-action="Index" class="btn-modern-outline btn-modern-lg">
                        Cancel
                    </a>
                </div>
            </form>

            <div class="section-header mt-4">
                <div>
                    <h3>@Localizer["Variant images"]</h3>
                    <p>@Localizer["Primary image is used on the e-commerce product card, product page, and cart."]</p>
                </div>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="validation-summary-modern">@TempData["Error"]</div>
            }

            @if (Model.Images.Count == 0)
            {
                <div class="empty-state">
                    <i class="bi bi-images"></i>
                    <div>@Localizer["No images uploaded for this variant yet."]</div>
                </div>
            }
            else
            {
                <div class="variant-image-admin-grid">
                    @foreach (var image in Model.Images)
                    {
                        <div class="variant-image-admin-card">
                            <img src="@image.ImageUrl" alt="@Model.SKU" />
                            @if (image.IsPrimary)
                            {
                                <span class="variant-image-badge">@Localizer["Primary"]</span>
                            }
                            <div class="variant-image-actions">
                                @if (!image.IsPrimary)
                                {
                                    <form asp-action="SetPrimaryImage" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="imageId" value="@image.Id" />
                                        <button type="submit" class="btn-modern-outline">@Localizer["Set Primary"]</button>
                                    </form>
                                }
                                <form asp-action="RemoveImage" method="post" onsubmit="return confirm('@Localizer["Remove this image?"]');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="imageId" value="@image.Id" />
                                    <button type="submit" class="btn-modern-outline order-btn-danger">@Localizer["Remove"]</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/searchable-picker.js" asp-append-version="true"></script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/create-product.css" />
}
