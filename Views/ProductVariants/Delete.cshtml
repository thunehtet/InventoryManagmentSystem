@using ClothInventoryApp.Dto.ProductVariant
@model ViewProductVariantDto

@{
    ViewData["Title"] = Localizer["Delete Variant"];
    var currency = ViewData["Currency"] as string ?? "";
    var canDelete = !(ViewBag.CanDelete is bool deleteAllowed) || deleteAllowed;
}

<div class="create-product-shell">
    <div class="create-product-hero">
        <div class="create-product-hero-content">
            <div class="hero-kicker">
                <i class="bi bi-trash-fill"></i>
                <span>@Localizer["Delete Variant"]</span>
            </div>

            <h1>@Localizer["Delete Variant"]</h1>
            <p>
                @Localizer["Please review the variant details below before deleting it."]
            </p>

            <div class="hero-actions">
                <a asp-action="Index" class="btn-soft-light">
                    <i class="bi bi-arrow-left"></i>
                    @Localizer["Back to Variants"]
                </a>
            </div>
        </div>
    </div>

    <div class="create-product-grid">
        <div class="create-main-card">
            @if (TempData["Error"] is string errorMessage)
            {
                <div class="alert alert-danger mb-3">@errorMessage</div>
            }

            @if (ViewBag.DeleteMessage is string deleteMessage)
            {
                <div class="alert alert-warning mb-3">@deleteMessage</div>
            }

            <div class="section-header">
                <div>
                    <h3>@Localizer["Variant details"]</h3>
                    <p>@Localizer["Confirm before deleting this product variant."]</p>
                </div>
            </div>

            <div class="form-grid-modern">
                <div class="form-group-modern form-group-full">
                    <label class="form-label-modern">@Localizer["Product"]</label>
                    <input value="@Model.ProductName" class="input-modern input-modern-lg" readonly />
                </div>

                <div class="form-group-modern form-group-full">
                    <label class="form-label-modern">@Localizer["SKU"]</label>
                    <input value="@Model.SKU" class="input-modern input-modern-lg" readonly />
                </div>

                <div class="form-group-modern">
                    <label class="form-label-modern">@Localizer["Size"]</label>
                    <input value="@Model.Size" class="input-modern" readonly />
                </div>

                <div class="form-group-modern">
                    <label class="form-label-modern">@Localizer["Color"]</label>
                    <input value="@Model.Color" class="input-modern" readonly />
                </div>

                <div class="form-group-modern">
                    <label class="form-label-modern">@Localizer["Cost Price"]</label>
                    <input value="@(Model.CostPrice.ToString("N0") + " " + currency)" class="input-modern" readonly />
                </div>

                <div class="form-group-modern">
                    <label class="form-label-modern">@Localizer["Selling Price"]</label>
                    <input value="@(Model.SellingPrice.ToString("N0") + " " + currency)" class="input-modern" readonly />
                </div>
            </div>

            <form asp-action="Delete" method="post" class="mt-4">
                <input type="hidden" asp-for="Id" />

                <div class="form-footer-modern">
                    <button type="submit" class="btn-modern-danger btn-modern-lg" disabled="@(!canDelete ? "disabled" : null)">
                        <i class="bi bi-trash"></i>
                        @Localizer["Delete Variant"]
                    </button>

                    <a asp-action="Index" class="btn-modern-outline btn-modern-lg">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/create-product.css" />
}
