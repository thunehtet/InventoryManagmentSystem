@{
    Layout = null;
    ViewData["Title"] = "Request Sent";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="~/images/websitelogo.png" asp-append-version="true" />
    <title>Request Sent — StockEasy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="auth-body-modern">

    <div class="auth-bg-shape auth-bg-shape-1"></div>
    <div class="auth-bg-shape auth-bg-shape-2"></div>

    <div class="auth-page" style="justify-content:center; align-items:center;">
        <div class="auth-panel" style="max-width:480px; width:100%;">
            <div class="auth-card-modern text-center">

                <div class="auth-card-header">
                    <div class="auth-card-avatar" style="background:linear-gradient(135deg,#d1fae5,#a7f3d0);">
                        <i class="bi bi-check-circle-fill" style="color:#059669; font-size:2rem;"></i>
                    </div>
                    <h2>Request Received</h2>
                    <p style="color:#64748b; margin-top:8px;">
                        Please contact your <strong>system administrator</strong> with your email address to
                        have your password reset. Your administrator can reset it from the
                        <em>Manage Users</em> panel.
                    </p>
                </div>

                <div class="auth-form" style="padding-top:0;">
                    <a asp-action="Login" class="btn auth-submit-btn">
                        <i class="bi bi-arrow-left"></i>
                        <span>Back to Sign In</span>
                    </a>
                </div>

                <div class="auth-card-footer">
                    <i class="bi bi-shield-check"></i>
                    Your data is protected and tenant-isolated.
                </div>

            </div>
        </div>
    </div>

</body>
</html>
