@using ClothInventoryApp.Resources
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject IStringLocalizer<SharedResource> Localizer
@model ClothInventoryApp.Dtos.Account.LoginDto
@{
    Layout = null;
    ViewData["Title"] = Localizer["Sign In"];
}

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="~/images/websitelogo.png" asp-append-version="true" />
    <title>@Localizer["Sign In"] - StockEasy</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-body-modern @(CultureInfo.CurrentUICulture.Name.StartsWith("my") ? "culture-my" : "")">

    <div class="auth-bg-shape auth-bg-shape-1"></div>
    <div class="auth-bg-shape auth-bg-shape-2"></div>

    <div class="auth-page">
        <div class="auth-layout">
            <div class="auth-showcase">
                <div class="auth-deco-card auth-deco-card--1">
                    <div class="auth-deco-icon"><i class="bi bi-boxes"></i></div>
                    <div>
                        <div class="auth-deco-val">1,240</div>
                        <div class="auth-deco-lbl">@Localizer["Units in stock"]</div>
                    </div>
                </div>
                <div class="auth-deco-card auth-deco-card--2">
                    <div class="auth-deco-icon auth-deco-icon--green"><i class="bi bi-graph-up-arrow"></i></div>
                    <div>
                        <div class="auth-deco-val" style="color:#34d399">+18%</div>
                        <div class="auth-deco-lbl">@Localizer["Sales this month"]</div>
                    </div>
                </div>
                <div class="auth-deco-card auth-deco-card--3">
                    <div class="auth-deco-icon auth-deco-icon--amber"><i class="bi bi-exclamation-triangle-fill"></i></div>
                    <div>
                        <div class="auth-deco-val" style="color:#fbbf24">3</div>
                        <div class="auth-deco-lbl">@Localizer["Low stock alerts"]</div>
                    </div>
                </div>

                <div class="auth-showcase-content">
                    <div class="auth-brand-modern">
                        <div class="auth-brand-logo">
                            <img src="~/images/websitelogo.png" alt="StockEasy" />
                        </div>
                    </div>

                    <div class="auth-showcase-text">
                        <div class="auth-badge">
                            <i class="bi bi-stars"></i>
                            <span>@Localizer["Free. Simple. Powerful."]</span>
                        </div>

                        <h1>
                            @Localizer["The smart inventory tool built for"]
                            <span class="auth-headline-accent">@Localizer["small businesses."]</span>
                        </h1>

                        <p>
                            @Localizer["Skip the expensive ERP. Manage products, track stock, record sales, and watch your profit grow from one clean dashboard."]
                        </p>
                    </div>

                    <div class="auth-feature-list">
                        <div class="auth-feature-item">
                            <div class="auth-feature-icon">
                                <i class="bi bi-box-seam-fill"></i>
                            </div>
                            <div>
                                <div class="auth-feature-title">@Localizer["Products & Variants"]</div>
                                <div class="auth-feature-text">@Localizer["Track every size, color, and SKU without spreadsheets."]</div>
                            </div>
                        </div>
                        <div class="auth-feature-item">
                            <div class="auth-feature-icon">
                                <i class="bi bi-arrow-left-right"></i>
                            </div>
                            <div>
                                <div class="auth-feature-title">@Localizer["Live Stock Movement"]</div>
                                <div class="auth-feature-text">@Localizer["Real-time stock-in, stock-out, and adjustment records."]</div>
                            </div>
                        </div>
                        <div class="auth-feature-item">
                            <div class="auth-feature-icon">
                                <i class="bi bi-cash-coin"></i>
                            </div>
                            <div>
                                <div class="auth-feature-title">@Localizer["Sales & Finance"]</div>
                                <div class="auth-feature-text">@Localizer["See your revenue, cost, and profit with every sale."]</div>
                            </div>
                        </div>
                    </div>

                    <div class="auth-trust-strip">
                        <span><i class="bi bi-check-circle-fill"></i> @Localizer["No credit card"]</span>
                        <span class="auth-trust-sep">·</span>
                        <span><i class="bi bi-check-circle-fill"></i> @Localizer["Multi-tenant"]</span>
                        <span class="auth-trust-sep">·</span>
                        <span><i class="bi bi-check-circle-fill"></i> @Localizer["Works anywhere"]</span>
                    </div>
                </div>
            </div>

            <div class="auth-panel">
                <a href="/" class="auth-back-link">
                    <i class="bi bi-arrow-left"></i> @Localizer["Back to home"]
                </a>

                <div class="auth-card-modern">
                    <div class="auth-card-header">
                        <div class="auth-card-avatar">
                            <i class="bi bi-person-circle"></i>
                        </div>
                        <h2>@Localizer["Welcome back"]</h2>
                        <p>@Localizer["Sign in to your workspace and pick up where you left off."]</p>
                    </div>

                    <form asp-action="Login" method="post" class="auth-form">
                        <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

                        <div class="auth-input-group">
                            <label asp-for="UserNameOrEmail" class="auth-label">@Localizer["Email or Username"]</label>
                            <div class="auth-input-wrap">
                                <i class="bi bi-person-circle"></i>
                                <input asp-for="UserNameOrEmail" class="form-control auth-input"
                                       placeholder="@Localizer["Email or username"]" autocomplete="username" />
                            </div>
                            <span asp-validation-for="UserNameOrEmail" class="text-danger small"></span>
                        </div>

                        <div class="auth-input-group">
                            <label asp-for="Password" class="auth-label">@Localizer["Password"]</label>
                            <div class="auth-input-wrap">
                                <i class="bi bi-shield-lock-fill"></i>
                                <input asp-for="Password" class="form-control auth-input"
                                       placeholder="@Localizer["Your password"]" autocomplete="current-password" />
                                <button type="button" class="auth-toggle-pw" id="togglePw" tabindex="-1">
                                    <i class="bi bi-eye" id="pwEyeIcon"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="auth-form-row">
                            <div class="form-check auth-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label" style="font-size:.88rem;color:#64748b;">@Localizer["Remember me"]</label>
                            </div>
                            <a asp-action="ForgotPassword" class="auth-link">@Localizer["Forgot password?"]</a>
                        </div>

                        <button type="submit" class="btn auth-submit-btn">
                            <i class="bi bi-box-arrow-in-right"></i>
                            <span>@Localizer["Sign In"]</span>
                        </button>
                    </form>

                    <div class="auth-card-footer">
                        <i class="bi bi-shield-check"></i>
                        @Localizer["Your data is protected and tenant-isolated."]
                    </div>
                </div>
            </div>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/login.js" asp-append-version="true"></script>
</body>
</html>
