@model ClothInventoryApp.Dtos.Account.LoginDto
@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Cloth Inventory</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-body-modern">
    <div class="auth-bg-shape auth-bg-shape-1"></div>
    <div class="auth-bg-shape auth-bg-shape-2"></div>

    <div class="auth-page">
        <div class="auth-layout">
            <div class="auth-showcase">
                <div class="auth-showcase-content">
                    <div class="auth-brand-modern">
                        <div class="auth-brand-logo">
                            <img src="~/images/default.jpeg" alt="Logo" />
                        </div>
                        <div>
                            <div class="auth-brand-title">Cloth Inventory</div>
                            <div class="auth-brand-subtitle">Smart business workspace</div>
                        </div>
                    </div>

                    <div class="auth-showcase-text">
                        <div class="auth-badge">
                            <i class="bi bi-stars"></i>
                            <span>Modern inventory platform</span>
                        </div>

                        <h1>Run your inventory, stock, and sales from one elegant dashboard.</h1>

                        <p>
                            Track product variants, manage stock movement, monitor low stock,
                            and keep your business organized with a cleaner workflow.
                        </p>
                    </div>

                    <div class="auth-feature-list">
                        <div class="auth-feature-item">
                            <div class="auth-feature-icon">
                                <i class="bi bi-box-seam-fill"></i>
                            </div>
                            <div>
                                <div class="auth-feature-title">Product & Variant Tracking</div>
                                <div class="auth-feature-text">Manage size, color, and SKU with clarity.</div>
                            </div>
                        </div>

                        <div class="auth-feature-item">
                            <div class="auth-feature-icon">
                                <i class="bi bi-arrow-left-right"></i>
                            </div>
                            <div>
                                <div class="auth-feature-title">Real-Time Stock Movement</div>
                                <div class="auth-feature-text">View stock in, stock out, and adjustments easily.</div>
                            </div>
                        </div>

                        <div class="auth-feature-item">
                            <div class="auth-feature-icon">
                                <i class="bi bi-bar-chart-fill"></i>
                            </div>
                            <div>
                                <div class="auth-feature-title">Business Insights</div>
                                <div class="auth-feature-text">Stay on top of trends, sales, and inventory health.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="auth-panel">
                <div class="auth-card-modern">
                    <div class="auth-card-header">
                        <h2>Sign in</h2>
                        <p>Enter your account details to continue.</p>
                    </div>

                    <form asp-action="Login" method="post" class="auth-form">
                        <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

                        <div class="auth-input-group">
                            <label asp-for="UserNameOrEmail" class="auth-label"></label>
                            <div class="auth-input-wrap">
                                <i class="bi bi-person-circle"></i>
                                <input asp-for="UserNameOrEmail" class="form-control auth-input" placeholder="Enter email or username" />
                            </div>
                            <span asp-validation-for="UserNameOrEmail" class="text-danger small"></span>
                        </div>

                        <div class="auth-input-group">
                            <label asp-for="Password" class="auth-label"></label>
                            <div class="auth-input-wrap">
                                <i class="bi bi-shield-lock-fill"></i>
                                <input asp-for="Password" class="form-control auth-input" placeholder="Enter password" />
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="auth-form-row">
                            <div class="form-check auth-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label"></label>
                            </div>

                            <a href="#" class="auth-link">Forgot password?</a>
                        </div>

                        <button type="submit" class="btn auth-submit-btn">
                            <i class="bi bi-box-arrow-in-right"></i>
                            <span>Sign In</span>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>