@using ClothInventoryApp.Resources
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject IStringLocalizer<SharedResource> Localizer
@model ClothInventoryApp.Dtos.Account.ResetPasswordDto
@{
    Layout = null;
    ViewData["Title"] = Localizer["Reset Password"];
}

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="~/images/websitelogo.png" asp-append-version="true" />
    <title>@Localizer["Reset Password"] - StockEasy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-body-modern @(CultureInfo.CurrentUICulture.Name.StartsWith("my") ? "culture-my" : "")">
    <div class="auth-bg-shape auth-bg-shape-1"></div>
    <div class="auth-bg-shape auth-bg-shape-2"></div>

    <div class="auth-page" style="justify-content:center; align-items:center;">
        <div class="auth-panel" style="max-width:480px; width:100%;">
            <div class="auth-card-modern">
                <div class="auth-card-header">
                    <div class="auth-card-avatar">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                    <h2>@Localizer["Set a new password"]</h2>
                    <p>@Localizer["Choose a new password for your account."]</p>
                </div>

                <form asp-action="ResetPassword" method="post" class="auth-form">
                    <div asp-validation-summary="ModelOnly" class="auth-validation"></div>
                    <input asp-for="Email" type="hidden" />
                    <input asp-for="Token" type="hidden" />

                    <div class="auth-input-group">
                        <label asp-for="NewPassword" class="auth-label"></label>
                        <div class="auth-input-wrap">
                            <i class="bi bi-key-fill"></i>
                            <input asp-for="NewPassword" class="form-control auth-input" autocomplete="new-password" />
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="auth-input-group">
                        <label asp-for="ConfirmPassword" class="auth-label"></label>
                        <div class="auth-input-wrap">
                            <i class="bi bi-key-fill"></i>
                            <input asp-for="ConfirmPassword" class="form-control auth-input" autocomplete="new-password" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn auth-submit-btn">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>@Localizer["Reset Password"]</span>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>
