@using ClothInventoryApp.Resources
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject IStringLocalizer<SharedResource> Localizer
@{
    Layout = null;
    ViewData["Title"] = Localizer["Password Updated"];
}

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="~/images/websitelogo.png" asp-append-version="true" />
    <title>@Localizer["Password Updated"] - StockEasy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-body-modern @(CultureInfo.CurrentUICulture.Name.StartsWith("my") ? "culture-my" : "")">
    <div class="auth-bg-shape auth-bg-shape-1"></div>
    <div class="auth-bg-shape auth-bg-shape-2"></div>

    <div class="auth-page" style="justify-content:center; align-items:center;">
        <div class="auth-panel" style="max-width:480px; width:100%;">
            <div class="auth-card-modern text-center">
                <div class="auth-card-header">
                    <div class="auth-card-avatar" style="background:linear-gradient(135deg,#d1fae5,#a7f3d0);">
                        <i class="bi bi-check-circle-fill" style="color:#059669; font-size:2rem;"></i>
                    </div>
                    <h2>@Localizer["Password reset complete"]</h2>
                    <p>@Localizer["You can now sign in with your new password."]</p>
                </div>

                <div class="auth-form" style="padding-top:0;">
                    <a asp-action="Login" class="btn auth-submit-btn">
                        <i class="bi bi-box-arrow-in-right"></i>
                        <span>@Localizer["Back to Sign In"]</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
