@{
    Layout = null;
    var feature = (string)(ViewBag.Feature ?? "");
    var (icon, label, requiredPlan) = feature switch
    {
        "sales"    => ("bi-bag-check-fill",  "Sales",             "Starter"),
        "finance"  => ("bi-cash-coin",       "Finance Dashboard", "Pro"),
        "textiles" => ("bi-tags-fill",       "Textile Tracking",  "Pro"),
        _          => ("bi-lock-fill",       "This feature",      "a higher plan")
    };
    ViewData["Title"] = "Upgrade Required";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Upgrade Required — StockEasy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-body-modern">

    <div class="auth-bg-shape auth-bg-shape-1"></div>
    <div class="auth-bg-shape auth-bg-shape-2"></div>

    <div class="auth-page" style="justify-content:center;align-items:center;">
        <div class="auth-panel" style="max-width:520px;width:100%;">
            <div class="auth-card-modern" style="text-align:center;">

                <div style="margin-bottom:1.5rem;">
                    <div style="
                        width:72px;height:72px;border-radius:20px;
                        background:linear-gradient(135deg,#6366f1,#8b5cf6);
                        display:inline-flex;align-items:center;justify-content:center;
                        font-size:1.8rem;color:#fff;margin-bottom:1.2rem;">
                        <i class="bi @icon"></i>
                    </div>
                    <h2 style="font-size:1.4rem;font-weight:700;color:#f1f5f9;margin-bottom:.5rem;">
                        @label requires <span style="color:#818cf8;">@requiredPlan</span>
                    </h2>
                    <p style="color:#94a3b8;font-size:.93rem;line-height:1.6;margin-bottom:1.8rem;">
                        Your current plan does not include access to <strong style="color:#e2e8f0;">@label</strong>.
                        Upgrade to the <strong style="color:#e2e8f0;">@requiredPlan</strong> plan to unlock this feature
                        and many others.
                    </p>
                </div>

                <!-- Plan comparison strip -->
                <div style="
                    display:grid;grid-template-columns:1fr 1fr 1fr;gap:.75rem;
                    margin-bottom:1.8rem;">

                    <div style="background:rgba(255,255,255,.05);border-radius:14px;padding:1rem .75rem;border:1px solid rgba(255,255,255,.08);">
                        <div style="font-weight:700;color:#f1f5f9;font-size:.9rem;margin-bottom:.3rem;">Starter</div>
                        <div style="color:#818cf8;font-weight:700;font-size:1.1rem;margin-bottom:.5rem;">$9<span style="font-size:.75rem;color:#64748b;">/mo</span></div>
                        <div style="font-size:.78rem;color:#94a3b8;line-height:1.5;">Products<br>Stock<br><strong style="color:#e2e8f0;">Sales</strong></div>
                    </div>

                    <div style="background:rgba(99,102,241,.12);border-radius:14px;padding:1rem .75rem;border:2px solid #6366f1;">
                        <div style="font-weight:700;color:#f1f5f9;font-size:.9rem;margin-bottom:.3rem;">Pro ✦</div>
                        <div style="color:#818cf8;font-weight:700;font-size:1.1rem;margin-bottom:.5rem;">$25<span style="font-size:.75rem;color:#64748b;">/mo</span></div>
                        <div style="font-size:.78rem;color:#94a3b8;line-height:1.5;">Everything<br><strong style="color:#e2e8f0;">Finance</strong><br><strong style="color:#e2e8f0;">Textiles</strong></div>
                    </div>

                    <div style="background:rgba(255,255,255,.05);border-radius:14px;padding:1rem .75rem;border:1px solid rgba(255,255,255,.08);">
                        <div style="font-weight:700;color:#f1f5f9;font-size:.9rem;margin-bottom:.3rem;">Enterprise</div>
                        <div style="color:#818cf8;font-weight:700;font-size:1.1rem;margin-bottom:.5rem;">$79<span style="font-size:.75rem;color:#64748b;">/mo</span></div>
                        <div style="font-size:.78rem;color:#94a3b8;line-height:1.5;">Unlimited<br>users &amp;<br>products</div>
                    </div>
                </div>

                <p style="font-size:.85rem;color:#64748b;margin-bottom:1.5rem;">
                    Contact your system administrator or
                    <a href="/#contact" style="color:#818cf8;">reach out to us</a>
                    to upgrade your plan.
                </p>

                <a asp-controller="Home" asp-action="Index"
                   style="display:inline-flex;align-items:center;gap:.5rem;
                          padding:.7rem 1.4rem;border-radius:12px;
                          background:rgba(255,255,255,.08);color:#e2e8f0;
                          text-decoration:none;font-weight:500;font-size:.9rem;
                          border:1px solid rgba(255,255,255,.12);">
                    <i class="bi bi-arrow-left"></i> Back to Dashboard
                </a>

            </div>
        </div>
    </div>
</body>
</html>
