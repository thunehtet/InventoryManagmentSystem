@{
    Layout = null;
    var feature = (string)(ViewBag.Feature ?? "");
    var (icon, label, requiredPlan) = feature switch
    {
        "sales"    => ("bi-bag-check-fill", "Sales", "Starter"),
        "finance"  => ("bi-cash-coin", "Finance Dashboard", "Pro"),
        "textiles" => ("bi-tags-fill", "Purchases", "Pro"),
        _          => ("bi-lock-fill", "This feature", "a higher plan")
    };
    ViewData["Title"] = Localizer["Upgrade Required"];
}
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="~/images/websitelogo.png" asp-append-version="true" />
    <title>@Localizer["Upgrade Required"] - StockEasy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-body-modern">

    <div class="auth-bg-shape auth-bg-shape-1"></div>
    <div class="auth-bg-shape auth-bg-shape-2"></div>

    <div class="auth-page auth-page-centered">
        <div class="auth-panel auth-panel-feature-required">
            <div class="auth-card-modern auth-card-centered">

                <div class="feature-required-header">
                    <div class="feature-required-icon">
                        <i class="bi @icon"></i>
                    </div>
                    <h2 class="feature-required-title">
                        @Localizer["{0} requires {1}", Localizer[label].Value, requiredPlan]
                    </h2>
                    <p class="feature-required-copy">
                        @Localizer["Your current plan does not include access to {0}.", Localizer[label].Value]
                        @Localizer["Upgrade to the {0} plan to unlock this feature and many others.", requiredPlan]
                    </p>
                </div>

                <div class="feature-required-plan-grid">
                    <div class="feature-required-plan-card">
                        <div class="feature-required-plan-name">Starter</div>
                        <div class="feature-required-plan-price">$9<span class="feature-required-plan-period">/mo</span></div>
                        <div class="feature-required-plan-copy">
                            @Localizer["Products"]<br />@Localizer["Stock"]<br /><strong class="feature-required-strong">@Localizer["Sales"]</strong>
                        </div>
                    </div>

                    <div class="feature-required-plan-card feature-required-plan-card-featured">
                        <div class="feature-required-plan-name">Pro</div>
                        <div class="feature-required-plan-price">$25<span class="feature-required-plan-period">/mo</span></div>
                        <div class="feature-required-plan-copy">
                            @Localizer["Everything"]<br /><strong class="feature-required-strong">@Localizer["Finance"]</strong><br /><strong class="feature-required-strong">@Localizer["Purchases"]</strong>
                        </div>
                    </div>

                    <div class="feature-required-plan-card">
                        <div class="feature-required-plan-name">Enterprise</div>
                        <div class="feature-required-plan-price">$79<span class="feature-required-plan-period">/mo</span></div>
                        <div class="feature-required-plan-copy">
                            @Localizer["Unlimited"]<br />@Localizer["Users"] &amp;<br />@Localizer["Products"]
                        </div>
                    </div>
                </div>

                <p class="feature-required-note">
                    @Localizer["Contact your system administrator or"]
                    <a href="/#contact" class="feature-required-note-link">@Localizer["reach out to us"]</a>
                    @Localizer["to upgrade your plan."]
                </p>

                <a asp-controller="Home" asp-action="Index" class="feature-required-back-link">
                    <i class="bi bi-arrow-left"></i> @Localizer["Back to Dashboard"]
                </a>

            </div>
        </div>
    </div>
</body>
</html>
