@using ClothInventoryApp.Resources
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Access Denied"];
    Layout = null;
}
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="~/images/websitelogo.png" asp-append-version="true" />
    <title>@Localizer["Access Denied"] - StockEasy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body class="auth-body-modern @(CultureInfo.CurrentUICulture.Name.StartsWith("my") ? "culture-my" : "")">

    <div class="auth-bg-shape auth-bg-shape-1"></div>
    <div class="auth-bg-shape auth-bg-shape-2"></div>

    <div class="auth-page auth-page-centered">
        <div class="auth-panel auth-panel-compact">
            <div class="auth-card-modern">
                <div class="auth-card-header">
                    <div class="auth-card-avatar auth-card-avatar-danger">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                    <h2>@Localizer["Access Denied"]</h2>
                    <p>@Localizer["You don't have permission to access this page. Contact your administrator if you think this is a mistake."]</p>
                </div>

                <div class="d-flex flex-column gap-3 mt-2">
                    <a href="/Home/Index" class="auth-submit-btn auth-submit-link">
                        <i class="bi bi-house-fill"></i> @Localizer["Back to Home"]
                    </a>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="auth-submit-btn auth-submit-btn-secondary">
                            <i class="bi bi-box-arrow-right"></i> @Localizer["Sign in as a different user"]
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
