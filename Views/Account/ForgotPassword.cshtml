@using ClothInventoryApp.Resources
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject IStringLocalizer<SharedResource> Localizer
@model ClothInventoryApp.Dtos.Account.ForgotPasswordDto
@{
    Layout = null;
    ViewData["Title"] = Localizer["Forgot Password"];
}

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="~/images/websitelogo.png" asp-append-version="true" />
    <title>@Localizer["Forgot Password"] - StockEasy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body class="auth-body-modern @(CultureInfo.CurrentUICulture.Name.StartsWith("my") ? "culture-my" : "")">

    <div class="auth-bg-shape auth-bg-shape-1"></div>
    <div class="auth-bg-shape auth-bg-shape-2"></div>

    <div class="auth-page auth-page-centered">
        <div class="auth-panel auth-panel-narrow">
            <div class="auth-card-modern">
                <div class="auth-card-header">
                    <div class="auth-card-avatar">
                        <i class="bi bi-question-circle-fill auth-icon-violet"></i>
                    </div>
                    <h2>@Localizer["Forgot Password?"]</h2>
                    <p>@Localizer["Enter your email and your administrator will help reset it."]</p>
                </div>

                <form asp-action="ForgotPassword" method="post" class="auth-form">
                    <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

                    <div class="auth-input-group">
                        <label asp-for="Email" class="auth-label"></label>
                        <div class="auth-input-wrap">
                            <i class="bi bi-envelope-fill"></i>
                            <input asp-for="Email" class="form-control auth-input"
                                   placeholder="@Localizer["Your email address"]" autocomplete="email" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn auth-submit-btn">
                        <i class="bi bi-send-fill"></i>
                        <span>@Localizer["Submit Request"]</span>
                    </button>

                    <div class="text-center mt-3">
                        <a asp-action="Login" class="auth-link">
                            <i class="bi bi-arrow-left"></i> @Localizer["Back to sign in"]
                        </a>
                    </div>
                </form>

                <div class="auth-card-footer">
                    <i class="bi bi-shield-check"></i>
                    @Localizer["Your data is protected and tenant-isolated."]
                </div>
            </div>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>
