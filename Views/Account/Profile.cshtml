@model ClothInventoryApp.Dtos.Account.ProfileSettingsDto
@{
    ViewData["Title"] = Localizer["Profile"];
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/create-product.css" asp-append-version="true" />
}

<div class="create-product-shell">
    <div class="create-product-hero">
        <div class="create-product-hero-content">
            <div class="hero-kicker">
                <i class="bi bi-person-badge-fill"></i>
                <span>Profile</span>
            </div>
            <h1>Profile Settings</h1>
            <p>Manage your profile photo, brand logo, and your sign-in identity.</p>
        </div>
    </div>

    <div class="create-product-grid">
        <div class="create-main-card">
            <div class="section-header">
                <div>
                    <h3>Account Details</h3>
                    <p>Username and email can only be changed once.</p>
                </div>
            </div>

            <form asp-action="Profile" method="post" enctype="multipart/form-data" class="modern-product-form">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="validation-summary-modern"></div>

                <div class="product-table-card mb-4">
                    <div class="row g-4">
                        <div class="col-12 col-lg-6">
                            <div class="fw-semibold mb-2">Profile Photo</div>
                            @if (!string.IsNullOrWhiteSpace(Model.CurrentProfileImageUrl))
                            {
                                <img src="@Model.CurrentProfileImageUrl" alt="Profile Photo" class="profile-media-preview" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center text-muted profile-media-placeholder">
                                    <i class="bi bi-person-circle fs-1"></i>
                                </div>
                            }
                            <div class="mt-3">
                                <input asp-for="ProfileImage" class="input-modern" type="file" accept=".jpg,.jpeg,.png,image/jpeg,image/png" />
                                <span asp-validation-for="ProfileImage" class="text-danger small"></span>
                            </div>
                        </div>

                        @if (Model.IsTenantAdmin)
                        {
                            <div class="col-12 col-lg-6">
                                <div class="fw-semibold mb-2">Brand Logo</div>
                                @if (!string.IsNullOrWhiteSpace(Model.CurrentBrandLogoUrl))
                                {
                                    <img src="@Model.CurrentBrandLogoUrl" alt="@Model.TenantName" class="profile-media-preview" />
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center text-muted profile-media-placeholder">
                                        <i class="bi bi-building fs-1"></i>
                                    </div>
                                }
                                <div class="mt-3">
                                    <input asp-for="BrandLogoImage" class="input-modern" type="file" accept=".jpg,.jpeg,.png,image/jpeg,image/png" />
                                    <span asp-validation-for="BrandLogoImage" class="text-danger small"></span>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="form-grid-modern">
                    <div class="form-group-modern">
                        <label asp-for="FullName" class="form-label-modern"></label>
                        <input asp-for="FullName" class="input-modern" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="UserName" class="form-label-modern"></label>
                        @if (Model.CanChangeLoginIdentity)
                        {
                            <input asp-for="UserName" class="input-modern" />
                        }
                        else
                        {
                            <input asp-for="UserName" class="input-modern" readonly />
                        }
                        <span asp-validation-for="UserName" class="text-danger small"></span>
                    </div>

                    <div class="form-group-modern">
                        <label asp-for="Email" class="form-label-modern"></label>
                        @if (Model.CanChangeLoginIdentity)
                        {
                            <input asp-for="Email" class="input-modern" />
                        }
                        else
                        {
                            <input asp-for="Email" class="input-modern" readonly />
                        }
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="form-group-modern">
                        <label class="form-label-modern">Identity Change Rule</label>
                        <input class="input-modern" readonly value="@(Model.CanChangeLoginIdentity ? "You can still change username/email once." : $"Already used on {Model.LoginIdentityChangedAt:yyyy-MM-dd HH:mm}")" />
                    </div>

                </div>

                <div class="form-footer-modern">
                    <button type="submit" class="btn-modern-primary btn-modern-lg">
                        <i class="bi bi-save-fill"></i>
                        Save Profile
                    </button>
                    <a asp-controller="Home" asp-action="Index" class="btn-modern-outline btn-modern-lg">@Localizer["Back"]</a>
                </div>
            </form>
        </div>

        <div class="create-main-card mt-4">
            <div class="section-header">
                <div>
                    <h3>Telegram Notifications</h3>
                    <p>Receive low stock alerts and subscription updates on Telegram.</p>
                </div>
            </div>

            @if (Model.IsTelegramConnected)
            {
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <span class="badge bg-success fs-6 px-3 py-2">
                        <i class="bi bi-telegram me-1"></i> Connected
                    </span>
                    <form asp-action="DisconnectTelegram" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-x-circle me-1"></i> Disconnect
                        </button>
                    </form>
                </div>
                <div class="text-muted small mt-2">You will receive low stock and subscription notifications on Telegram.</div>
            }
            else
            {
                @if (TempData["TelegramDeepLink"] is string deepLink)
                {
                    <div class="alert alert-info py-2 px-3 mb-3">
                        <strong>Step:</strong> Click the button below, then tap <strong>START</strong> in Telegram.
                        This link expires in 15 minutes.
                    </div>
                    <a href="@deepLink" target="_blank" class="btn-modern-primary btn-modern-lg d-inline-flex align-items-center gap-2">
                        <i class="bi bi-telegram"></i> Open Bot &amp; Connect
                    </a>
                }
                else
                {
                    <form asp-action="GenerateTelegramLink" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-modern-outline btn-modern-lg d-inline-flex align-items-center gap-2">
                            <i class="bi bi-telegram"></i> Connect Telegram
                        </button>
                    </form>
                    <div class="text-muted small mt-2">Connect once to receive stock and subscription alerts via Telegram.</div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
