@using ClothInventoryApp.Resources
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject IStringLocalizer<SharedResource> Localizer
@model ClothInventoryApp.Dtos.Account.ChangePasswordDto
@{
    Layout = null;
    ViewData["Title"] = Localizer["Change Password"];
}

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="~/images/websitelogo.png" asp-append-version="true" />
    <title>@Localizer["Change Password"] - StockEasy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body class="auth-body-modern @(CultureInfo.CurrentUICulture.Name.StartsWith("my") ? "culture-my" : "")">

    <div class="auth-bg-shape auth-bg-shape-1"></div>
    <div class="auth-bg-shape auth-bg-shape-2"></div>

    <div class="auth-page" style="justify-content:center; align-items:center;">
        <div class="auth-panel" style="max-width:480px; width:100%;">
            <div class="auth-card-modern">
                <div class="auth-card-header">
                    <div class="auth-card-avatar">
                        <i class="bi bi-key-fill" style="color:#7c3aed;"></i>
                    </div>
                    <h2>@Localizer["Change Password"]</h2>
                    @if (TempData["ForcedChange"] != null)
                    {
                        <div class="auth-validation" style="background:rgba(251,191,36,.12);border-color:#fbbf24;color:#fbbf24;margin-bottom:.5rem;">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i>
                            @Localizer["Your account uses a temporary password. Please set a new password to continue."]
                        </div>
                    }
                    <p>@Localizer["Enter your current password and choose a new one."]</p>
                </div>

                <form asp-action="ChangePassword" method="post" class="auth-form">
                    <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

                    <div class="auth-input-group">
                        <label asp-for="CurrentPassword" class="auth-label"></label>
                        <div class="auth-input-wrap">
                            <i class="bi bi-shield-lock-fill"></i>
                            <input asp-for="CurrentPassword" class="form-control auth-input"
                                   placeholder="@Localizer["Current password"]" autocomplete="current-password" />
                        </div>
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>

                    <div class="auth-input-group">
                        <label asp-for="NewPassword" class="auth-label"></label>
                        <div class="auth-input-wrap">
                            <i class="bi bi-lock-fill"></i>
                            <input asp-for="NewPassword" class="form-control auth-input"
                                   placeholder="@Localizer["New password (min 8 chars)"]" autocomplete="new-password" />
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="auth-input-group">
                        <label asp-for="ConfirmNewPassword" class="auth-label"></label>
                        <div class="auth-input-wrap">
                            <i class="bi bi-lock-fill"></i>
                            <input asp-for="ConfirmNewPassword" class="form-control auth-input"
                                   placeholder="@Localizer["Confirm new password"]" autocomplete="new-password" />
                        </div>
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn auth-submit-btn">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>@Localizer["Update Password"]</span>
                    </button>

                    @if (TempData["ForcedChange"] == null)
                    {
                        <div class="text-center mt-3">
                            <a asp-controller="Home" asp-action="Index" class="auth-link">
                                <i class="bi bi-arrow-left"></i> @Localizer["Back to dashboard"]
                            </a>
                        </div>
                    }
                </form>

                <div class="auth-card-footer">
                    <i class="bi bi-shield-check"></i>
                    @Localizer["Your data is protected and tenant-isolated."]
                </div>
            </div>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>
