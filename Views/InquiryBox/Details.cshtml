@model ClothInventoryApp.Models.ContactInquiry
@{
    ViewData["Title"] = "Inquiry Details";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/create-product.css" asp-append-version="true" />
}

<div class="create-product-shell">
    <div class="create-main-card">
        <div class="section-header">
            <div>
                <h3>Inquiry Details</h3>
                <p>@Model.BusinessName requested a free account.</p>
            </div>
            <a asp-action="Index" class="btn-modern-outline">Back to Inbox</a>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <div class="form-grid-modern mb-4">
            <div class="form-group-modern">
                <label class="form-label-modern">Contact Name</label>
                <input class="input-modern" value="@Model.Name" readonly />
            </div>
            <div class="form-group-modern">
                <label class="form-label-modern">Email</label>
                <input class="input-modern" value="@Model.Email" readonly />
            </div>
            <div class="form-group-modern">
                <label class="form-label-modern">Phone</label>
                <input class="input-modern" value="@(Model.Phone ?? "-")" readonly />
            </div>
            <div class="form-group-modern">
                <label class="form-label-modern">Business Name</label>
                <input class="input-modern" value="@Model.BusinessName" readonly />
            </div>
            <div class="form-group-modern">
                <label class="form-label-modern">Business Type</label>
                <input class="input-modern" value="@Model.BusinessType" readonly />
            </div>
            <div class="form-group-modern">
                <label class="form-label-modern">Status</label>
                <input class="input-modern" value="@Model.Status" readonly />
            </div>
            <div class="form-group-modern">
                <label class="form-label-modern">Submitted</label>
                    <input class="input-modern" value="@Html.TenantDate(Model.SubmittedAt, "dd MMM yyyy HH:mm")" readonly />
            </div>
            <div class="form-group-modern">
                <label class="form-label-modern">Approved Tenant</label>
                <input class="input-modern" value="@(Model.ApprovedTenant?.Name ?? "-")" readonly />
            </div>
        </div>

        <div class="product-table-card mb-4">
            <h4 class="mb-3">Inquiry Notes</h4>
            <div class="text-muted" style="white-space:pre-wrap;line-height:1.7;">
                @(string.IsNullOrWhiteSpace(Model.Message) ? "-" : Model.Message)
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ReviewRemarks))
        {
            <div class="alert alert-secondary mb-4">
                <strong>Review Note:</strong> @Model.ReviewRemarks
                @if (Model.ReviewedAt.HasValue)
                {
                            <span class="text-muted">(@Html.TenantDate(Model.ReviewedAt, "dd MMM yyyy HH:mm"))</span>
                }
            </div>
        }

        @if (Model.Status == "Pending")
        {
            <div class="row g-4">
                <div class="col-12 col-lg-6">
                    <form asp-action="Approve" method="post" class="product-table-card h-100">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <h4 class="mb-3">Approve</h4>
                        <p class="text-muted">This will create the tenant, tenant admin, and activate the free plan.</p>
                        <button type="submit" class="btn-modern-primary">
                            <i class="bi bi-check-circle-fill"></i> Approve and Create Free Account
                        </button>
                    </form>
                </div>
                <div class="col-12 col-lg-6">
                    <form asp-action="Reject" method="post" class="product-table-card h-100">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <h4 class="mb-3">Reject</h4>
                        <textarea name="remarks" class="form-control mb-3" rows="4" placeholder="Reason for rejection..."></textarea>
                        <button type="submit" class="btn-modern-danger">
                            <i class="bi bi-x-circle-fill"></i> Reject Inquiry
                        </button>
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="d-flex flex-wrap gap-2">
                <a asp-action="Index" class="btn-modern-outline">@Localizer["Back"]</a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Delete this inquiry permanently?');" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-modern-danger">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </form>
            </div>
        }
    </div>
</div>
