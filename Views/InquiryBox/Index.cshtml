@model IEnumerable<ClothInventoryApp.Models.ContactInquiry>
@{
    ViewData["Title"] = "Inquiry Box";
    var filter = (string)(ViewBag.Filter ?? "all");
    int unread = (int)(ViewBag.UnreadCount ?? 0);
    int pending = (int)(ViewBag.PendingCount ?? 0);
    int approved = (int)(ViewBag.ApprovedCount ?? 0);
    int rejected = (int)(ViewBag.RejectedCount ?? 0);
    var ibpg = ViewBag.Pagination as ClothInventoryApp.Models.PaginationViewModel;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/superadmin.css" asp-append-version="true" />
}

<div class="superadmin-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <h1 class="product-hero-title">
                <i class="bi bi-envelope-fill"></i> Inquiry Box
                @if (unread > 0)
                {
                    <span class="ib-unread-badge">@unread new</span>
                }
            </h1>
            <p class="product-hero-sub">Review free-account inquiries before creating tenant accounts.</p>
        </div>
        <a asp-controller="SuperAdmin" asp-action="Index" class="sa-btn-back">
            <i class="bi bi-arrow-left"></i> Dashboard
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="ib-filter-tabs">
        <a asp-action="Index" asp-route-filter="all" asp-route-size="@(ibpg?.PageSize ?? 10)"
           class="ib-tab @(filter == "all" ? "active" : "")">
            All <span class="ib-tab-count">@(ibpg?.TotalCount ?? Model.Count())</span>
        </a>
        <a asp-action="Index" asp-route-filter="pending" asp-route-size="@(ibpg?.PageSize ?? 10)"
           class="ib-tab @(filter == "pending" ? "active" : "")">
            Pending <span class="ib-tab-count">@pending</span>
        </a>
        <a asp-action="Index" asp-route-filter="approved" asp-route-size="@(ibpg?.PageSize ?? 10)"
           class="ib-tab @(filter == "approved" ? "active" : "")">
            Approved <span class="ib-tab-count">@approved</span>
        </a>
        <a asp-action="Index" asp-route-filter="rejected" asp-route-size="@(ibpg?.PageSize ?? 10)"
           class="ib-tab @(filter == "rejected" ? "active" : "")">
            Rejected <span class="ib-tab-count">@rejected</span>
        </a>
        <a asp-action="Index" asp-route-filter="unread" asp-route-size="@(ibpg?.PageSize ?? 10)"
           class="ib-tab @(filter == "unread" ? "active" : "")">
            Unread <span class="ib-tab-count">@unread</span>
        </a>
    </div>

    <div class="product-table-card">
        @if (!Model.Any())
        {
            <div class="ib-empty">
                <i class="bi bi-inbox"></i>
                <span>No inquiries yet</span>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="superadmin-table">
                    <thead>
                        <tr>
                            <th style="width:60px;"></th>
                            <th>Contact</th>
                            <th>Business</th>
                            <th>Status</th>
                            <th>Received</th>
                            <th style="width:100px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="@(!item.IsRead ? "ib-row-unread" : "")">
                                <td>
                                    @if (!item.IsRead)
                                    {
                                        <span class="ib-new-dot"></span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-check2 text-muted"></i>
                                    }
                                </td>
                                <td>
                                    <div class="fw-semibold text-dark">@item.Name</div>
                                    <div class="text-muted small">@item.Email</div>
                                    <div class="text-muted small">@(item.Phone ?? "-")</div>
                                </td>
                                <td>
                                    <div class="fw-semibold text-dark">@item.BusinessName</div>
                                    <div class="text-muted small">@item.BusinessType</div>
                                </td>
                                <td>
                                    <span class="status-badge @(item.Status == "Approved" ? "active" : item.Status == "Rejected" ? "inactive" : "trial")">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="text-muted small" style="white-space:nowrap;">
                                    @item.SubmittedAt.ToString("dd MMM yyyy HH:mm")
                                </td>
                                <td>
                                    <div class="table-actions">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="action-btn action-btn-view" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                              onsubmit="return confirm('Delete this inquiry?');" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="action-btn action-btn-delete" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (ibpg != null) { @await Html.PartialAsync("_Pagination", ibpg) }
        }
    </div>
</div>
