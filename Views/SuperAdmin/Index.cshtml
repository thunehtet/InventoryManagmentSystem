@model ClothInventoryApp.Dto.SuperAdmin.SuperAdminDashboardDto
@{
    ViewData["Title"] = Localizer["System Dashboard"];
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/superadmin.css" asp-append-version="true" />
}

<div class="superadmin-shell">
    <div class="superadmin-hero">
        <div class="superadmin-hero-content">
            <div class="superadmin-badge">
                <i class="bi bi-shield-lock-fill"></i>
                @Localizer["Super Admin"]
            </div>
            <h1 class="superadmin-title">@Localizer["System Dashboard"]</h1>
            <p class="superadmin-subtitle">
                @Localizer["Platform-wide overview of tenants, user activity, and operational usage."]
            </p>
            <div class="dashboard-hero-actions">
                <a asp-controller="Tenant" asp-action="Index" class="btn-dashboard-secondary">
                    <i class="bi bi-building"></i> @Localizer["View All Tenants"]
                </a>
                <a asp-controller="InquiryBox" asp-action="Index" class="btn-dashboard-secondary">
                    <i class="bi bi-envelope-fill"></i> @Localizer["View All Inquiries"]
                </a>
            </div>
        </div>

        <div class="superadmin-hero-side">
            <div class="superadmin-hero-side-card">
                <div class="hero-summary-top">
                    <span class="summary-label">@Localizer["Platform Snapshot"]</span>
                    <i class="bi bi-activity"></i>
                </div>
                <div class="superadmin-mini-metrics">
                    <div class="superadmin-mini-metric">
                        <span class="superadmin-mini-label">@Localizer["Active Tenants"]</span>
                        <span class="superadmin-mini-value">@Model.ActiveTenants</span>
                    </div>
                    <div class="superadmin-mini-metric">
                        <span class="superadmin-mini-label">@Localizer["Active in 30 Days"]</span>
                        <span class="superadmin-mini-value">@Model.ActiveTenants30Days</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="superadmin-stats-grid">
        <div class="superadmin-stat-card">
            <div class="superadmin-stat-icon red">
                <i class="bi bi-building"></i>
            </div>
            <div>
                <div class="superadmin-stat-label">@Localizer["Total Tenants"]</div>
                <div class="superadmin-stat-value">@Model.TotalTenants</div>
                <div class="superadmin-stat-note">@Model.ActiveTenants @Localizer["active"]</div>
            </div>
        </div>
        <div class="superadmin-stat-card">
            <div class="superadmin-stat-icon blue">
                <i class="bi bi-person-check-fill"></i>
            </div>
            <div>
                <div class="superadmin-stat-label">@Localizer["Today's Logins"]</div>
                <div class="superadmin-stat-value">@Model.TodayLoginCount</div>
                <div class="superadmin-stat-note">@Localizer["Successful tenant logins"]</div>
            </div>
        </div>
        <div class="superadmin-stat-card">
            <div class="superadmin-stat-icon green">
                <i class="bi bi-lightning-charge-fill"></i>
            </div>
            <div>
                <div class="superadmin-stat-label">@Localizer["Today's Actions"]</div>
                <div class="superadmin-stat-value">@Model.TodayActionCount</div>
                <div class="superadmin-stat-note">@Localizer["Tracked business actions"]</div>
            </div>
        </div>
        <div class="superadmin-stat-card">
            <div class="superadmin-stat-icon orange">
                <i class="bi bi-moon-stars-fill"></i>
            </div>
            <div>
                <div class="superadmin-stat-label">@Localizer["Dormant Tenants"]</div>
                <div class="superadmin-stat-value">@Model.DormantTenants</div>
                <div class="superadmin-stat-note">@Localizer["No activity for 7+ days"]</div>
            </div>
        </div>
    </div>

    <div class="superadmin-grid">
        <div class="superadmin-panel">
            <div class="superadmin-panel-header-with-action">
                <div class="superadmin-panel-header superadmin-hero-header-tight">
                    <h3>@Localizer["Top Tenant Usage"]</h3>
                    <p>@Localizer["Most active workspaces over the last 30 days"]</p>
                </div>
                <a asp-controller="Tenant" asp-action="Index" class="superadmin-panel-link">
                    @Localizer["View all"] <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div class="usage-card-grid">
                @foreach (var item in Model.TopTenantUsage)
                {
                    <a asp-action="TenantUsage" asp-route-id="@item.TenantId" class="usage-card">
                        <div class="usage-card-head">
                            <div>
                                <div class="usage-card-title">@item.TenantName</div>
                                <div class="usage-card-code">@item.TenantCode</div>
                            </div>
                            <i class="bi bi-arrow-up-right"></i>
                        </div>
                        <div class="usage-card-metrics">
                            <div>
                                <span class="usage-card-label">@Localizer["Actions"]</span>
                                <strong>@item.TotalActions</strong>
                            </div>
                            <div>
                                <span class="usage-card-label">@Localizer["Logins"]</span>
                                <strong>@item.LoginCount</strong>
                            </div>
                            <div>
                                <span class="usage-card-label">@Localizer["Active Users"]</span>
                                <strong>@item.ActiveUsers</strong>
                            </div>
                        </div>
                        <div class="usage-card-footer">
                            @Localizer["Last activity"]: @(item.LastActivityAt.HasValue ? Html.TenantDate(item.LastActivityAt, "dd MMM yyyy HH:mm") : Localizer["Never"].Value)
                        </div>
                    </a>
                }
                @if (!Model.TopTenantUsage.Any())
                {
                    <div class="usage-empty">@Localizer["No usage data yet."]</div>
                }
            </div>
        </div>

        <div class="superadmin-panel">
            <div class="superadmin-panel-header">
                <h3>@Localizer["Plan Distribution"]</h3>
                <p>@Localizer["Active subscriptions by plan"]</p>
            </div>

            @if (Model.PlanDistribution.Any())
            {
                var maxCount = Model.PlanDistribution.Max(p => p.Count);
                <div class="plan-dist-list">
                    @foreach (var p in Model.PlanDistribution)
                    {
                        var pct = maxCount > 0 ? (double)p.Count / maxCount * 100 : 0;
                        <div class="plan-dist-row">
                            <span class="plan-dist-name">@p.PlanName</span>
                            <div class="plan-dist-bar-wrap">
                                <progress class="plan-dist-bar" max="100" value="@pct.ToString("F0")">@pct.ToString("F0")%</progress>
                            </div>
                            <span class="plan-dist-count">@p.Count</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted small">@Localizer["No active subscriptions."]</p>
            }
        </div>
    </div>

    <div class="superadmin-grid">
        <div class="superadmin-panel">
            <div class="superadmin-panel-header-with-action">
                <div class="superadmin-panel-header superadmin-hero-header-tight">
                    <h3>@Localizer["Recent Activity"]</h3>
                    <p>@Localizer["Latest tracked actions from tenant users"]</p>
                </div>
            </div>

            <div class="usage-activity-list">
                @foreach (var item in Model.RecentActivities)
                {
                    <div class="usage-activity-item">
                        <div class="usage-activity-icon">
                            <i class="bi bi-activity"></i>
                        </div>
                        <div class="usage-activity-content">
                            <div class="usage-activity-title">@(item.Description ?? $"{item.Feature} / {item.Action}")</div>
                            <div class="usage-activity-meta">
                                <span>@(item.UserName ?? Localizer["Unknown User"].Value)</span>
                                <span>@(item.TenantName ?? Localizer["System"].Value)</span>
                                <span>@Html.TenantDate(item.CreatedAt, "dd MMM yyyy HH:mm")</span>
                            </div>
                        </div>
                    </div>
                }
                @if (!Model.RecentActivities.Any())
                {
                    <div class="usage-empty">@Localizer["No activity recorded yet."]</div>
                }
            </div>
        </div>

        <div class="superadmin-panel">
            <div class="superadmin-panel-header">
                <h3>@Localizer["Dormant Tenants"]</h3>
                <p>@Localizer["Active tenants with no recent usage"]</p>
            </div>

            <div class="usage-dormant-list">
                @foreach (var item in Model.DormantTenantList)
                {
                    <a asp-action="TenantUsage" asp-route-id="@item.TenantId" class="usage-dormant-item">
                        <div>
                            <div class="usage-dormant-title">@item.TenantName</div>
                            <div class="usage-dormant-sub">@item.TenantCode</div>
                        </div>
                        <div class="usage-dormant-time">
                            @(item.LastActivityAt.HasValue ? Html.TenantDate(item.LastActivityAt, "dd MMM yyyy") : Localizer["Never"].Value)
                        </div>
                    </a>
                }
                @if (!Model.DormantTenantList.Any())
                {
                    <div class="usage-empty">@Localizer["No dormant tenants right now."]</div>
                }
            </div>
        </div>
    </div>

    <div class="superadmin-panel">
        <div class="superadmin-panel-header-with-action">
            <div class="superadmin-panel-header superadmin-hero-header-tight">
                <h3>@Localizer["Recent Tenants"]</h3>
                <p>@Localizer["Latest registered workspaces"]</p>
            </div>
            <a asp-controller="Tenant" asp-action="Index" class="superadmin-panel-link">
                @Localizer["View all"] <i class="bi bi-arrow-right"></i>
            </a>
        </div>
        <div class="table-responsive">
            <table class="superadmin-table">
                <thead>
                    <tr>
                        <th>@Localizer["Tenant"]</th>
                        <th>@Localizer["Plan"]</th>
                        <th>@Localizer["Status"]</th>
                        <th>@Localizer["Joined"]</th>
                        <th>@Localizer["Usage"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.RecentTenants)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold text-dark">@t.Name</div>
                                <div class="text-muted small">@t.ContactEmail</div>
                            </td>
                            <td>@(t.ActivePlan ?? Localizer["Not available"].Value)</td>
                            <td>
                                <span class="status-badge @(t.IsActive ? "active" : "inactive")">
                                    @(t.IsActive ? Localizer["Active"].Value : Localizer["Inactive"].Value)
                                </span>
                            </td>
                            <td class="text-muted small">@Html.TenantDate(t.CreatedAt, "dd MMM yyyy")</td>
                            <td>
                                <a asp-action="TenantUsage" asp-route-id="@t.Id" class="superadmin-panel-link">@Localizer["View"]</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.RecentTenants.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">@Localizer["No tenants yet."]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
