@model ClothInventoryApp.Models.Tenant
@{
    ViewData["Title"] = Model.Name;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/superadmin.css" asp-append-version="true" />
}

<div class="superadmin-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <h1 class="product-hero-title"><i class="bi bi-building"></i> @Model.Name</h1>
            <p class="product-hero-sub">
                <span class="status-badge @(Model.IsActive ? "active" : "inactive") me-2">
                    @(Model.IsActive ? "Active" : "Inactive")
                </span>
                @Model.Code
            </p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="sa-btn-add">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-action="Index" class="sa-btn-back">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <div class="sa-details-grid">
        <div class="sa-panel">
            <div class="sa-panel-header">
                <span class="sa-section-dot"></span>
                <h3 class="sa-panel-title">Workspace Details</h3>
            </div>
            <div class="sa-detail-rows">
                <div class="sa-detail-row">
                    <span class="sa-detail-label">Name</span>
                    <span class="sa-detail-value">@Model.Name</span>
                </div>
                <div class="sa-detail-row">
                    <span class="sa-detail-label">Code</span>
                    <span class="sa-detail-value"><span class="sa-detail-mono">@Model.Code</span></span>
                </div>
                <div class="sa-detail-row">
                    <span class="sa-detail-label">Currency</span>
                    <span class="sa-detail-value">@(Model.CurrencyCode ?? "—")</span>
                </div>
                <div class="sa-detail-row">
                    <span class="sa-detail-label">Country</span>
                    <span class="sa-detail-value">@(Model.Country ?? "—")</span>
                </div>
                <div class="sa-detail-row">
                    <span class="sa-detail-label">Contact Email</span>
                    <span class="sa-detail-value">@(Model.ContactEmail ?? "—")</span>
                </div>
                <div class="sa-detail-row">
                    <span class="sa-detail-label">Contact Phone</span>
                    <span class="sa-detail-value">@(Model.ContactPhone ?? "—")</span>
                </div>
                <div class="sa-detail-row">
                    <span class="sa-detail-label">Created</span>
                    <span class="sa-detail-value">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
                </div>
                @if (Model.UpdatedAt.HasValue)
                {
                    <div class="sa-detail-row">
                        <span class="sa-detail-label">Updated</span>
                        <span class="sa-detail-value">@Model.UpdatedAt.Value.ToString("dd MMM yyyy HH:mm")</span>
                    </div>
                }
            </div>
        </div>

        <div class="d-flex flex-column gap-4">
            <div class="sa-panel">
                <div class="sa-panel-header">
                    <span class="sa-section-dot"></span>
                    <h3 class="sa-panel-title">Users</h3>
                    <span class="sa-count-badge ms-auto">@Model.Users.Count</span>
                </div>
                @if (Model.Users.Any())
                {
                    <div class="sa-user-list">
                        @foreach (var u in Model.Users)
                        {
                            <div class="sa-user-row">
                                <div class="sa-user-avatar"><i class="bi bi-person-fill"></i></div>
                                <div class="sa-user-info">
                                    <div class="sa-user-name">@u.FullName</div>
                                    <div class="sa-user-email">@u.Email</div>
                                </div>
                                @if (u.IsTenantAdmin)
                                {
                                    <span class="status-badge active ms-auto">Admin</span>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small mb-0 px-4 pb-4">No users yet.</p>
                }
            </div>

            <div class="sa-panel">
                <div class="sa-panel-header">
                    <span class="sa-section-dot"></span>
                    <h3 class="sa-panel-title">Subscriptions</h3>
                    <span class="sa-count-badge ms-auto">@Model.Subscriptions.Count</span>
                </div>
                @if (Model.Subscriptions.Any())
                {
                    <div class="sa-sub-list">
                        @foreach (var sub in Model.Subscriptions.OrderByDescending(s => s.CreatedAt))
                        {
                            var isExpired = sub.EndDate < DateTime.UtcNow;
                            <div class="sa-sub-row">
                                <div class="sa-sub-info">
                                    <div class="sa-sub-plan">@sub.Plan.Name</div>
                                    <div class="sa-sub-dates">
                                        @sub.StartDate.ToString("dd MMM yyyy") — @sub.EndDate.ToString("dd MMM yyyy")
                                    </div>
                                </div>
                                <span class="status-badge @(sub.IsTrial ? "trial" : sub.IsActive && !isExpired ? "active" : "inactive")">
                                    @(sub.IsTrial ? "Trial" : sub.IsActive && !isExpired ? "Active" : "Expired")
                                </span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small mb-0 px-4 pb-4">No subscriptions.</p>
                }
            </div>
        </div>
    </div>
</div>
