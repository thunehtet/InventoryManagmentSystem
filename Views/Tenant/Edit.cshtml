@model ClothInventoryApp.Dtos.Tenant.TenantEditDto
@{
    ViewData["Title"] = Localizer["Edit Tenant"];
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/superadmin.css" asp-append-version="true" />
}

<div class="superadmin-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <h1 class="product-hero-title"><i class="bi bi-pencil-square"></i> Edit Tenant</h1>
            <p class="product-hero-sub">@Model.Name</p>
        </div>
        <a asp-action="Index" class="sa-btn-back">
            <i class="bi bi-arrow-left"></i> Back to Tenants
        </a>
    </div>

    <div class="sa-form-card">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mx-4 mt-4 mb-0"></div>

            <div class="sa-form-section">
                <div class="sa-section-header">
                    <span class="sa-section-dot"></span>
                    <span class="sa-section-title">Workspace Info</span>
                </div>
                <div class="superadmin-form-grid">
                    <div class="form-group-modern">
                        <label asp-for="Name" class="form-label-modern">Business Name</label>
                        <input asp-for="Name" class="form-input-modern" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="form-group-modern">
                        <label asp-for="BusinessType" class="form-label-modern">Business Type</label>
                        <input asp-for="BusinessType" class="form-input-modern" />
                        <span asp-validation-for="BusinessType" class="text-danger small"></span>
                    </div>
                    <div class="form-group-modern">
                        <label asp-for="Code" class="form-label-modern">Tenant Code</label>
                        <input asp-for="Code" class="form-input-modern" />
                        <span asp-validation-for="Code" class="text-danger small"></span>
                    </div>
                    <div class="form-group-modern">
                        <label asp-for="CurrencyCode" class="form-label-modern">Currency</label>
                        <input asp-for="CurrencyCode" class="form-input-modern" />
                        <span asp-validation-for="CurrencyCode" class="text-danger small"></span>
                    </div>
                    <div class="form-group-modern">
                        <label asp-for="Country" class="form-label-modern">Country</label>
                        <input asp-for="Country" class="form-input-modern" />
                        <span asp-validation-for="Country" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="sa-form-section">
                <div class="sa-section-header">
                    <span class="sa-section-dot"></span>
                    <span class="sa-section-title">Contact</span>
                </div>
                <div class="superadmin-form-grid">
                    <div class="form-group-modern">
                        <label asp-for="ContactEmail" class="form-label-modern">Contact Email</label>
                        <input asp-for="ContactEmail" class="form-input-modern" />
                        <span asp-validation-for="ContactEmail" class="text-danger small"></span>
                    </div>
                    <div class="form-group-modern">
                        <label asp-for="ContactPhone" class="form-label-modern">Contact Phone</label>
                        <input asp-for="ContactPhone" class="form-input-modern" />
                        <span asp-validation-for="ContactPhone" class="text-danger small"></span>
                    </div>
                    <div class="form-group-modern form-span-2">
                        <label asp-for="LogoUrl" class="form-label-modern">Logo URL</label>
                        <input asp-for="LogoUrl" class="form-input-modern" />
                        <span asp-validation-for="LogoUrl" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="sa-form-section">
                <div class="sa-section-header">
                    <span class="sa-section-dot"></span>
                    <span class="sa-section-title">Settings</span>
                </div>
                <div class="form-check-modern">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label">@Localizer["Active"]</label>
                </div>
            </div>

            <div class="sa-form-actions">
                <a asp-action="Index" class="sa-btn-cancel">
                    <i class="bi bi-x-lg"></i> Cancel
                </a>
                <button type="submit" class="sa-btn-save">
                    <i class="bi bi-check-lg"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
