@model ClothInventoryApp.Models.Tenant
@{
    ViewData["Title"] = "Delete Tenant";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/superadmin.css" asp-append-version="true" />
}

<div class="superadmin-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <h1 class="product-hero-title"><i class="bi bi-trash3-fill"></i> Delete Tenant</h1>
            <p class="product-hero-sub">This action cannot be undone</p>
        </div>
        <a asp-action="Index" class="sa-btn-back">
            <i class="bi bi-arrow-left"></i> Back to Tenants
        </a>
    </div>

    <div class="sa-delete-card">
        <div class="sa-delete-banner">
            <div class="sa-delete-banner-icon">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <div>
                <div class="sa-delete-title">Delete "@Model.Name"?</div>
                <div class="sa-delete-sub">
                    This will permanently remove the workspace and all its data.
                    @if (Model.Users.Any())
                    {
                        <span class="fw-semibold superadmin-text-danger">
                            This tenant has @Model.Users.Count linked user(s) — deactivate it instead.
                        </span>
                    }
                    else
                    {
                        <span>This tenant has no users and can be safely deleted.</span>
                    }
                </div>
            </div>
        </div>

        <div class="sa-detail-rows">
            <div class="sa-detail-row">
                <span class="sa-detail-label">Name</span>
                <span class="sa-detail-value fw-semibold">@Model.Name</span>
            </div>
            <div class="sa-detail-row">
                <span class="sa-detail-label">Code</span>
                <span class="sa-detail-value"><span class="sa-detail-mono">@Model.Code</span></span>
            </div>
            <div class="sa-detail-row">
                <span class="sa-detail-label">Contact Email</span>
                <span class="sa-detail-value">@(Model.ContactEmail ?? "—")</span>
            </div>
            <div class="sa-detail-row">
                <span class="sa-detail-label">Linked Users</span>
                <span class="sa-detail-value @(Model.Users.Any() ? "text-danger fw-bold" : "")">@Model.Users.Count</span>
            </div>
        </div>

        <div class="sa-form-actions">
            <a asp-action="Index" class="sa-btn-cancel">
                <i class="bi bi-x-lg"></i> Cancel
            </a>
            @if (!Model.Users.Any())
            {
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="sa-btn-danger">
                        <i class="bi bi-trash3"></i> Delete Permanently
                    </button>
                </form>
            }
            else
            {
                <form asp-action="ToggleStatus" asp-route-id="@Model.Id" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="sa-btn-save">
                        <i class="bi bi-slash-circle"></i> Deactivate Instead
                    </button>
                </form>
            }
        </div>
    </div>
</div>
