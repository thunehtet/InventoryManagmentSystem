@{
    Layout = null;
    var tenantName = ViewBag.TenantName as string ?? "the shop";
    var tenantLogoUrl = ViewBag.TenantLogoUrl as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="~/images/websitelogo.png" asp-append-version="true" />
    <title>Registered! - @tenantName</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/public-shared.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+Myanmar:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="public-page public-page--success">
    <div class="public-shell public-shell--centered">
        <div class="public-card public-card--compact public-card--centered">
            <div class="public-brand-banner public-brand-banner--stacked">
                <div class="public-tenant-brand public-tenant-brand--centered">
                    <div class="public-tenant-logo">
                        @if (!string.IsNullOrWhiteSpace(tenantLogoUrl))
                        {
                            <img src="@tenantLogoUrl" alt="@tenantName" />
                        }
                        else
                        {
                            <span>@tenantName.Substring(0, 1).ToUpperInvariant()</span>
                        }
                    </div>
                    <div class="public-tenant-label">@tenantName</div>
                </div>
                <div class="public-powered-by">
                    <span>Powered by</span>
                    <img src="~/images/websitelogo.png" alt="StockEasy" />
                </div>
            </div>
            <div class="public-check-icon">
                <i class="bi bi-check-lg"></i>
            </div>
            <h1 class="public-card-title">You're registered!</h1>
            <p class="public-card-subtitle">
                Thanks for registering with <strong>@tenantName</strong>.<br />
                Your details have been saved.
            </p>
        </div>
    </div>
</body>
</html>
