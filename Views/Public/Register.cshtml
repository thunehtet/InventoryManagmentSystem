@using ClothInventoryApp.Dto.Customer
@model CreateCustomerDto
@{
    Layout = null;
    var tenantName = ViewBag.TenantName as string ?? "the shop";
    var tenantCode = ViewBag.TenantCode as string ?? "";
    var inviteToken = ViewBag.InviteToken as string;
    var formAction = !string.IsNullOrWhiteSpace(inviteToken)
        ? Url.Action("RegisterByInvite", "Public", new { token = inviteToken })
        : $"/p/{tenantCode}/join";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - @tenantName</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/public-shared.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+Myanmar:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="public-page public-page--form">
    <div class="public-shell">
        <div class="public-card">
            <div class="public-card-header">
                <div class="public-card-icon">
                    <i class="bi bi-person-plus-fill"></i>
                </div>
                <h1 class="public-card-title">Join @tenantName</h1>
                <p class="public-card-subtitle">Fill in your details to register as a customer.</p>

                @if (!string.IsNullOrWhiteSpace(inviteToken))
                {
                    <div class="public-info-chip">
                        <i class="bi bi-shield-check"></i>
                        <span>Secure one-time link</span>
                    </div>
                }
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="public-alert public-alert--error">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>Please fix the errors below and try again.</span>
                </div>
            }

            <form method="post" action="@formAction" class="public-form">
                @Html.AntiForgeryToken()

                <div class="public-field">
                    <label asp-for="Name" class="public-label"></label>
                    <input asp-for="Name" class="public-input" placeholder="Your full name" autocomplete="name" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>

                <div class="public-field">
                    <label asp-for="Phone" class="public-label">
                        Phone <span class="public-optional">(optional)</span>
                    </label>
                    <input asp-for="Phone" class="public-input" placeholder="09 xxx xxx xxx" autocomplete="tel" />
                    <span asp-validation-for="Phone" class="field-validation-error"></span>
                </div>

                <div class="public-field">
                    <label asp-for="Email" class="public-label">
                        Email <span class="public-optional">(optional)</span>
                    </label>
                    <input asp-for="Email" type="email" class="public-input" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="public-field">
                    <label asp-for="FacebookAccount" class="public-label">
                        Facebook <span class="public-optional">(optional)</span>
                    </label>
                    <input asp-for="FacebookAccount" class="public-input" placeholder="Facebook name or profile link" />
                    <span asp-validation-for="FacebookAccount" class="field-validation-error"></span>
                </div>

                <div class="public-field">
                    <label asp-for="Address" class="public-label">
                        Address <span class="public-optional">(optional)</span>
                    </label>
                    <input asp-for="Address" class="public-input" placeholder="Street, township, city..." autocomplete="street-address" />
                    <span asp-validation-for="Address" class="field-validation-error"></span>
                </div>

                <button type="submit" class="public-btn public-btn--primary">Register</button>
            </form>

            <p class="public-privacy">Your information is only shared with @tenantName.</p>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
