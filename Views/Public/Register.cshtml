@using ClothInventoryApp.Dto.Customer
@model CreateCustomerDto
@{
    Layout = null;
    var tenantName = ViewBag.TenantName as string ?? "the shop";
    var tenantLogoUrl = ViewBag.TenantLogoUrl as string;
    var tenantCode = ViewBag.TenantCode as string ?? "";
    var inviteToken = ViewBag.InviteToken as string;
    var formAction = !string.IsNullOrWhiteSpace(inviteToken)
        ? Url.Action("RegisterByInvite", "Public", new { token = inviteToken })
        : $"/p/{tenantCode}/join";
}
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="~/images/websitelogo.png" asp-append-version="true" />
    <title>@Localizer["Register"] - @tenantName</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/public-shared.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+Myanmar:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="public-page public-page--form">
    <div class="public-shell">
        <div class="public-card">
            <div class="public-card-header">
                <div class="public-brand-banner">
                    <div class="public-tenant-brand">
                        <div class="public-tenant-logo">
                            @if (!string.IsNullOrWhiteSpace(tenantLogoUrl))
                            {
                                <img src="@tenantLogoUrl" alt="@tenantName" />
                            }
                            else
                            {
                                <span>@tenantName.Substring(0, 1).ToUpperInvariant()</span>
                            }
                        </div>
                        <div>
                            <div class="public-tenant-label">@Localizer["Customer Registration"]</div>
                            <h1 class="public-card-title">@Localizer["Join {0}", tenantName]</h1>
                        </div>
                    </div>
                    <div class="public-powered-by">
                        <span>@Localizer["Powered by"]</span>
                        <img src="~/images/websitelogo.png" alt="StockEasy" />
                    </div>
                </div>
                <p class="public-card-subtitle">@Localizer["Fill in your details to register as a customer."]</p>

                @if (!string.IsNullOrWhiteSpace(inviteToken))
                {
                    <div class="public-info-chip">
                        <i class="bi bi-shield-check"></i>
                        <span>@Localizer["Secure one-time link"]</span>
                    </div>
                }
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="public-alert public-alert--error">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@Localizer["Please fix the errors below and try again."]</span>
                </div>
            }

            <form method="post" action="@formAction" class="public-form">
                @Html.AntiForgeryToken()

                <div class="public-field">
                    <label asp-for="Name" class="public-label"></label>
                    <input asp-for="Name" class="public-input" placeholder='@Localizer["Your full name"]' autocomplete="name" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>

                <div class="public-field">
                    <label asp-for="Phone" class="public-label">
                        @Localizer["Phone"] <span class="public-optional">@Localizer["(optional)"]</span>
                    </label>
                    <input asp-for="Phone" class="public-input" placeholder='@Localizer["09 xxx xxx xxx"]' autocomplete="tel" />
                    <span asp-validation-for="Phone" class="field-validation-error"></span>
                </div>

                <div class="public-field">
                    <label asp-for="Email" class="public-label">
                        @Localizer["Email"] <span class="public-optional">@Localizer["(optional)"]</span>
                    </label>
                    <input asp-for="Email" type="email" class="public-input" placeholder='@Localizer["you@example.com"]' autocomplete="email" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="public-field">
                    <label asp-for="FacebookAccount" class="public-label">
                        @Localizer["Facebook"] <span class="public-optional">@Localizer["(optional)"]</span>
                    </label>
                    <input asp-for="FacebookAccount" class="public-input" placeholder='@Localizer["Facebook name or profile link"]' />
                    <span asp-validation-for="FacebookAccount" class="field-validation-error"></span>
                </div>

                <div class="public-field">
                    <label asp-for="Address" class="public-label">
                        @Localizer["Address"] <span class="public-optional">@Localizer["(optional)"]</span>
                    </label>
                    <input asp-for="Address" class="public-input" placeholder='@Localizer["Street, township, city..."]' autocomplete="street-address" />
                    <span asp-validation-for="Address" class="field-validation-error"></span>
                </div>

                <button type="submit" class="public-btn public-btn--primary">@Localizer["Register"]</button>
            </form>

            <p class="public-privacy">@Localizer["Your information is only shared with {0}.", tenantName]</p>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
