@model IEnumerable<ClothInventoryApp.Dto.SuperAdmin.SubscriptionPaymentRequestReviewDto>
@{
    ViewData["Title"] = Localizer["Payment Requests"];
    var pg = ViewBag.Pagination as ClothInventoryApp.Models.PaginationViewModel;
    var selectedStatus = ViewBag.Status as string ?? "Pending";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/superadmin.css" asp-append-version="true" />
}

<div class="superadmin-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <h1 class="product-hero-title"><i class="bi bi-receipt-cutoff"></i> Payment Requests</h1>
            <p class="product-hero-sub">Review tenant payment proofs before activating subscriptions.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Subscription" asp-action="Index" class="sa-btn-back">
                <i class="bi bi-credit-card-fill"></i> Subscriptions
            </a>
            <a asp-controller="SuperAdmin" asp-action="Index" class="sa-btn-back">
                <i class="bi bi-arrow-left"></i> Dashboard
            </a>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <form method="get" asp-action="Index" class="sa-search-bar">
        @if (pg != null) { <input type="hidden" name="size" value="@pg.PageSize" /> }
        <div class="sa-search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" name="search" value="@ViewBag.Search" class="sa-search-input" placeholder="Search tenant, plan, requester, transaction..." />
        </div>
        <select name="status" class="form-select superadmin-filter-select">
            @if (string.IsNullOrEmpty(selectedStatus))
            {
                <option value="" selected>All Statuses</option>
            }
            else
            {
                <option value="">All Statuses</option>
            }
            @if (selectedStatus == "Pending")
            {
                <option value="Pending" selected>Pending</option>
            }
            else
            {
                <option value="Pending">Pending</option>
            }
            @if (selectedStatus == "Approved")
            {
                <option value="Approved" selected>Approved</option>
            }
            else
            {
                <option value="Approved">Approved</option>
            }
            @if (selectedStatus == "Rejected")
            {
                <option value="Rejected" selected>Rejected</option>
            }
            else
            {
                <option value="Rejected">Rejected</option>
            }
        </select>
        <button type="submit" class="sa-search-btn"><i class="bi bi-search"></i> Search</button>
    </form>

    <div class="product-table-card">
        <div class="table-responsive">
            <table class="superadmin-table">
                <thead>
                    <tr>
                        <th>Tenant</th>
                        <th>Plan</th>
                        <th>Billing</th>
                        <th>Price</th>
                        <th>Txn Last 6</th>
                        <th>Status</th>
                        <th>Submitted</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">No payment requests found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold text-dark">@item.TenantName</div>
                                    <div class="text-muted small">@item.RequestedByName</div>
                                </td>
                                <td>@item.PlanName</td>
                                <td>@item.BillingCycle</td>
                                <td>@item.ExpectedPrice.ToString("N0")</td>
                                <td>@item.Last6TransactionId</td>
                                <td>
                                    <span class="status-badge @(item.Status == "Approved" ? "active" : item.Status == "Rejected" ? "inactive" : "trial")">
                                        @item.Status
                                    </span>
                                </td>
                            <td>@Html.TenantDate(item.SubmittedAt, "dd MMM yyyy")</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="action-btn action-btn-view" title="Review">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (pg != null) { @await Html.PartialAsync("_Pagination", pg) }
    </div>
</div>
