@model ClothInventoryApp.Dto.Dashboard.DashboardViewModel

@{
    ViewData["Title"] = Localizer["Dashboard"];
    var currency = ViewData["Currency"] as string ?? "";
}

<div class="dashboard-shell">
    <section class="dashboard-hero">
        <div class="dashboard-hero-content">
            <div class="hero-badge-modern">
                <i class="bi bi-stars"></i>
                <span>@Localizer["Inventory control center"]</span>
            </div>

            <h1 class="dashboard-title">
                @Localizer["Manage your inventory with a cleaner and smarter dashboard."]
            </h1>

            <p class="dashboard-subtitle">
                @Localizer["Monitor products, variants, stock movement, and recent activity in one place."]
            </p>

            <div class="dashboard-hero-actions">
                <a asp-controller="Products" asp-action="Index" class="btn-dashboard-primary">
                    <i class="bi bi-box-seam"></i>
                    @Localizer["Manage Products"]
                </a>

                <a asp-controller="Stock" asp-action="Inventory" class="btn-dashboard-secondary">
                    <i class="bi bi-boxes"></i>
                    @Localizer["View Inventory"]
                </a>
            </div>
        </div>

        <div class="dashboard-hero-side">
            <div class="hero-summary-card">
                <div class="hero-summary-top">
                    <span class="summary-label">@Localizer["System overview"]</span>
                    <i class="bi bi-graph-up-arrow"></i>
                </div>

                <div class="hero-summary-metrics">
                    <div class="mini-metric">
                        <span class="mini-metric-label">@Localizer["Products"]</span>
                        <span class="mini-metric-value">@Model.TotalProducts</span>
                    </div>

                    <div class="mini-metric">
                        <span class="mini-metric-label">@Localizer["Variants"]</span>
                        <span class="mini-metric-value">@Model.TotalVariants</span>
                    </div>

                    <div class="mini-metric">
                        <span class="mini-metric-label">@Localizer["Low Stock"]</span>
                        <span class="mini-metric-value">@Model.LowStockCount</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="dashboard-stats-grid">
        <div class="dashboard-stat-card">
            <div class="stat-card-icon bg-blue-soft">
                <i class="bi bi-box-seam-fill"></i>
            </div>
            <div class="stat-card-content">
                <div class="stat-card-label">@Localizer["Total Products"]</div>
                <div class="stat-card-value">@Model.TotalProducts</div>
                <div class="stat-card-note">@Localizer["All master products in catalog"]</div>
            </div>
        </div>

        <div class="dashboard-stat-card">
            <div class="stat-card-icon bg-purple-soft">
                <i class="bi bi-grid-3x3-gap-fill"></i>
            </div>
            <div class="stat-card-content">
                <div class="stat-card-label">@Localizer["Total Variants"]</div>
                <div class="stat-card-value">@Model.TotalVariants</div>
                <div class="stat-card-note">@Localizer["Color and size combinations tracked"]</div>
            </div>
        </div>

        <div class="dashboard-stat-card">
            <div class="stat-card-icon bg-orange-soft">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <div class="stat-card-content">
                <div class="stat-card-label">@Localizer["Low Stock Items"]</div>
                <div class="stat-card-value">@Model.LowStockCount</div>
                <div class="stat-card-note">@Localizer["Items that may need replenishment"]</div>
            </div>
        </div>
    </section>

    <section class="dashboard-main-grid">
        <div class="dashboard-panel dashboard-panel-large">
            <div class="panel-header">
                <div>
                    <h3>@Localizer["Quick Actions"]</h3>
                    <p>@Localizer["Access common tasks quickly from the dashboard."]</p>
                </div>
            </div>

            <div class="quick-action-grid">
                <a asp-controller="Products" asp-action="Create" class="quick-action-card">
                    <div class="quick-action-icon blue">
                        <i class="bi bi-plus-square-fill"></i>
                    </div>
                    <div class="quick-action-body">
                        <h4>@Localizer["Add Product"]</h4>
                        <p>@Localizer["Create a new master product in your catalog."]</p>
                    </div>
                    <i class="bi bi-arrow-right-short quick-action-arrow"></i>
                </a>

                <a asp-controller="ProductVariants" asp-action="Create" class="quick-action-card">
                    <div class="quick-action-icon purple">
                        <i class="bi bi-diagram-3-fill"></i>
                    </div>
                    <div class="quick-action-body">
                        <h4>@Localizer["Add Variant"]</h4>
                        <p>@Localizer["Create size and color combinations for products."]</p>
                    </div>
                    <i class="bi bi-arrow-right-short quick-action-arrow"></i>
                </a>

                <a asp-controller="Stock" asp-action="StockIn" class="quick-action-card">
                    <div class="quick-action-icon green">
                        <i class="bi bi-box-arrow-in-down"></i>
                    </div>
                    <div class="quick-action-body">
                        <h4>@Localizer["Stock In"]</h4>
                        <p>@Localizer["Record incoming inventory for a product variant."]</p>
                    </div>
                    <i class="bi bi-arrow-right-short quick-action-arrow"></i>
                </a>

                <a asp-controller="Stock" asp-action="StockOut" class="quick-action-card">
                    <div class="quick-action-icon red">
                        <i class="bi bi-box-arrow-up"></i>
                    </div>
                    <div class="quick-action-body">
                        <h4>@Localizer["Stock Out"]</h4>
                        <p>@Localizer["Record outgoing inventory movement accurately."]</p>
                    </div>
                    <i class="bi bi-arrow-right-short quick-action-arrow"></i>
                </a>

                <a asp-controller="Sales" asp-action="Create" class="quick-action-card">
                    <div class="quick-action-icon teal">
                        <i class="bi bi-receipt-cutoff"></i>
                    </div>
                    <div class="quick-action-body">
                        <h4>@Localizer["Create Sale"]</h4>
                        <p>@Localizer["Record a new sale and update item movement."]</p>
                    </div>
                    <i class="bi bi-arrow-right-short quick-action-arrow"></i>
                </a>

                <a asp-controller="Stock" asp-action="Inventory" class="quick-action-card">
                    <div class="quick-action-icon dark">
                        <i class="bi bi-bar-chart-line-fill"></i>
                    </div>
                    <div class="quick-action-body">
                        <h4>@Localizer["Inventory Report"]</h4>
                        <p>@Localizer["Review available stock and movement summary."]</p>
                    </div>
                    <i class="bi bi-arrow-right-short quick-action-arrow"></i>
                </a>
            </div>
        </div>

        <div class="dashboard-panel dashboard-panel-side">
            <div class="panel-header">
                <div>
                    <h3>@Localizer["Inventory Health"]</h3>
                    <p>@Localizer["Quick inventory summary."]</p>
                </div>
            </div>

            <div class="health-list">
                <a asp-controller="Products" asp-action="Index" class="health-row health-row-link">
                    <div class="health-label-wrap">
                        <span class="health-dot blue"></span>
                        <span class="health-label">@Localizer["Products"]</span>
                    </div>
                    <div class="health-value-wrap">
                        <span class="health-value">@Model.TotalProducts</span>
                        <i class="bi bi-chevron-right health-arrow"></i>
                    </div>
                </a>

                <a asp-controller="ProductVariants" asp-action="Index" class="health-row health-row-link">
                    <div class="health-label-wrap">
                        <span class="health-dot purple"></span>
                        <span class="health-label">@Localizer["Variants"]</span>
                    </div>
                    <div class="health-value-wrap">
                        <span class="health-value">@Model.TotalVariants</span>
                        <i class="bi bi-chevron-right health-arrow"></i>
                    </div>
                </a>

                <a asp-controller="Stock" asp-action="Inventory" asp-route-lowstock="true" class="health-row health-row-link @(Model.LowStockCount > 0 ? "health-row-warning" : "")">
                    <div class="health-label-wrap">
                        <span class="health-dot orange"></span>
                        <span class="health-label">@Localizer["Low Stock"]</span>
                    </div>
                    <div class="health-value-wrap">
                        <span class="health-value">@Model.LowStockCount</span>
                        <i class="bi bi-chevron-right health-arrow"></i>
                    </div>
                </a>
            </div>

            <div class="inventory-health-footer">
                @if (Model.LowStockCount > 0)
                {
                    <div class="alert-soft warning">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        <span>@Localizer["{0} item(s) may need replenishment soon.", Model.LowStockCount]</span>
                    </div>
                }
                else
                {
                    <div class="alert-soft success">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>@Localizer["No low stock alert at the moment."]</span>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Sales Trend Chart -->
    <section class="dashboard-panel chart-panel">
        <div class="panel-header panel-header-with-action">
            <div>
                <h3>@Localizer["Sales & Profit Trend"]</h3>
                <p id="chartSubtitle">@Localizer["Daily revenue and profit for the last 30 days"]</p>
            </div>
            <div class="chart-legend-row">
                <div class="chart-legend-item">
                    <span class="chart-legend-dot legend-sales"></span> @Localizer["Sales"]
                </div>
                <div class="chart-legend-item">
                    <span class="chart-legend-dot legend-profit"></span> @Localizer["Profit"]
                </div>
                <div class="trend-filter-group">
                    <button id="btnDaily"  class="trend-filter-btn trend-filter-active" type="button">@Localizer["Daily"]</button>
                    <button id="btnMonthly" class="trend-filter-btn" type="button">@Localizer["Monthly"]</button>
                </div>
            </div>
        </div>
        <div class="chart-wrap">
            <canvas id="salesTrendChart"></canvas>
        </div>
    </section>

    <section class="dashboard-panel recent-activity-panel">
        <div class="panel-header panel-header-with-action">
            <div>
                <h3>@Localizer["Recent Inventory Activity"]</h3>
                <p>@Localizer["Latest stock movement records from the system."]</p>
            </div>

            <a asp-controller="Stock" asp-action="Index" class="panel-link-action">
                @Localizer["View all"]
                <i class="bi bi-arrow-right"></i>
            </a>
        </div>

        <div class="table-responsive">
            <table class="table-modern dashboard-table">
                <thead>
                    <tr>
                        <th>@Localizer["SKU"]</th>
                        <th>@Localizer["Product"]</th>
                        <th>@Localizer["Action"]</th>
                        <th>@Localizer["Quantity"]</th>
                        <th>@Localizer["Date"]</th>
                        <th>@Localizer["Status"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentActivities == null || !Model.RecentActivities.Any())
                    {
                        <tr>
                            <td colspan="6" class="empty-state-cell">
                                <div class="empty-state-wrap">
                                    <i class="bi bi-inbox"></i>
                                    <p>@Localizer["No recent activity found."]</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.RecentActivities)
                        {
                            var isIn = item.Quantity >= 0;
                            <tr>
                                <td class="fw-semibold">@item.SKU</td>
                                <td>@item.ProductName</td>
                                <td>
                                    <span class="activity-badge @(isIn ? "activity-in" : "activity-out")">
                                        @item.Action
                                    </span>
                                </td>
                                <td class="@(isIn ? "qty-positive" : "qty-negative")">
                                    @(isIn ? "+" + item.Quantity : item.Quantity.ToString())
                                </td>
                                <td>@item.Date.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <span class="badge-soft success">@item.Status</span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/dashboard.css" asp-append-version="true" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script>
    (function () {
        // ── Data from server ─────────────────────────────────────────
        var daily = {
            labels:  @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyTrend.Select(p => p.Label))),
            sales:   @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyTrend.Select(p => p.Amount))),
            profit:  @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyTrend.Select(p => p.Profit)))
        };
        var monthly = {
            labels:  @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(p => p.Label))),
            sales:   @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(p => p.Amount))),
            profit:  @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(p => p.Profit)))
        };

        // ── Number formatter: abbreviate large values ─────────────────
        function fmtAxis(v) {
            var abs = Math.abs(v);
            if (abs >= 1000000) return (v / 1000000).toFixed(abs >= 10000000 ? 0 : 1) + 'M';
            if (abs >= 1000)    return (v / 1000).toFixed(abs >= 10000 ? 0 : 1) + 'K';
            return v.toLocaleString();
        }
        var currencyCode = '@currency';
        function fmtTooltip(v) {
            return v.toLocaleString() + (currencyCode ? ' ' + currencyCode : '');
        }

        // ── Chart config ──────────────────────────────────────────────
        var ctx = document.getElementById('salesTrendChart').getContext('2d');
        var chart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: daily.labels,
                datasets: [
                    {
                        label: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Sales"].Value)),
                        data: daily.sales,
                        borderColor: '#6366f1',
                        backgroundColor: 'rgba(99,102,241,0.08)',
                        borderWidth: 2.5,
                        pointRadius: 3,
                        pointHoverRadius: 6,
                        tension: 0.35,
                        fill: true
                    },
                    {
                        label: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Profit"].Value)),
                        data: daily.profit,
                        borderColor: '#10b981',
                        backgroundColor: 'rgba(16,185,129,0.07)',
                        borderWidth: 2.5,
                        pointRadius: 3,
                        pointHoverRadius: 6,
                        tension: 0.35,
                        fill: true
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function(c) {
                                return ' ' + c.dataset.label + ': ' + fmtTooltip(c.parsed.y);
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { color: '#94a3b8', font: { size: 11 }, maxRotation: 45, autoSkip: true, maxTicksLimit: 15 }
                    },
                    y: {
                        grid: { color: '#f1f5f9' },
                        ticks: {
                            color: '#94a3b8',
                            font: { size: 11 },
                            callback: fmtAxis
                        }
                    }
                }
            }
        });

        // ── Filter buttons (no page reload, no scroll jump) ───────────
        var btnDaily   = document.getElementById('btnDaily');
        var btnMonthly = document.getElementById('btnMonthly');
        var subtitle   = document.getElementById('chartSubtitle');

        function setMode(mode) {
            var src = mode === 'month' ? monthly : daily;
            chart.data.labels = src.labels;
            chart.data.datasets[0].data = src.sales;
            chart.data.datasets[1].data = src.profit;
            chart.update();

            subtitle.textContent = mode === 'month'
                ? @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Monthly revenue and profit for the last 12 months"].Value))
                : @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Daily revenue and profit for the last 30 days"].Value));

            btnDaily.classList.toggle('trend-filter-active',   mode === 'day');
            btnMonthly.classList.toggle('trend-filter-active', mode === 'month');
        }

        btnDaily.addEventListener('click',   function() { setMode('day'); });
        btnMonthly.addEventListener('click', function() { setMode('month'); });
    })();
    </script>
}
