@model ClothInventoryApp.Dto.Dashboard.DashboardViewModel

@{
    ViewData["Title"] = Localizer["Dashboard"];
    var currency = ViewData["Currency"] as string ?? "";
    var selectedMonthName = new DateTime(Model.SelectedYear, Model.SelectedMonth, 1).ToString("MMMM");
}

<div class="dashboard-shell">
    @await Html.PartialAsync("_PlanLimitWarnings", Model.PlanLimitWarnings)

    <section class="dashboard-hero">
        <div class="dashboard-hero-content">
            <div class="hero-badge-modern">
                <i class="bi bi-stars"></i>
                <span>@Localizer["Operational command center"]</span>
            </div>

            <h1 class="dashboard-title">
                @Localizer["Run daily sales, stock movement, and replenishment from one place."]
            </h1>

            <p class="dashboard-subtitle">
                @Localizer["Use this dashboard for day-to-day operations. Finance stays separate so this page can stay action-focused."]
            </p>

            <div class="dashboard-hero-actions">
                <a asp-controller="Sales" asp-action="Create" class="btn-dashboard-primary">
                    <i class="bi bi-receipt-cutoff"></i>
                    @Localizer["Create Sale"]
                </a>

                <a asp-controller="Stock" asp-action="Inventory" class="btn-dashboard-secondary">
                    <i class="bi bi-boxes"></i>
                    @Localizer["View Inventory"]
                </a>
            </div>
        </div>

        <div class="dashboard-hero-side">
            <div class="hero-summary-card">
                <div class="hero-summary-top">
                    <span class="summary-label">@Localizer["Current month snapshot"]</span>
                    <i class="bi bi-graph-up-arrow"></i>
                </div>

                <div class="hero-summary-metrics">
                    <div class="mini-metric">
                        <span class="mini-metric-label">@Localizer["Sales"]</span>
                        <span class="mini-metric-value">@Model.CurrentMonthSalesAmount.ToString("N0") @currency</span>
                    </div>

                    <div class="mini-metric">
                        <span class="mini-metric-label">@Localizer["Orders"]</span>
                        <span class="mini-metric-value">@Model.CurrentMonthOrderCount</span>
                    </div>

                    <div class="mini-metric">
                        <span class="mini-metric-label">@Localizer["Profit"]</span>
                        <span class="mini-metric-value">@Model.CurrentMonthProfitAmount.ToString("N0") @currency</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="dashboard-stats-grid dashboard-stats-grid-4">
        <div class="dashboard-stat-card">
            <div class="stat-card-icon bg-blue-soft">
                <i class="bi bi-sun-fill"></i>
            </div>
            <div class="stat-card-content">
                <div class="stat-card-label">@Localizer["Today Sales"]</div>
                <div class="stat-card-value">@Model.TodaySalesAmount.ToString("N0") @currency</div>
                <div class="stat-card-note">@Localizer["Revenue recorded for today"]</div>
            </div>
        </div>

        <div class="dashboard-stat-card">
            <div class="stat-card-icon bg-purple-soft">
                <i class="bi bi-calendar3"></i>
            </div>
            <div class="stat-card-content">
                <div class="stat-card-label">@Localizer["Month Sales"]</div>
                <div class="stat-card-value">@Model.CurrentMonthSalesAmount.ToString("N0") @currency</div>
                <div class="stat-card-note">@Localizer["Sales booked in the current month"]</div>
            </div>
        </div>

        <div class="dashboard-stat-card">
            <div class="stat-card-icon bg-green-soft">
                <i class="bi bi-bag-check-fill"></i>
            </div>
            <div class="stat-card-content">
                <div class="stat-card-label">@Localizer["Month Orders"]</div>
                <div class="stat-card-value">@Model.CurrentMonthOrderCount</div>
                <div class="stat-card-note">@Localizer["Completed sale records this month"]</div>
            </div>
        </div>

        <div class="dashboard-stat-card">
            <div class="stat-card-icon bg-orange-soft">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <div class="stat-card-content">
                <div class="stat-card-label">@Localizer["Low Stock"]</div>
                <div class="stat-card-value">@Model.LowStockCount</div>
                <div class="stat-card-note">@Localizer["Variants below the stock threshold"]</div>
            </div>
        </div>
    </section>

    <section class="dashboard-main-grid">
        <div class="dashboard-panel dashboard-panel-large">
            <div class="panel-header">
                <div>
                    <h3>@Localizer["Quick Actions"]</h3>
                    <p>@Localizer["Use these shortcuts for common daily operations."]</p>
                </div>
            </div>

            <div class="quick-action-grid">
                <a asp-controller="Sales" asp-action="Create" class="quick-action-card">
                    <div class="quick-action-icon teal">
                        <i class="bi bi-receipt-cutoff"></i>
                    </div>
                    <div class="quick-action-body">
                        <h4>@Localizer["Create Sale"]</h4>
                        <p>@Localizer["Record a new customer sale and update stock immediately."]</p>
                    </div>
                    <i class="bi bi-arrow-right-short quick-action-arrow"></i>
                </a>

                <a asp-controller="Stock" asp-action="StockIn" class="quick-action-card">
                    <div class="quick-action-icon green">
                        <i class="bi bi-box-arrow-in-down"></i>
                    </div>
                    <div class="quick-action-body">
                        <h4>@Localizer["Stock In"]</h4>
                        <p>@Localizer["Add received inventory to keep availability accurate."]</p>
                    </div>
                    <i class="bi bi-arrow-right-short quick-action-arrow"></i>
                </a>

                <a asp-controller="Stock" asp-action="StockOut" class="quick-action-card">
                    <div class="quick-action-icon red">
                        <i class="bi bi-box-arrow-up"></i>
                    </div>
                    <div class="quick-action-body">
                        <h4>@Localizer["Stock Out"]</h4>
                        <p>@Localizer["Record non-sale stock removal or adjustments."]</p>
                    </div>
                    <i class="bi bi-arrow-right-short quick-action-arrow"></i>
                </a>

                <a asp-controller="Products" asp-action="Create" class="quick-action-card">
                    <div class="quick-action-icon blue">
                        <i class="bi bi-plus-square-fill"></i>
                    </div>
                    <div class="quick-action-body">
                        <h4>@Localizer["Add Product"]</h4>
                        <p>@Localizer["Expand the catalog with a new master product."]</p>
                    </div>
                    <i class="bi bi-arrow-right-short quick-action-arrow"></i>
                </a>
            </div>
        </div>

        <div class="dashboard-panel dashboard-panel-side">
            <div class="panel-header">
                <div>
                    <h3>@Localizer["Needs Attention"]</h3>
                    <p>@Localizer["Items that deserve action before they affect sales."]</p>
                </div>
            </div>

            <div class="attention-list">
                @foreach (var item in Model.AttentionItems)
                {
                    <a asp-controller="@item.Controller"
                       asp-action="@item.Action"
                       asp-route-lowstock="@item.RouteValue"
                       class="attention-card tone-@item.Tone">
                        <div class="attention-top">
                            <span class="attention-title">@Localizer[item.Title]</span>
                            <span class="attention-value">@item.Value</span>
                        </div>
                        <p>@Localizer[item.Note]</p>
                        <span class="attention-link">
                            @Localizer[item.ActionText]
                            <i class="bi bi-arrow-right-short"></i>
                        </span>
                    </a>
                }
            </div>

            <div class="inventory-health-footer">
                @if (Model.OutOfStockCount > 0)
                {
                    <div class="alert-soft warning">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        <span>@Localizer["{0} variant(s) are currently out of stock.", Model.OutOfStockCount]</span>
                    </div>
                }
                else
                {
                    <div class="alert-soft success">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>@Localizer["No out-of-stock alert at the moment."]</span>
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="dashboard-panel chart-panel">
        <div id="salesTrendData"
             data-daily-labels='@System.Text.Json.JsonSerializer.Serialize(Model.DailyTrend.Select(p => p.Label))'
             data-daily-sales='@System.Text.Json.JsonSerializer.Serialize(Model.DailyTrend.Select(p => p.Amount))'
             data-daily-profit='@System.Text.Json.JsonSerializer.Serialize(Model.DailyTrend.Select(p => p.Profit))'
             data-monthly-labels='@System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(p => p.Label))'
             data-monthly-sales='@System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(p => p.Amount))'
             data-monthly-profit='@System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(p => p.Profit))'
             data-currency='@currency'
             data-sales-label='@Localizer["Sales"].Value'
             data-profit-label='@Localizer["Profit"].Value'
             data-daily-subtitle='@Localizer["Daily revenue and profit for {0} {1}", selectedMonthName, Model.SelectedYear].Value'
             data-monthly-subtitle='@Localizer["Monthly revenue and profit for {0}", Model.SelectedYear].Value'
             hidden></div>
        <div class="panel-header panel-header-with-action">
            <div>
                <h3>@Localizer["Sales & Profit Trend"]</h3>
                <p id="chartSubtitle">@Localizer["Daily revenue and profit for {0} {1}", selectedMonthName, Model.SelectedYear]</p>
            </div>
            <div class="chart-legend-row">
                <form method="get" asp-action="Index" class="trend-period-form">
                    <label class="visually-hidden" for="trendMonth">@Localizer["Month"]</label>
                    <select id="trendMonth" name="month" class="form-select form-select-sm trend-period-select">
                        @for (var month = 1; month <= 12; month++)
                        {
                            var monthName = new DateTime(Model.SelectedYear, month, 1).ToString("MMMM");
                            if (month == Model.SelectedMonth)
                            {
                                <option value="@month" selected>@monthName</option>
                            }
                            else
                            {
                                <option value="@month">@monthName</option>
                            }
                        }
                    </select>
                    <label class="visually-hidden" for="trendYear">@Localizer["Year"]</label>
                    <select id="trendYear" name="year" class="form-select form-select-sm trend-period-select">
                        @foreach (var year in Model.AvailableYears)
                        {
                            if (year == Model.SelectedYear)
                            {
                                <option value="@year" selected>@year</option>
                            }
                            else
                            {
                                <option value="@year">@year</option>
                            }
                        }
                    </select>
                </form>
                <div class="chart-legend-item">
                    <span class="chart-legend-dot legend-sales"></span> @Localizer["Sales"]
                </div>
                <div class="chart-legend-item">
                    <span class="chart-legend-dot legend-profit"></span> @Localizer["Profit"]
                </div>
                <div class="trend-filter-group">
                    <button id="btnDaily" class="trend-filter-btn trend-filter-active" type="button">@Localizer["Daily"]</button>
                    <button id="btnMonthly" class="trend-filter-btn" type="button">@Localizer["Monthly"]</button>
                </div>
            </div>
        </div>
        <div class="chart-wrap">
            <canvas id="salesTrendChart"></canvas>
        </div>
    </section>

    <section class="dashboard-panel recent-activity-panel">
        <div class="panel-header panel-header-with-action">
            <div>
                <h3>@Localizer["Recent Inventory Activity"]</h3>
                <p>@Localizer["Latest stock movement records from the system."]</p>
            </div>

            <a asp-controller="Stock" asp-action="Index" class="panel-link-action">
                @Localizer["View all"]
                <i class="bi bi-arrow-right"></i>
            </a>
        </div>

        <div class="table-responsive">
            <table class="table-modern dashboard-table">
                <thead>
                    <tr>
                        <th>@Localizer["SKU"]</th>
                        <th>@Localizer["Product"]</th>
                        <th>@Localizer["Action"]</th>
                        <th>@Localizer["Quantity"]</th>
                        <th>@Localizer["Date"]</th>
                        <th>@Localizer["Status"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentActivities == null || !Model.RecentActivities.Any())
                    {
                        <tr>
                            <td colspan="6" class="empty-state-cell">
                                <div class="empty-state-wrap">
                                    <i class="bi bi-inbox"></i>
                                    <p>@Localizer["No recent activity found."]</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.RecentActivities)
                        {
                            var isIn = item.Quantity >= 0;
                            <tr>
                                <td class="fw-semibold">@item.SKU</td>
                                <td>@item.ProductName</td>
                                <td>
                                    <span class="activity-badge @(isIn ? "activity-in" : "activity-out")">
                                        @item.Action
                                    </span>
                                </td>
                                <td class="@(isIn ? "qty-positive" : "qty-negative")">
                                    @(isIn ? "+" + item.Quantity : item.Quantity.ToString())
                                </td>
                                <td>@Html.TenantDate(item.Date, "yyyy-MM-dd HH:mm")</td>
                                <td>
                                    <span class="badge-soft success">@item.Status</span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/product-index.css" asp-append-version="true" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script src="~/js/dashboard-index.js" asp-append-version="true"></script>
}
