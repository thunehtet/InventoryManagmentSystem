@model ClothInventoryApp.Dto.SuperAdmin.SubscriptionEditDto
@{
    ViewData["Title"] = "Edit Subscription";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/superadmin.css" asp-append-version="true" />
}

<div class="superadmin-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <h1 class="product-hero-title"><i class="bi bi-pencil-square"></i> Edit Subscription</h1>
            <p class="product-hero-sub">Update subscription details</p>
        </div>
        <a asp-action="Index" class="sa-btn-back">
            <i class="bi bi-arrow-left"></i> Back to Subscriptions
        </a>
    </div>

    <div class="sa-form-card">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mx-4 mt-4 mb-0"></div>

            <div class="sa-form-section">
                <div class="sa-section-header">
                    <span class="sa-section-dot"></span>
                    <span class="sa-section-title">Assignment</span>
                </div>
                <div class="superadmin-form-grid">
                    <div class="form-group-modern">
                        <label asp-for="TenantId" class="form-label-modern">Tenant</label>
                        <select asp-for="TenantId" asp-items="ViewBag.Tenants" class="form-input-modern">
                            <option value="">— Select Tenant —</option>
                        </select>
                        <span asp-validation-for="TenantId" class="text-danger small"></span>
                    </div>
                    <div class="form-group-modern">
                        <label asp-for="PlanId" class="form-label-modern">Plan</label>
                        <select asp-for="PlanId" asp-items="ViewBag.Plans" class="form-input-modern">
                            <option value="">— Select Plan —</option>
                        </select>
                        <span asp-validation-for="PlanId" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="sa-form-section">
                <div class="sa-section-header">
                    <span class="sa-section-dot"></span>
                    <span class="sa-section-title">Billing</span>
                </div>
                <div class="superadmin-form-grid">
                    <div class="form-group-modern">
                        <label asp-for="BillingCycle" class="form-label-modern">Billing Cycle</label>
                        <select asp-for="BillingCycle" asp-items="ViewBag.BillingCycles" class="form-input-modern"></select>
                        <span asp-validation-for="BillingCycle" class="text-danger small"></span>
                    </div>
                    <div class="form-group-modern">
                        <label asp-for="Price" class="form-label-modern">Price ($)</label>
                        <input asp-for="Price" class="form-input-modern" type="number" step="1" min="0" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="form-group-modern">
                        <label asp-for="StartDate" class="form-label-modern">Start Date</label>
                        <input asp-for="StartDate" class="form-input-modern" type="date" />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>
                    <div class="form-group-modern">
                        <label asp-for="EndDate" class="form-label-modern">End Date</label>
                        <input asp-for="EndDate" class="form-input-modern" type="date" />
                        <span asp-validation-for="EndDate" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="sa-form-section">
                <div class="sa-section-header">
                    <span class="sa-section-dot"></span>
                    <span class="sa-section-title">Options</span>
                </div>
                <div class="superadmin-form-grid">
                    <div class="form-group-modern form-span-2">
                        <label asp-for="Notes" class="form-label-modern">Internal Notes</label>
                        <textarea asp-for="Notes" class="form-input-modern" rows="2"></textarea>
                        <span asp-validation-for="Notes" class="text-danger small"></span>
                    </div>
                </div>
                <div class="d-flex gap-4 mt-3 px-1">
                    <div class="form-check-modern">
                        <input asp-for="IsTrial" class="form-check-input" type="checkbox" />
                        <label asp-for="IsTrial" class="form-check-label">Trial</label>
                    </div>
                    <div class="form-check-modern">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">@Localizer["Active"]</label>
                    </div>
                </div>
            </div>

            <div class="sa-form-actions">
                <a asp-action="Index" class="sa-btn-cancel">
                    <i class="bi bi-x-lg"></i> Cancel
                </a>
                <button type="submit" class="sa-btn-save">
                    <i class="bi bi-check-lg"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
