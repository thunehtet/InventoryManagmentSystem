@model ClothInventoryApp.Dto.SuperAdmin.PlanEditDto
@{
    ViewData["Title"] = Localizer["Edit Plan"];
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/superadmin.css" asp-append-version="true" />
}

<div class="superadmin-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <h1 class="product-hero-title"><i class="bi bi-pencil-square"></i> Edit Plan</h1>
            <p class="product-hero-sub">@Model.Name</p>
        </div>
        <a asp-action="Index" class="sa-btn-back">
            <i class="bi bi-arrow-left"></i> Back to Plans
        </a>
    </div>

    <div class="sa-form-card">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mx-4 mt-4 mb-0"></div>

            <div class="sa-form-section">
                <div class="sa-section-header">
                    <span class="sa-section-dot"></span>
                    <span class="sa-section-title">Plan Identity</span>
                </div>
                <div class="superadmin-form-grid">
                    <div class="form-group-modern">
                        <label asp-for="Name" class="form-label-modern">Plan Name</label>
                        <input asp-for="Name" class="form-input-modern" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="form-group-modern">
                        <label asp-for="Code" class="form-label-modern">Plan Code</label>
                        <input asp-for="Code" class="form-input-modern" />
                        <span asp-validation-for="Code" class="text-danger small"></span>
                    </div>
                    <div class="form-group-modern form-span-2">
                        <label asp-for="Description" class="form-label-modern">Description</label>
                        <textarea asp-for="Description" class="form-input-modern" rows="2"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="sa-form-section">
                <div class="sa-section-header">
                    <span class="sa-section-dot"></span>
                    <span class="sa-section-title">Pricing</span>
                </div>
                <div class="superadmin-form-grid">
                    <div class="form-group-modern">
                        <label asp-for="PriceMonthly" class="form-label-modern">Monthly Price ($)</label>
                        <input asp-for="PriceMonthly" class="form-input-modern" type="number" step="1" min="0" />
                        <span asp-validation-for="PriceMonthly" class="text-danger small"></span>
                    </div>
                    <div class="form-group-modern">
                        <label asp-for="PriceYearly" class="form-label-modern">Yearly Price ($)</label>
                        <input asp-for="PriceYearly" class="form-input-modern" type="number" step="1" min="0" />
                        <span asp-validation-for="PriceYearly" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="sa-form-section">
                <div class="sa-section-header">
                    <span class="sa-section-dot"></span>
                    <span class="sa-section-title">Resource Limits <small class="text-muted fw-normal">(leave blank = unlimited)</small></span>
                </div>
                <div class="superadmin-form-grid">
                    <div class="form-group-modern">
                        <label asp-for="MaxUsers" class="form-label-modern">Max Users</label>
                        <input asp-for="MaxUsers" class="form-input-modern" type="number" min="1" placeholder="Unlimited" />
                        <span asp-validation-for="MaxUsers" class="text-danger small"></span>
                    </div>
                    <div class="form-group-modern">
                        <label asp-for="MaxProducts" class="form-label-modern">Max Products</label>
                        <input asp-for="MaxProducts" class="form-input-modern" type="number" min="1" placeholder="Unlimited" />
                        <span asp-validation-for="MaxProducts" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="sa-form-section">
                <div class="sa-section-header">
                    <span class="sa-section-dot"></span>
                    <span class="sa-section-title">Monthly Usage Limits <small class="text-muted fw-normal">(leave blank = unlimited)</small></span>
                </div>
                <div class="superadmin-form-grid">
                    <div class="form-group-modern">
                        <label asp-for="MaxMonthlySales" class="form-label-modern">Max Sales / Month</label>
                        <input asp-for="MaxMonthlySales" class="form-input-modern" type="number" min="1" placeholder="Unlimited" />
                        <span asp-validation-for="MaxMonthlySales" class="text-danger small"></span>
                    </div>
                    <div class="form-group-modern">
                        <label asp-for="MaxMonthlyPdfInvoices" class="form-label-modern">Max PDF Invoices / Month</label>
                        <input asp-for="MaxMonthlyPdfInvoices" class="form-input-modern" type="number" min="1" placeholder="Unlimited" />
                        <span asp-validation-for="MaxMonthlyPdfInvoices" class="text-danger small"></span>
                    </div>
                    <div class="form-group-modern">
                        <label asp-for="MaxMonthlyReceiptShares" class="form-label-modern">Max Receipt Shares / Month</label>
                        <input asp-for="MaxMonthlyReceiptShares" class="form-input-modern" type="number" min="1" placeholder="Unlimited" />
                        <span asp-validation-for="MaxMonthlyReceiptShares" class="text-danger small"></span>
                    </div>
                    <div class="form-group-modern">
                        <label asp-for="MaxMonthlyCustomerInvites" class="form-label-modern">Max Customer Invites / Month</label>
                        <input asp-for="MaxMonthlyCustomerInvites" class="form-input-modern" type="number" min="1" placeholder="Unlimited" />
                        <span asp-validation-for="MaxMonthlyCustomerInvites" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="sa-form-section">
                <div class="sa-section-header">
                    <span class="sa-section-dot"></span>
                    <span class="sa-section-title">Visibility</span>
                </div>
                <div class="form-check-modern">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label">@Localizer["Active"]</label>
                </div>
            </div>

            <div class="sa-form-actions">
                <a asp-action="Index" class="sa-btn-cancel">
                    <i class="bi bi-x-lg"></i> Cancel
                </a>
                <button type="submit" class="sa-btn-save">
                    <i class="bi bi-check-lg"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
