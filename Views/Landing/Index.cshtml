<!-- ═══════════════════════════════════════════════════════════
     JAVASCRIPT
     ═══════════════════════════════════════════════════════════ -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<partial name="_ValidationScriptsPartial" />
<script>
(function () {

    // ── Language toggle ────────────────────────────────────────
    window.toggleLang = function () {
        var root = document.getElementById('htmlRoot');
        var current = root.getAttribute('data-lang') || 'en';
        var next = current === 'en' ? 'my' : 'en';
        root.setAttribute('data-lang', next);
        localStorage.setItem('se-lang', next);

        // Sync ASP.NET culture cookie so app sections use correct culture
        var culture = next === 'my' ? 'my-MM' : 'en';
        document.cookie = '.AspNetCore.Culture=c%3D' + culture + '%7Cuic%3D' + culture
            + '; path=/; max-age=31536000; SameSite=Strict';
    };

    var langBtn = document.getElementById('langBtn');
    if (langBtn) langBtn.addEventListener('click', toggleLang);

    // ── Navbar scroll effect ───────────────────────────────────
    var nav = document.getElementById('navbar');
    window.addEventListener('scroll', function () {
        nav.classList.toggle('scrolled', window.scrollY > 40);
    }, { passive: true });

    // ── Close mobile menu when a link is clicked ───────────────
    document.querySelectorAll('.nav-mobile a').forEach(function (link) {
        link.addEventListener('click', function () {
            var t = document.getElementById('nav-toggle');
            if (t) t.checked = false;
        });
    });

    // ── Scroll fade-up animations ──────────────────────────────
    var fadeEls = document.querySelectorAll('.fade-up');
    if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    io.unobserve(entry.target);
                }
            });
        }, { threshold: 0.10, rootMargin: '0px 0px -40px 0px' });
        fadeEls.forEach(function (el) { io.observe(el); });
    } else {
        fadeEls.forEach(function (el) { el.classList.add('visible'); });
    }

})();
</script>

</body>
</html>
