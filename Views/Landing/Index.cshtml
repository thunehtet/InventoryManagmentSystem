@{
    Layout = null;
}
@model ClothInventoryApp.Dto.Landing.LandingSignupDto
<!DOCTYPE html>
<html lang="en" data-lang="en" id="htmlRoot">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StockEasy — Inventory Management for Small Business</title>
    <meta name="description" content="StockEasy helps small businesses manage inventory, track sales, and grow faster." />
    <link rel="icon" type="image/png" href="~/images/websitelogo.png" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/pages/landing.css" asp-append-version="true" />

    <!-- Apply saved language BEFORE render to avoid flash -->
    <script>
        (function(){
            var l = localStorage.getItem('se-lang') || 'en';
            document.getElementById('htmlRoot').setAttribute('data-lang', l);
        })();
    </script>
</head>
<body>

<!-- ═══════════════════════════════════════════════════════════
     NAVBAR
     ═══════════════════════════════════════════════════════════ -->
<header class="nav" id="navbar">
    <div class="nav-inner">

        <a href="#" class="nav-brand">
            <img src="~/images/websitelogo.png" alt="StockEasy" class="nav-brand-logo" />
        </a>

        <nav class="nav-links">
            <a href="#features"><span class="en">Features</span><span class="my">လုပ်ဆောင်ချက်</span></a>
            <a href="#how"><span class="en">How It Works</span><span class="my">အသုံးပြုပုံ</span></a>
            <a href="#pricing"><span class="en">Pricing</span><span class="my">စျေးနှုန်း</span></a>
            <a href="#contact"><span class="en">Contact</span><span class="my">ဆက်သွယ်ရန်</span></a>
        </nav>

        <div class="nav-actions">
            <button class="lang-btn" id="langBtn" aria-label="Switch language">
                <i class="bi bi-translate"></i>
                <span class="en">မြန်မာ</span><span class="my">English</span>
            </button>
            <a href="/Account/Login" class="btn-nav-ghost">
                <span class="en">Sign In</span><span class="my">ဝင်ရောက်ပါ</span>
            </a>
            <a href="#contact" class="btn-nav-cta">
                <span class="en">Get Started</span><span class="my">စတင်ပါ</span>
            </a>
        </div>

        <label class="nav-burger" for="nav-toggle" aria-label="Open menu">
            <i class="bi bi-list"></i>
        </label>
    </div>

    <input type="checkbox" id="nav-toggle" class="nav-toggle-input" />
    <div class="nav-mobile">
        <a href="#features"><span class="en">Features</span><span class="my">လုပ်ဆောင်ချက်</span></a>
        <a href="#how"><span class="en">How It Works</span><span class="my">အသုံးပြုပုံ</span></a>
        <a href="#pricing"><span class="en">Pricing</span><span class="my">စျေးနှုန်း</span></a>
        <a href="#contact"><span class="en">Contact</span><span class="my">ဆက်သွယ်ရန်</span></a>
        <hr />
        <!-- Get Started CTA (btn-nav-cta is hidden on mobile, so show it here) -->
        <a href="#contact" class="btn-nav-cta" style="text-align:center;border-radius:10px;padding:11px 20px;">
            <span class="en">Get Started Free</span><span class="my">အခမဲ့ စတင်ပါ</span>
        </a>
    </div>
</header>


<!-- ═══════════════════════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════════════════════ -->
<section class="hero" id="home">
    <div class="hero-inner">

        <div class="hero-copy">
            <div class="hero-badge">
                <i class="bi bi-stars"></i>
                <span class="en">Built for Myanmar Businesses, Online Sellers and Growing Teams</span>
                <span class="my">မြန်မာလုပ်ငန်းများ၊ online seller များနှင့် တိုးတက်လာနေသော team များအတွက်</span>
            </div>

            <div class="promo-marquee" aria-label="Launch promotion">
                <div class="promo-marquee-track">
                    <span class="promo-pill">
                        <i class="bi bi-megaphone-fill"></i>
                        <span class="en">Launch Promotion: Enjoy Pro free for 1 month</span>
                        <span class="my">မိတ်ဆက်အထူးအစီအစဉ် - Pro package ကို ၁ လ အခမဲ့အသုံးပြုနိုင်ပါသည်</span>
                    </span>
                    <span class="promo-pill">
                        <i class="bi bi-globe2"></i>
                        <span class="en">For Myanmar businesses, shops and online sellers moving toward digital operations</span>
                        <span class="my">digital စနစ်သို့ ပြောင်းလဲနေသော မြန်မာလုပ်ငန်းများ၊ ဆိုင်များနှင့် online seller များအတွက်</span>
                    </span>
                    <span class="promo-pill">
                        <i class="bi bi-graph-up-arrow"></i>
                        <span class="en">Track stock, sales and profit from one simple system</span>
                        <span class="my">စတော့၊ ရောင်းအားနှင့် အမြတ်ကို system တစ်ခုတည်းမှ စီမံနိုင်ပါသည်</span>
                    </span>
                    <span class="promo-pill" aria-hidden="true">
                        <i class="bi bi-megaphone-fill"></i>
                        <span class="en">Launch Promotion: Enjoy Pro free for 1 month</span>
                        <span class="my">မိတ်ဆက်အထူးအစီအစဉ် - Pro package ကို ၁ လ အခမဲ့အသုံးပြုနိုင်ပါသည်</span>
                    </span>
                </div>
            </div>

            <h1 class="hero-title">
                <span class="en">Run Your Business Smarter.<br /><span class="hero-title-accent">Grow Faster in Digital Myanmar.</span></span>
                <span class="my">သင့်လုပ်ငန်းကို ပိုမိုစနစ်တကျ လည်ပတ်ပါ။<br /><span class="hero-title-accent">Digital Myanmar မှာ ပိုမြန်စွာ တိုးတက်ပါ။</span></span>
            </h1>

            <p class="hero-sub">
                <span class="en">Built for Myanmar businesses going digital, StockEasy helps shops, online sellers, wholesalers and service teams manage stock, sales, profit and daily operations from one simple dashboard.</span>
                <span class="my">Digital စနစ်သို့ ပြောင်းလဲလိုသော မြန်မာလုပ်ငန်းများအတွက် StockEasy သည် ဆိုင်များ၊ online seller များ၊ wholesale လုပ်ငန်းများနှင့် service team များ၏ စတော့၊ ရောင်းအား၊ အမြတ်နှင့် နေ့စဉ်လုပ်ငန်းဆောင်တာများကို dashboard တစ်ခုတည်းမှ လွယ်ကူစွာ စီမံနိုင်စေပါသည်။</span>
            </p>

            <div class="hero-btns">
                <a href="#contact" class="btn-hero-primary">
                    <i class="bi bi-rocket-takeoff-fill"></i>
                    <span class="en">Get Started Free</span><span class="my">အခမဲ့ စတင်ပါ</span>
                </a>
                <a href="/Account/Login" class="btn-hero-ghost">
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span class="en">Sign In</span><span class="my">ဝင်ရောက်ပါ</span>
                </a>
            </div>

            <div class="hero-trust">
                <span><i class="bi bi-check-circle-fill"></i> <span class="en">1 month Pro trial</span><span class="my">Pro ကို ၁ လ အခမဲ့စမ်းသုံးနိုင်သည်</span></span>
                <span><i class="bi bi-check-circle-fill"></i> <span class="en">Works for shops and online business</span><span class="my">ဆိုင်နှင့် online business နှစ်မျိုးလုံးအတွက် သင့်တော်သည်</span></span>
                <span><i class="bi bi-check-circle-fill"></i> <span class="en">Supports digital transformation</span><span class="my">digital transformation ကို အထောက်အကူပြုသည်</span></span>
            </div>
        </div>

        <!-- CSS-drawn mockup dashboard -->
        <div class="hero-mockup" aria-hidden="true">
            <div class="mockup-browser">
                <div class="mockup-titlebar">
                    <span class="dot red"></span>
                    <span class="dot yellow"></span>
                    <span class="dot green"></span>
                    <span class="mockup-url">app.stockeasy.io/dashboard</span>
                </div>
                <div class="mockup-body">
                    <div class="mockup-stats">
                        <div class="mockup-stat">
                            <div class="mockup-stat-label">Products</div>
                            <div class="mockup-stat-value">1,248</div>
                        </div>
                        <div class="mockup-stat">
                            <div class="mockup-stat-label">Sales Today</div>
                            <div class="mockup-stat-value">84</div>
                        </div>
                        <div class="mockup-stat">
                            <div class="mockup-stat-label">Revenue</div>
                            <div class="mockup-stat-value">K 2.4M</div>
                        </div>
                    </div>
                    <div class="mockup-section-label">Recent Sales</div>
                    <div class="mockup-table">
                        <div class="mockup-table-row header">
                            <span>Product</span><span>Qty</span><span>Amount</span>
                        </div>
                        <div class="mockup-table-row">
                            <span class="row-dot indigo"></span>
                            <span>Cotton Shirt — M/White</span><span>3</span><span>K 45,000</span>
                        </div>
                        <div class="mockup-table-row">
                            <span class="row-dot green"></span>
                            <span>Silk Scarf — Blue</span><span>1</span><span>K 28,000</span>
                        </div>
                        <div class="mockup-table-row">
                            <span class="row-dot purple"></span>
                            <span>Denim Jacket — L</span><span>2</span><span>K 92,000</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="mockup-float-1">
                <i class="bi bi-graph-up-arrow"></i>
                <div><div class="float-value">+24%</div><div class="float-label">This Month</div></div>
            </div>
            <div class="mockup-float-2">
                <i class="bi bi-shield-check-fill"></i>
                <div><div class="float-value">99.9%</div><div class="float-label">Uptime</div></div>
            </div>
        </div>

    </div>
</section>


