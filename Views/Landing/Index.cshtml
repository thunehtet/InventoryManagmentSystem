<!-- ═══════════════════════════════════════════════════════════
     PRICING
     ═══════════════════════════════════════════════════════════ -->
<section class="pricing" id="pricing">
    <div class="section-inner">
        <div class="section-header fade-up">
            <span class="section-label"><span class="en">Transparent Pricing</span><span class="my">ပွင့်လင်းသောစျေးနှုန်း</span></span>
            <h2 class="section-title">
                <span class="en">Plans That Grow With You</span>
                    <span class="my">သင်နှင့်အတူ တိုးတက်သောအစီအစဉ်</span>
            </h2>
            <p class="section-sub">
                <span class="en">Start free and scale as your business grows. No hidden fees.</span>
                <span class="my">အခမဲ့ စတင်ပြီး လုပ်ငန်းကြီးထွားသည်နှင့် တိုးချဲ့နိုင်သည်။ ဝှက်ထားသောကြေးများ မရှိပါ။</span>
            </p>
        </div>

@{
            var landingPlans = ViewBag.Plans as List<ClothInventoryApp.Models.Plan>
                               ?? new List<ClothInventoryApp.Models.Plan>();
            // Feature the second plan (index 1) when ≥2 plans exist, otherwise first
            int featuredPlanIdx = landingPlans.Count >= 2 ? 1 : 0;
        }

        <div class="pricing-grid">

        @if (!landingPlans.Any())
        {
            <!-- Fallback: no plans configured yet -->
            <div class="price-card fade-up" style="grid-column:1/-1;text-align:center;padding:3rem 2rem;color:#94a3b8;">
                <i class="bi bi-info-circle" style="font-size:2rem;display:block;margin-bottom:1rem;"></i>
                <span class="en">Pricing plans coming soon. Contact us for details.</span>
                <span class="my">စျေးနှုန်းအစီအစဉ်များ မကြာမီ ရောက်ရှိမည်။ ဆက်သွယ်ပါ။</span>
            </div>
        }
        else
        {
            for (int pi = 0; pi < landingPlans.Count; pi++)
            {
                var lp          = landingPlans[pi];
                bool isFeatured = (pi == featuredPlanIdx && landingPlans.Count > 1);
                bool isFree     = lp.PriceMonthly == 0;
                bool isCustom   = !isFree && lp.MaxUsers == null && lp.MaxProducts == null
                                  && lp.PriceMonthly == 0;
                var  planFeats  = lp.PlanFeatures
                                    .Where(pf => pf.IsEnabled && pf.Feature != null)
                                    .OrderBy(pf => pf.Feature.Name)
                                    .ToList();

                <div class="price-card @(isFeatured ? "featured" : "") fade-up">

                    @if (isFeatured)
                    {
                        <div class="price-ribbon">
                            <span class="en">Most Popular</span>
                            <span class="my">အကြိုက်ဆုံး</span>
                        </div>
                    }

                    <!-- Plan name -->
                    <div class="price-plan @(isFeatured ? "featured" : "")">@lp.Name</div>

                    <!-- Price -->
                    <div class="price-amount">
                        @if (isFree)
                        {
                            <span class="price-value">
                                <span class="en">Free</span>
                                <span class="my">အခမဲ့</span>
                            </span>
                        }
                        else
                        {
                            
                            <span class="price-value">@lp.PriceMonthly.ToString("N0")</span>
                                    <span class="price-currency"> MMK</span>
                        }
                    </div>

                    <!-- Period / subtitle -->
                    <div class="price-period">
                        @if (isFree)
                        {
                            <span class="en">Forever free</span>
                            <span class="my">အမြဲအခမဲ့</span>
                        }
                        else
                        {
                            <span class="en">Monthly price</span>
                            <span class="my">တစ်လစာ စျေးနှုန်း</span>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(lp.Description))
                    {
                        <div class="price-period">
                            @lp.Description
                        </div>
                    }
                    else if (!isFree)
                    {
                        <div class="price-period">
                            <span class="en">Billed per month</span>
                            <span class="my">တစ်လလျှင် ကောက်ခံပါသည်</span>
                        </div>
                    }

                    <!-- Feature list -->
                    <ul class="price-features">
                        <!-- Users -->
                        <li>
                            <i class="bi bi-check2"></i>
                            @if (lp.MaxUsers.HasValue)
                            {
                                <span class="en">Up to @lp.MaxUsers users</span>
                                <span class="my">အသုံးပြုသူ @lp.MaxUsers ယောက်</span>
                            }
                            else
                            {
                                <span class="en">Unlimited users</span>
                                <span class="my">အသုံးပြုသူ အကန့်အသတ်မဲ့</span>
                            }
                        </li>
                        <!-- Products -->
                        <li>
                            <i class="bi bi-check2"></i>
                            @if (lp.MaxProducts.HasValue)
                            {
                                <span class="en">@lp.MaxProducts products</span>
                                <span class="my">ကုန်ပစ္စည်း @lp.MaxProducts</span>
                            }
                            else
                            {
                                <span class="en">Unlimited products</span>
                                <span class="my">ကုန်ပစ္စည်း အကန့်အသတ်မဲ့</span>
                            }
                        </li>
                        <!-- Variants (if capped) -->
                        @if (lp.MaxVariants.HasValue)
                        {
                            <li>
                                <i class="bi bi-check2"></i>
                                <span class="en">@lp.MaxVariants variants</span>
                                <span class="my">မျိုးကွဲ @lp.MaxVariants</span>
                            </li>
                        }
                        <!-- Enabled features from DB -->
                        @foreach (var pf in planFeats)
                        {
                            <li><i class="bi bi-check2"></i> <span>@pf.Feature.Name</span></li>
                        }
                    </ul>

                    <!-- CTA button -->
                    <a href="#contact" class="btn-price @(isFeatured ? "featured" : "")">
                        @if (isFree)
                        {
                            <span class="en">Get Started Free</span>
                            <span class="my">အခမဲ့ စတင်ပါ</span>
                        }
                        else
                        {
                            <span class="en">Get Started</span>
                            <span class="my">စတင်ပါ</span>
                        }
                    </a>

                </div>
            }
        }

        </div>
    </div>
</section>


