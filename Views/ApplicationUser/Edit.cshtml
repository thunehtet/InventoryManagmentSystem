@model ClothInventoryApp.Dtos.ApplicationUser.ApplicationUserEditDto
@{
    ViewData["Title"] = "Edit User";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" asp-append-version="true" />
}

<div class="product-index-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <h1 class="product-hero-title">
                <i class="bi bi-person-gear"></i> Edit User
            </h1>
            <p class="product-hero-sub">@Model.FullName</p>
        </div>
        <a asp-action="Index" class="btn-modern-secondary hero-align-center">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>

    <div class="product-table-card product-form-card">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="TenantId" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label fw-semibold"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
                <div class="form-text">Also used as the login username.</div>
            </div>

            <hr class="my-3" />
            <p class="fw-semibold mb-1 text-heading-sm">Reset Password</p>
            <p class="text-muted small mb-3">Leave blank to keep the current password unchanged.</p>

            <div class="mb-4">
                <label asp-for="NewPassword" class="form-label fw-semibold">New Password</label>
                <input asp-for="NewPassword" type="password" class="form-control" placeholder="Leave blank to keep unchanged" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="mb-4 d-flex gap-4">
                <div class="form-check">
                    <input asp-for="IsTenantAdmin" class="form-check-input" />
                    <label asp-for="IsTenantAdmin" class="form-check-label">Admin role</label>
                </div>
                <div class="form-check">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">@Localizer["Active"]</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn-modern-primary">
                    <i class="bi bi-check-circle-fill"></i> Save Changes
                </button>
                <a asp-action="Index" class="btn btn-light">@Localizer["Cancel"]</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
