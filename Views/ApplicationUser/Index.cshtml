@model IEnumerable<ClothInventoryApp.Models.ApplicationUser>
@{
    ViewData["Title"] = "Manage Users";
    var currentUserId = ViewBag.CurrentUserId as string;
    bool canAdd     = (bool)(ViewBag.CanAddUser ?? true);
    int  userCount  = (int)(ViewBag.UserCount ?? 0);
    int? userMax    = ViewBag.UserMax as int?;
}

<div class="product-index-shell">

    <div class="product-hero">
        <div class="product-hero-content">
            <h1>Manage Users</h1>
            <p>Add and manage staff accounts within your workspace.</p>
            <div class="hero-actions">
                @if (canAdd)
                {
                    <a asp-action="Create" class="btn-modern-primary">
                        <i class="bi bi-person-plus-fill"></i> Add User
                    </a>
                }
                else
                {
                    <span class="btn-modern-primary btn-disabled-static"
                          title="User limit reached — upgrade your plan">
                        <i class="bi bi-person-plus-fill"></i> Add User
                    </span>
                }
            </div>
        </div>

        <div class="product-hero-side">
            <div class="hero-stat-card">
                <div class="hero-stat-icon">
                    <i class="bi bi-people"></i>
                </div>
                <div class="hero-stat-title">Team Members</div>
                <div class="hero-stat-text">
                    @userCount @(userMax.HasValue ? $"/ {userMax} (plan limit)" : "users") total
                </div>
                @if (!canAdd)
                {
                    <div class="warning-note">
                        <i class="bi bi-lock-fill me-1"></i> Plan limit reached
                    </div>
                }
            </div>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @{ var aupg = ViewBag.Pagination as ClothInventoryApp.Models.PaginationViewModel; }
    <div class="product-table-card">
        <div class="table-responsive-modern">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Last Login</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="empty-state">No users found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var user in Model)
                        {
                            var isSelf = user.Id == currentUserId;
                            var initial = user.FullName.Length > 0 ? user.FullName[0].ToString().ToUpper() : "?";
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="user-avatar-circle @(isSelf ? "is-you" : "")">@initial</div>
                                        <div>
                                            <div class="fw-semibold text-heading-sm">
                                                @user.FullName
                                                @if (isSelf)
                                                {
                                                    <span class="you-chip"><i class="bi bi-person-fill"></i> You</span>
                                                }
                                            </div>
                                            <div class="table-cell-xs-muted">Since @Html.TenantDate(user.CreatedAt, "MMM yyyy")</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="table-cell-sm-muted">@user.Email</td>
                                <td>
                                    <span class="badge-pill @(user.IsTenantAdmin ? "badge-role-admin" : "badge-role-staff")">
                                        @(user.IsTenantAdmin ? "Admin" : "Staff")
                                    </span>
                                </td>
                                <td>
                                    <span class="badge-pill @(user.IsActive ? "badge-status-active" : "badge-status-inactive")">
                                        @(user.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="table-cell-sm-faded">
                                    @(user.LastLoginAt.HasValue ? Html.TenantDate(user.LastLoginAt, "dd MMM yyyy HH:mm") : "Never")
                                </td>
                                <td>
                                    <div class="table-actions">
                                        @if (!isSelf)
                                        {
                                            <a asp-action="Edit" asp-route-id="@user.Id" class="action-btn action-btn-edit" title="Edit">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@user.Id" class="action-btn action-btn-delete" title="Delete">
                                                <i class="bi bi-trash-fill"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (aupg != null) { @await Html.PartialAsync("_Pagination", aupg) }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/create-product.css" asp-append-version="true" />
}
