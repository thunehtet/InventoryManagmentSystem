@model ClothInventoryApp.Dtos.ApplicationUser.ApplicationUserCreateDto
@{
    ViewData["Title"] = "Add User";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" asp-append-version="true" />
}

<div class="product-index-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <h1 class="product-hero-title">
                <i class="bi bi-person-plus-fill"></i> Add User
            </h1>
            <p class="product-hero-sub">Create a new staff account for your workspace</p>
        </div>
        <a asp-action="Index" class="btn-modern-secondary" style="align-self:center">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>

    <div class="product-table-card product-form-card">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label fw-semibold"></label>
                <input asp-for="FullName" class="form-control" placeholder="e.g. Kyaw Zin" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold"></label>
                <input asp-for="Email" class="form-control" placeholder="staff@company.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
                <div class="form-text">This will also be used as the login username.</div>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold">Default Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Min 8 characters" />
                <span asp-validation-for="Password" class="text-danger small"></span>
                <div class="form-text">Share this with the user — they can change it after first login.</div>
            </div>

            <div class="mb-4 d-flex gap-4">
                <div class="form-check">
                    <input asp-for="IsTenantAdmin" class="form-check-input" />
                    <label asp-for="IsTenantAdmin" class="form-check-label">Admin role</label>
                </div>
                <div class="form-check">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">@Localizer["Active"]</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn-modern-primary">
                    <i class="bi bi-person-plus-fill"></i> Create User
                </button>
                <a asp-action="Index" class="btn btn-light">@Localizer["Cancel"]</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
