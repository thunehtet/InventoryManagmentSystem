@model ClothInventoryApp.Models.ApplicationUser
@{
    ViewData["Title"] = Model.FullName;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" asp-append-version="true" />
}

<div class="product-index-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <h1 class="product-hero-title">
                <i class="bi bi-person-circle"></i> @Model.FullName
            </h1>
            <p class="product-hero-sub">
                @(Model.IsTenantAdmin ? "Admin" : "Staff") · @(Model.IsActive ? "Active" : "Inactive")
            </p>
        </div>
        <div class="d-flex gap-2 hero-align-center">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-modern-primary">
                <i class="bi bi-pencil-fill"></i> Edit
            </a>
            <a asp-action="Index" class="btn-modern-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <div class="product-table-card product-form-card">
        <div class="product-detail-card">
            <div class="product-detail-row">
                <span class="product-detail-label">Full Name</span>
                <span class="product-detail-value fw-semibold">@Model.FullName</span>
            </div>
            <div class="product-detail-row">
                <span class="product-detail-label">Email / Username</span>
                <span class="product-detail-value">@(Model.Email ?? "—")</span>
            </div>
            <div class="product-detail-row">
                <span class="product-detail-label">Role</span>
                <span class="product-detail-value">
                    <span class="badge-pill @(Model.IsTenantAdmin ? "badge-role-admin" : "badge-role-staff")">
                        @(Model.IsTenantAdmin ? "Admin" : "Staff")
                    </span>
                </span>
            </div>
            <div class="product-detail-row">
                <span class="product-detail-label">Status</span>
                <span class="product-detail-value">
                    <span class="badge-pill @(Model.IsActive ? "badge-status-active" : "badge-status-inactive")">
                        @(Model.IsActive ? "Active" : "Inactive")
                    </span>
                </span>
            </div>
            <div class="product-detail-row">
                <span class="product-detail-label">Last Login</span>
                <span class="product-detail-value">
                    @(Model.LastLoginAt.HasValue ? Html.TenantDate(Model.LastLoginAt, "dd MMM yyyy HH:mm") : "Never logged in")
                </span>
            </div>
            <div class="product-detail-row">
                <span class="product-detail-label">Member Since</span>
                <span class="product-detail-value">@Html.TenantDate(Model.CreatedAt, "dd MMM yyyy")</span>
            </div>
        </div>
    </div>
</div>
