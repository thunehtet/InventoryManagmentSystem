@using ClothInventoryApp.Services.Feature
@using ClothInventoryApp.Services.Tenant
@using ClothInventoryApp.Data
@using Microsoft.EntityFrameworkCore
@inject IFeatureService FeatureService
@inject ITenantProvider TenantProvider
@inject AppDbContext DbContext
@{
    bool hasSales = false, hasFinance = false, hasTextiles = false,
         hasCustomers = false, hasDashboard = false, hasSaleProfit = false;
    string workspaceName = "StockEasy";
    string? workspaceLogoUrl = null;
    if (!User.IsInRole("SuperAdmin") && User.Identity?.IsAuthenticated == true)
    {
        try
        {
            var _tid    = TenantProvider.GetTenantId();
            var tenant = await DbContext.Tenants.AsNoTracking().FirstOrDefaultAsync(t => t.Id == _tid);
            if (tenant != null)
            {
                workspaceName = tenant.Name;
                workspaceLogoUrl = tenant.LogoUrl;
            }
            hasSales      = await FeatureService.HasFeatureAsync(_tid, "sales");
            hasSaleProfit = await FeatureService.HasFeatureAsync(_tid, "sale_profit");
            hasCustomers  = await FeatureService.HasFeatureAsync(_tid, "customers");
            hasDashboard  = await FeatureService.HasFeatureAsync(_tid, "dashboard");
            hasFinance    = await FeatureService.HasFeatureAsync(_tid, "finance");
            hasTextiles   = await FeatureService.HasFeatureAsync(_tid, "textiles");
        }
        catch { }
    }
}
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StockEasy</title>
    <link rel="icon" type="image/png" href="~/images/websitelogo.png" asp-append-version="true" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+Myanmar:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="modern-body @(User.IsInRole("SuperAdmin") && User.Identity?.IsAuthenticated == true ? "sa-body" : "") @(CultureInfo.CurrentUICulture.Name.StartsWith("my", StringComparison.OrdinalIgnoreCase) ? "culture-my" : "")"
      data-controller="@ViewContext.RouteData.Values["controller"]"
      data-action="@ViewContext.RouteData.Values["action"]">

    <!-- Sidebar backdrop (mobile) -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="app-shell">
        <aside class="sidebar" id="sidebar" data-initial>
            <div class="sidebar-brand" id="sidebarBrand" role="button" tabindex="0">
                <div class="brand-logo">
                    @if (!string.IsNullOrWhiteSpace(workspaceLogoUrl))
                    {
                        <img src="@workspaceLogoUrl" alt="@workspaceName" />
                    }
                    else
                    {
                        <span class="brand-logo-fallback">@workspaceName.Substring(0, 1).ToUpperInvariant()</span>
                    }
                </div>
                <div>
                    <div class="brand-title">@workspaceName</div>
                    <div class="brand-subtitle">@Localizer["Inventory Manager"]</div>
                </div>
            </div>

            @if (User.IsInRole("SuperAdmin"))
            {
            <!-- ── SuperAdmin navigation ── -->
            <nav class="sidebar-nav">
                <div class="nav-section-title">@Localizer["System"]</div>

                <a asp-controller="SuperAdmin" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-speedometer2"></i>
                    <span>@Localizer["Dashboard"]</span>
                </a>

                <div class="nav-section-title">@Localizer["Management"]</div>

                <a asp-controller="Tenant" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-building"></i>
                    <span>@Localizer["Tenants"]</span>
                </a>

                <a asp-controller="Plan" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-layers-fill"></i>
                    <span>@Localizer["Plans"]</span>
                </a>

                <a asp-controller="Feature" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-toggles"></i>
                    <span>@Localizer["Features"]</span>
                </a>

                <a asp-controller="PlanFeature" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-diagram-3-fill"></i>
                    <span>@Localizer["Plan Features"]</span>
                </a>

                <a asp-controller="TenantFeatureOverride" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-sliders"></i>
                    <span>@Localizer["Tenant Overrides"]</span>
                </a>

                <a asp-controller="Subscription" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-credit-card-fill"></i>
                    <span>@Localizer["Subscriptions"]</span>
                </a>

                <a asp-controller="Subscription" asp-action="History" class="nav-link-modern">
                    <i class="bi bi-clock-history"></i>
                    <span>@Localizer["Sub History"]</span>
                </a>

                <div class="nav-section-title">@Localizer["Inbox"]</div>

                <a asp-controller="InquiryBox" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-envelope-fill"></i>
                    <span>@Localizer["Inquiry Box"]</span>
                    @if ((int)(ViewBag.InquiryUnread ?? 0) > 0)
                    {
                        <span class="badge bg-danger ms-auto">@ViewBag.InquiryUnread</span>
                    }
                </a>
            </nav>
            }
            else
            {
            <!-- ── Tenant user navigation ── -->
            <nav class="sidebar-nav">
                <div class="nav-section-title">@Localizer["Main"]</div>

                <a asp-controller="Home" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-grid-1x2-fill"></i>
                    <span>@Localizer["Overview"]</span>
                </a>

                @if (User.IsInRole("Admin"))
                {
                @if (hasDashboard)
                {
                <a asp-controller="Dashboard" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-bar-chart-line-fill"></i>
                    <span>@Localizer["Dashboard"]</span>
                </a>
                }
                else
                {
                <span class="nav-link-modern nav-link-locked" title="Upgrade to Pro">
                    <i class="bi bi-bar-chart-line-fill"></i>
                    <span>@Localizer["Dashboard"]</span>
                    <i class="bi bi-lock-fill ms-auto nav-lock-icon"></i>
                </span>
                }

                @if (hasFinance)
                {
                <a asp-controller="Finance" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-cash-coin"></i>
                    <span>@Localizer["Finance Dashboard"]</span>
                </a>
                }
                else
                {
                <span class="nav-link-modern nav-link-locked" title="Upgrade to Pro">
                    <i class="bi bi-cash-coin"></i>
                    <span>@Localizer["Finance Dashboard"]</span>
                    <i class="bi bi-lock-fill ms-auto nav-lock-icon"></i>
                </span>
                }
                }

                <div class="nav-section-title">@Localizer["Inventory"]</div>

                <a asp-controller="Products" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-box-seam-fill"></i>
                    <span>@Localizer["Products"]</span>
                </a>

                <a asp-controller="ProductVariants" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-tags-fill"></i>
                    <span>@Localizer["Variants"]</span>
                </a>

                @if (hasTextiles)
                {
                <a asp-controller="Textile" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-tags-fill"></i>
                    <span>@Localizer["Textile List"]</span>
                </a>
                }
                else
                {
                <span class="nav-link-modern nav-link-locked" title="Upgrade to Pro">
                    <i class="bi bi-tags-fill"></i>
                    <span>@Localizer["Textile List"]</span>
                    <i class="bi bi-lock-fill ms-auto nav-lock-icon"></i>
                </span>
                }

                <a asp-controller="Stock" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-plus-circle-fill"></i>
                    <span>@Localizer["Stock Movement"]</span>
                </a>

                <a asp-controller="Stock" asp-action="Inventory" class="nav-link-modern">
                    <i class="bi bi-clock-history"></i>
                    <span>@Localizer["Inventory Log"]</span>
                </a>

                <div class="nav-section-title">@Localizer["Business"]</div>

                @if (hasSales)
                {
                <a asp-controller="Sales" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-bag-check-fill"></i>
                    <span>@Localizer["Sales"]</span>
                </a>
                }
                else
                {
                <span class="nav-link-modern nav-link-locked" title="Upgrade to Starter">
                    <i class="bi bi-bag-check-fill"></i>
                    <span>@Localizer["Sales"]</span>
                    <i class="bi bi-lock-fill ms-auto nav-lock-icon"></i>
                </span>
                }

                @if (hasCustomers)
                {
                <a asp-controller="Customer" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-people-fill"></i>
                    <span>@Localizer["Customers"]</span>
                </a>
                }
                else
                {
                <span class="nav-link-modern nav-link-locked" title="Upgrade to Starter">
                    <i class="bi bi-people-fill"></i>
                    <span>@Localizer["Customers"]</span>
                    <i class="bi bi-lock-fill ms-auto nav-lock-icon"></i>
                </span>
                }

                @if (User.IsInRole("Admin"))
                {
                @if (hasFinance)
                {
                <a asp-controller="CashTransaction" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-wallet2"></i>
                    <span>@Localizer["Expenses"]</span>
                </a>
                }
                else
                {
                <span class="nav-link-modern nav-link-locked" title="Upgrade to Pro">
                    <i class="bi bi-wallet2"></i>
                    <span>@Localizer["Expenses"]</span>
                    <i class="bi bi-lock-fill ms-auto nav-lock-icon"></i>
                </span>
                }

                <a asp-controller="ApplicationUser" asp-action="Index" class="nav-link-modern">
                    <i class="bi bi-people-fill"></i>
                    <span>@Localizer["Manage Users"]</span>
                </a>
                }
            </nav>
            }
        </aside>
        <script>(function(){if(window.innerWidth<=900){document.getElementById('sidebar').classList.add('collapsed');}}());</script>

        <div class="main-panel">
            <header class="topbar">
                <div class="topbar-left">
                    <button class="menu-btn" id="menuToggle" type="button" aria-label="Toggle menu">
                        <i class="bi bi-list"></i>
                    </button>

                    <div class="topbar-search">
                        <i class="bi bi-search"></i>
                        <input type="text" id="topbarSearch"
                               placeholder="@Localizer["Search products, SKU, stock…"]"
                               value="@(ViewBag.Search ?? "")"
                               autocomplete="off" />
                    </div>
                </div>

                <div class="topbar-right">
                    <div class="topbar-chip">
                        <i class="bi bi-stars"></i>
                        <span>@Localizer["Smart Inventory"]</span>
                    </div>

                    <!-- Language switcher -->
                    <div class="lang-switcher">
                        <a asp-controller="Language" asp-action="Set"
                           asp-route-culture="en"
                           asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                           class="lang-btn @(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en" ? "lang-active" : "")">
                            EN
                        </a>
                        <span class="lang-sep">|</span>
                        <a asp-controller="Language" asp-action="Set"
                           asp-route-culture="my"
                           asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                           class="lang-btn @(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "my" ? "lang-active" : "")">
                            MY
                        </a>
                    </div>

                    <div class="user-dropdown">
                        <button class="user-btn" onclick="toggleUserMenu()" type="button">
                            <div class="user-avatar">
                                <i class="bi bi-person-circle"></i>
                            </div>
                            <span class="user-name">@User.Identity?.Name</span>
                            <i class="bi bi-chevron-down"></i>
                        </button>

                        <div id="userMenu" class="user-menu">
                            <a href="#" class="user-menu-item">
                                <i class="bi bi-person"></i>
                                @Localizer["Profile"]
                            </a>
                            <a asp-controller="Account" asp-action="ChangePassword" class="user-menu-item">
                                <i class="bi bi-key-fill"></i>
                                @Localizer["Change Password"]
                            </a>
                            <a href="#" class="user-menu-item">
                                <i class="bi bi-gear"></i>
                                @Localizer["Settings"]
                            </a>
                            <div class="user-menu-divider"></div>
                            <!-- Language switch — always accessible, including on mobile -->
                            <div class="user-menu-lang-row">
                                <i class="bi bi-translate"></i>
                                <span>@Localizer["Language"]</span>
                                <div class="user-menu-lang-btns">
                                    <a asp-controller="Language" asp-action="Set"
                                       asp-route-culture="en"
                                       asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                                       class="umenu-lang @(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en" ? "umenu-lang--active" : "")">EN</a>
                                    <span class="user-menu-lang-sep">|</span>
                                    <a asp-controller="Language" asp-action="Set"
                                       asp-route-culture="my"
                                       asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                                       class="umenu-lang @(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "my" ? "umenu-lang--active" : "")">MY</a>
                                </div>
                            </div>
                            <div class="user-menu-divider"></div>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="user-menu-item logout-btn">
                                    <i class="bi bi-box-arrow-right"></i>
                                    @Localizer["Logout"]
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </header>

            <main class="page-content">
                @RenderBody()
            </main>

            <!-- Mobile bottom navigation — SuperAdmin -->
            @if (User.IsInRole("SuperAdmin"))
            {
            <nav class="mob-bottom-nav" id="mobBottomNav">
                <a href="/SuperAdmin/Index" class="mob-nav-item">
                    <i class="bi bi-speedometer2"></i>
                    <span>@Localizer["Dashboard"]</span>
                </a>
                <a href="/Tenant/Index" class="mob-nav-item">
                    <i class="bi bi-building"></i>
                    <span>@Localizer["Tenants"]</span>
                </a>
                <a href="/Plan/Index" class="mob-nav-item mob-nav-center mob-nav-sa-center">
                    <i class="bi bi-layers-fill"></i>
                    <span>@Localizer["Plans"]</span>
                </a>
                <a href="/Subscription/Index" class="mob-nav-item">
                    <i class="bi bi-credit-card-fill"></i>
                    <span>@Localizer["Subs"]</span>
                </a>
                <a href="/InquiryBox/Index" class="mob-nav-item">
                    <i class="bi bi-envelope-fill"></i>
                    <span>@Localizer["Inbox"]</span>
                </a>
                <a href="/TenantFeatureOverride/Index" class="mob-nav-item">
                    <i class="bi bi-sliders"></i>
                    <span>@Localizer["Overrides"]</span>
                </a>
            </nav>
            }

            <!-- Mobile bottom navigation — Tenant users -->
            @if (!User.IsInRole("SuperAdmin"))
            {
            <nav class="mob-bottom-nav" id="mobBottomNav">
                <a href="/Home/Index" class="mob-nav-item">
                    <i class="bi bi-grid-1x2-fill"></i>
                    <span>@Localizer["Overview"]</span>
                </a>
                <a href="/Stock/Inventory" class="mob-nav-item">
                    <i class="bi bi-box-seam-fill"></i>
                    <span>@Localizer["Inventory"]</span>
                </a>
                @if (hasSales)
                {
                <a href="/Sales/Create" class="mob-nav-item mob-nav-center">
                    <i class="bi bi-plus-circle-fill"></i>
                    <span>@Localizer["New Sale"]</span>
                </a>
                <a href="/Sales/Index" class="mob-nav-item">
                    <i class="bi bi-bag-check-fill"></i>
                    <span>@Localizer["Sales"]</span>
                </a>
                }
                else
                {
                <span class="mob-nav-item mob-nav-center mob-nav-locked">
                    <i class="bi bi-plus-circle-fill"></i>
                    <span>@Localizer["New Sale"]</span>
                </span>
                <span class="mob-nav-item mob-nav-locked">
                    <i class="bi bi-bag-check-fill"></i>
                    <span>@Localizer["Sales"]</span>
                </span>
                }
                @if (hasFinance)
                {
                <a href="/Finance/Index" class="mob-nav-item">
                    <i class="bi bi-cash-coin"></i>
                    <span>@Localizer["Finance"]</span>
                </a>
                }
                else
                {
                <span class="mob-nav-item mob-nav-locked">
                    <i class="bi bi-cash-coin"></i>
                    <span>@Localizer["Finance"]</span>
                </span>
                }
            </nav>
            }
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/layout.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
