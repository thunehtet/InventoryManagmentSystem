@using ClothInventoryApp.Dto.Textile
@model IEnumerable<ViewTextileDto>
@{
    ViewData["Title"] = Localizer["Purchases"];
    var currency = ViewData["Currency"] as string ?? "";
    var pg = ViewBag.Pagination as ClothInventoryApp.Models.PaginationViewModel;
}

<div class="product-index-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <div class="hero-kicker">
                <i class="bi bi-box-seam-fill"></i>
                <span>@Localizer["Purchases"]</span>
            </div>
            <h1>@Localizer["Purchase List"]</h1>
            <p>@Localizer["Use this page only for stock replenishment and inventory-related purchases from outside suppliers. Do not record general expenses here."]</p>
            <div class="hero-actions">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn-modern-primary">
                        <i class="bi bi-plus-circle"></i> @Localizer["Record Purchase"]
                    </a>
                }
            </div>
        </div>
        <div class="product-hero-side">
            <div class="hero-stat-card">
                <div class="hero-stat-icon"><i class="bi bi-archive"></i></div>
                <div class="hero-stat-title">@Localizer["Total Records"]</div>
                <div class="hero-stat-text">@(pg?.TotalCount ?? 0) @Localizer["purchase records"]</div>
            </div>
        </div>
    </div>

    <!-- FILTER BAR -->
    <div class="list-filter-bar">
        <form method="get" asp-action="Index" class="filter-form">
            @if (pg != null) { <input type="hidden" name="size" value="@pg.PageSize" /> }
            <div class="filter-search-wrap">
                <i class="bi bi-search filter-search-icon"></i>
                <input type="text" name="search" value="@ViewBag.Search"
                       class="filter-search-input" placeholder="@Localizer["Search item name or supplier..."]" autocomplete="off" />
                @if (!string.IsNullOrWhiteSpace(ViewBag.Search as string))
                {
                    <a href="@Url.Action("Index", new { size = pg?.PageSize ?? 10 })" class="filter-clear-btn" title="@Localizer["Clear"]">
                        <i class="bi bi-x-circle-fill"></i>
                    </a>
                }
            </div>
            <button type="submit" class="filter-search-btn">
                <i class="bi bi-search"></i> @Localizer["Search"]
            </button>
        </form>
    </div>

    <!-- TABLE CARD -->
    <div class="product-table-card">
        <div class="table-responsive-modern">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>@Localizer["Item Name"]</th>
                        <th>@Localizer["Supplier"]</th>
                        <th>@Localizer["Purchase Quantity"]</th>
                        <th>@Localizer["Purchase Date"]</th>
                        <th>@Localizer["Unit Cost"]</th>
                        <th>@Localizer["Total Cost"]</th>
                        <th>@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <div>@(string.IsNullOrWhiteSpace(ViewBag.Search as string) ? Localizer["No purchase records yet."].Value : Localizer["No records match your search"].Value)</div>
                                @if (User.IsInRole("Admin") && string.IsNullOrWhiteSpace(ViewBag.Search as string))
                                {
                                    <a asp-action="Create" class="btn-modern-primary mt-2">@Localizer["Record your first purchase"]</a>
                                }
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Name</td>
                                <td>@item.PurchaseFrom</td>
                                <td>@item.Quantity</td>
                                <td class="text-muted table-cell-sm">@item.PurchaseDate.ToString("dd MMM yyyy")</td>
                                <td>@item.UnitPrice.ToString("N0") @currency</td>
                                <td class="fw-semibold">@item.TotalPrice.ToString("N0") @currency</td>
                                <td>
                                    <div class="table-actions">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="action-btn action-btn-view" title="@Localizer["Details"]"><i class="bi bi-eye-fill"></i></a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn action-btn-edit" title="@Localizer["Edit"]"><i class="bi bi-pencil-fill"></i></a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn action-btn-delete" title="@Localizer["Delete"]"><i class="bi bi-trash-fill"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (pg != null) { @await Html.PartialAsync("_Pagination", pg) }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/product-index.css" />
}
