@model IEnumerable<ClothInventoryApp.Models.Plan>
@{
    ViewData["Title"] = Localizer["Plan Features"];
    Guid? selectedPlanId = ViewBag.SelectedPlanId;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/superadmin.css" asp-append-version="true" />
}

<div class="superadmin-shell">
    <div class="product-hero">
        <div class="product-hero-content">
            <h1 class="product-hero-title"><i class="bi bi-diagram-3-fill"></i> Plan Features</h1>
            <p class="product-hero-sub">Manage which features are enabled per plan</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Create" asp-route-planId="@selectedPlanId" class="sa-btn-add">
                <i class="bi bi-plus-lg"></i> Assign Feature
            </a>
            <a asp-controller="Plan" asp-action="Index" class="sa-btn-back">
                <i class="bi bi-arrow-left"></i> Back to Plans
            </a>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filter by plan -->
    <div class="d-flex gap-2 mb-3 flex-wrap">
        <a asp-action="Index" class="sa-btn-back @(selectedPlanId == null ? "active" : "")">All Plans</a>
        @foreach (var p in (IEnumerable<ClothInventoryApp.Models.Plan>)ViewBag.Plans)
        {
            <a asp-action="Index" asp-route-planId="@p.Id"
               class="sa-btn-back @(selectedPlanId == p.Id ? "active" : "")">@p.Name</a>
        }
    </div>

    @foreach (var plan in Model)
    {
        <div class="product-table-card mb-4">
            <div class="sa-panel-header px-4 pt-3 pb-2">
                <span class="sa-section-dot"></span>
                <h3 class="sa-panel-title">@plan.Name <span class="sa-detail-mono superadmin-mono-sm ms-2">@plan.Code</span></h3>
                <span class="sa-count-badge ms-auto">@plan.PlanFeatures.Count feature(s)</span>
            </div>
            <div class="table-responsive">
                <table class="superadmin-table">
                    <thead>
                        <tr>
                            <th>Feature</th>
                            <th>Code</th>
                            <th>Enabled</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pf in plan.PlanFeatures.OrderBy(x => x.Feature.Name))
                        {
                            <tr>
                                <td class="fw-semibold">@pf.Feature.Name</td>
                                <td><span class="sa-detail-mono">@pf.Feature.Code</span></td>
                                <td>
                                    <span class="status-badge @(pf.IsEnabled ? "active" : "inactive")">
                                        @(pf.IsEnabled ? "Enabled" : "Disabled")
                                    </span>
                                </td>
                                <td>
                                    <div class="table-actions">
                                        <a asp-action="Delete" asp-route-id="@pf.Id"
                                           class="action-btn action-btn-delete" title="Remove">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!plan.PlanFeatures.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-3">No features assigned to this plan.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5">No plans found.</div>
    }
</div>
